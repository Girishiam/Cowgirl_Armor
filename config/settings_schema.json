[
  {
    "name": "theme_info",
    "theme_name": "Cowgirl Armor",
    "theme_version": "1.0.0",
    "theme_author": "You",
    "theme_documentation_url": "https://shopify.dev",
    "theme_support_url": "https://shopify.dev"
  },

  {
    "name": "Favicon & Social",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32×32px or 64×64px PNG — shows in browser tab"
      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Social Sharing Image",
        "info": "1200×630px — shows when sharing links on Facebook, WhatsApp etc."
      }
    ]
  },

  {
    "name": "Brand Gradient",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_gradient",
        "label": "Enable brand gradient globally",
        "default": true,
        "info": "Applies the gradient to buttons, announcement bar, cart, header (if toggled), and more across the whole theme."
      },
      {
        "type": "color",
        "id": "gradient_color_1",
        "label": "Gradient Color 1 — Start",
        "default": "#3A6FE8"
      },
      {
        "type": "color",
        "id": "gradient_color_2",
        "label": "Gradient Color 2 — Middle",
        "default": "#8B52D4"
      },
      {
        "type": "color",
        "id": "gradient_color_3",
        "label": "Gradient Color 3 — End",
        "default": "#CC72E8"
      },
      {
        "type": "select",
        "id": "gradient_direction",
        "label": "Gradient Direction",
        "options": [
          { "value": "135deg", "label": "Diagonal ↘ (default)" },
          { "value": "90deg",  "label": "Horizontal →"         },
          { "value": "180deg", "label": "Vertical ↓"           },
          { "value": "45deg",  "label": "Diagonal ↗"           }
        ],
        "default": "135deg"
      },
      {
        "type": "checkbox",
        "id": "gradient_header",
        "label": "Apply gradient to header background",
        "default": false,
        "info": "When on, the header nav bar will use the gradient. Text automatically switches to white."
      }
    ]
  },

  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg",        "label": "Page Background", "default": "#F8F6F4" },
      { "type": "color", "id": "color_text",       "label": "Body Text",       "default": "#1A1A1A" },
      { "type": "color", "id": "color_accent",     "label": "Accent",          "default": "#8B52D4" },
      { "type": "color", "id": "color_secondary",  "label": "Secondary",       "default": "#CC72E8" },
      { "type": "color", "id": "color_border",     "label": "Border",          "default": "#CCCCCC" },
      { "type": "color", "id": "color_error",      "label": "Error",           "default": "#DC2626" },
      { "type": "color", "id": "color_success",    "label": "Success",         "default": "#16A34A" }
    ]
  },

  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading Font",
        "default": "assistant_n4",
        "info": "Used for titles, headings, pull quotes"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body Font",
        "default": "assistant_n4",
        "info": "Used for paragraphs and general text"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base Font Size",
        "min": 12, "max": 20, "step": 1, "unit": "px", "default": 16
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading Scale",
        "min": 75, "max": 150, "step": 5, "unit": "%", "default": 100,
        "info": "Scales all headings up or down proportionally"
      },
      {
        "type": "range",
        "id": "body_scale",
        "label": "Body Scale",
        "min": 75, "max": 150, "step": 5, "unit": "%", "default": 100
      },
      {
        "type": "range",
        "id": "heading_weight",
        "label": "Heading Weight",
        "min": 300, "max": 900, "step": 100, "default": 700
      },
      {
        "type": "select",
        "id": "heading_text_transform",
        "label": "Heading Transform",
        "options": [
          { "value": "none",       "label": "None"       },
          { "value": "uppercase",  "label": "Uppercase"  },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      },
      {
        "type": "range",
        "id": "heading_letter_spacing",
        "label": "Heading Letter Spacing",
        "min": -2, "max": 10, "step": 1, "unit": "px", "default": 0
      },
      {
        "type": "range",
        "id": "heading_line_height",
        "label": "Heading Line Height",
        "min": 90, "max": 200, "step": 5, "unit": "%", "default": 120,
        "info": "e.g. 120 = 1.2"
      },
      {
        "type": "range",
        "id": "body_weight",
        "label": "Body Font Weight",
        "min": 300, "max": 700, "step": 100, "default": 400
      },
      {
        "type": "range",
        "id": "body_letter_spacing",
        "label": "Body Letter Spacing",
        "min": -1, "max": 5, "step": 1, "unit": "px", "default": 0
      },
      {
        "type": "range",
        "id": "body_line_height",
        "label": "Body Line Height",
        "min": 100, "max": 220, "step": 5, "unit": "%", "default": 170,
        "info": "e.g. 170 = 1.7"
      }
    ]
  },

  {
    "name": "Buttons",
    "settings": [
      { "type": "color", "id": "color_button",       "label": "Button Background", "default": "#3A6FE8" },
      { "type": "color", "id": "color_button_text",  "label": "Button Text",       "default": "#FFFFFF" },
      { "type": "color", "id": "color_button_hover", "label": "Button Hover",      "default": "#8B52D4" },
      { "type": "checkbox", "id": "buttons_uppercase", "label": "Uppercase button text", "default": false },
      { "type": "checkbox", "id": "buttons_shadow",    "label": "Button shadow",         "default": false },
      {
        "type": "range", "id": "buttons_radius",
        "label": "Button Corner Radius", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 4
      },
      {
        "type": "range", "id": "buttons_border_thickness",
        "label": "Button Border Thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1
      }
    ]
  },

  {
    "name": "Layout",
    "settings": [
      {
        "type": "range", "id": "page_width",
        "label": "Page Max Width", "min": 1000, "max": 1920, "step": 20, "unit": "px", "default": 1400
      },
      {
        "type": "range", "id": "content_width",
        "label": "Content Max Width", "min": 480, "max": 1200, "step": 20, "unit": "px", "default": 720,
        "info": "Used for text-heavy pages like editorial and blog"
      },
      {
        "type": "range", "id": "spacing_sections",
        "label": "Section Spacing", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
      },
      {
        "type": "range", "id": "spacing_grid_horizontal",
        "label": "Grid Gap Horizontal", "min": 0, "max": 60, "step": 4, "unit": "px", "default": 20
      },
      {
        "type": "range", "id": "spacing_grid_vertical",
        "label": "Grid Gap Vertical", "min": 0, "max": 60, "step": 4, "unit": "px", "default": 20
      }
    ]
  },

  {
    "name": "Borders & Corners",
    "settings": [
      {
        "type": "range", "id": "border_radius",
        "label": "Card Border Radius", "min": 0, "max": 20, "step": 2, "unit": "px", "default": 0
      },
      {
        "type": "range", "id": "border_thickness",
        "label": "Border Thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1
      },
      {
        "type": "range", "id": "border_opacity",
        "label": "Border Opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100
      }
    ]
  },

  {
    "name": "Shadows",
    "settings": [
      {
        "type": "range", "id": "shadow_opacity",
        "label": "Shadow Opacity", "min": 0, "max": 40, "step": 2, "unit": "%", "default": 10
      },
      {
        "type": "range", "id": "shadow_blur",
        "label": "Shadow Blur", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 20
      }
    ]
  },

  {
    "name": "Product Cards",
    "settings": [
      {
        "type": "select", "id": "card_style", "label": "Card Style",
        "options": [
          { "value": "standard", "label": "Standard" },
          { "value": "card",     "label": "Card"     },
          { "value": "minimal",  "label": "Minimal"  }
        ],
        "default": "standard"
      },
      {
        "type": "select", "id": "image_ratio", "label": "Image Ratio",
        "options": [
          { "value": "adapt",     "label": "Adapt to image" },
          { "value": "portrait",  "label": "Portrait 2:3"   },
          { "value": "square",    "label": "Square 1:1"     },
          { "value": "landscape", "label": "Landscape 4:3"  }
        ],
        "default": "adapt"
      },
      { "type": "checkbox", "id": "show_secondary_image", "label": "Show second image on hover", "default": false },
      { "type": "checkbox", "id": "show_vendor",          "label": "Show vendor",                "default": false },
      { "type": "checkbox", "id": "show_rating",          "label": "Show product rating",        "default": false },
      { "type": "checkbox", "id": "show_sale_badge",      "label": "Show sale badge",            "default": true  },
      {
        "type": "select", "id": "sale_badge_style", "label": "Sale Badge Style",
        "options": [
          { "value": "text",    "label": "Text (SALE)"    },
          { "value": "percent", "label": "Percentage off" }
        ],
        "default": "text"
      }
    ]
  },

  {
    "name": "Cart",
    "settings": [
      {
        "type": "select", "id": "cart_type", "label": "Cart Type",
        "options": [
          { "value": "drawer",       "label": "Drawer"       },
          { "value": "notification", "label": "Notification" },
          { "value": "page",         "label": "Page"         }
        ],
        "default": "notification"
      },
      { "type": "checkbox", "id": "show_cart_note",               "label": "Show order note in cart",         "default": false },
      { "type": "checkbox", "id": "cart_free_shipping_threshold", "label": "Show free shipping progress bar", "default": false },
      { "type": "text",     "id": "cart_free_shipping_amount",    "label": "Free shipping threshold ($)",     "default": "50"  }
    ]
  },

  {
    "name": "Search",
    "settings": [
      { "type": "checkbox", "id": "predictive_search_enabled",     "label": "Enable predictive search", "default": true  },
      { "type": "checkbox", "id": "predictive_search_show_vendor", "label": "Show vendor in results",   "default": false },
      { "type": "checkbox", "id": "predictive_search_show_price",  "label": "Show price in results",    "default": true  }
    ]
  },

  {
    "name": "Social Media",
    "settings": [
      { "type": "text", "id": "social_facebook_link",  "label": "Facebook URL",   "info": "https://facebook.com/yourpage"    },
      { "type": "text", "id": "social_instagram_link", "label": "Instagram URL",  "info": "https://instagram.com/yourhandle" },
      { "type": "text", "id": "social_twitter_link",   "label": "Twitter / X URL" },
      { "type": "text", "id": "social_pinterest_link", "label": "Pinterest URL"   },
      { "type": "text", "id": "social_youtube_link",   "label": "YouTube URL"     },
      { "type": "text", "id": "social_tiktok_link",    "label": "TikTok URL"      }
    ]
  },

  {
    "name": "Badges",
    "settings": [
      { "type": "color", "id": "badge_sale_bg",       "label": "Sale Badge Background", "default": "#DC2626" },
      { "type": "color", "id": "badge_sale_text",     "label": "Sale Badge Text",       "default": "#FFFFFF" },
      { "type": "color", "id": "badge_sold_out_bg",   "label": "Sold Out Background",   "default": "#1A1A1A" },
      { "type": "color", "id": "badge_sold_out_text", "label": "Sold Out Text",         "default": "#FFFFFF" },
      {
        "type": "range", "id": "badge_corner_radius",
        "label": "Badge Corner Radius", "min": 0, "max": 20, "step": 2, "unit": "px", "default": 4
      }
    ]
  },

  {
    "name": "Inputs & Forms",
    "settings": [
      {
        "type": "range", "id": "inputs_radius",
        "label": "Input Corner Radius", "min": 0, "max": 20, "step": 2, "unit": "px", "default": 4
      },
      {
        "type": "range", "id": "inputs_border_thickness",
        "label": "Input Border Thickness", "min": 1, "max": 4, "step": 1, "unit": "px", "default": 1
      },
      { "type": "color", "id": "inputs_bg",           "label": "Input Background",  "default": "#FFFFFF" },
      { "type": "color", "id": "inputs_border_color", "label": "Input Border",      "default": "#CCCCCC" },
      { "type": "color", "id": "inputs_focus_color",  "label": "Input Focus Color", "default": "#8B52D4" }
    ]
  },

  {
    "name": "Drawers",
    "settings": [
      {
        "type": "range", "id": "drawer_overlay_opacity",
        "label": "Overlay Opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 50
      },
      { "type": "color", "id": "drawer_overlay_color", "label": "Overlay Color", "default": "#000000" }
    ]
  },

  {
    "name": "Popups & Modals",
    "settings": [
      {
        "type": "range", "id": "popup_border_radius",
        "label": "Popup Border Radius", "min": 0, "max": 20, "step": 2, "unit": "px", "default": 8
      },
      {
        "type": "range", "id": "popup_border_thickness",
        "label": "Popup Border Thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "default": 1
      },
      {
        "type": "range", "id": "popup_overlay_opacity",
        "label": "Overlay Opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 50
      },
      { "type": "color",    "id": "popup_overlay_color", "label": "Overlay Color",            "default": "#000000" },
      { "type": "checkbox", "id": "popup_show_overlay",  "label": "Show overlay behind popup", "default": true     }
    ]
  },

  {
    "name": "Icons",
    "settings": [
      {
        "type": "range", "id": "icon_size",
        "label": "Icon Size", "min": 16, "max": 48, "step": 2, "unit": "px", "default": 24
      }
    ]
  },

  {
    "name": "Prices",
    "settings": [
      { "type": "color", "id": "price_sale_color", "label": "Sale Price Color", "default": "#DC2626" }
    ]
  },

  {
    "name": "Logo",
    "settings": [
      {
        "type": "range", "id": "logo_width",
        "label": "Logo Width", "min": 50, "max": 300, "step": 10, "unit": "px", "default": 120
      }
    ]
  },

  {
    "name": "Animations",
    "settings": [
      { "type": "checkbox", "id": "animations_reveal_on_scroll", "label": "Reveal sections on scroll", "default": false },
      {
        "type": "select", "id": "animations_type", "label": "Animation Style",
        "options": [
          { "value": "fade",     "label": "Fade In"  },
          { "value": "slide-in", "label": "Slide Up" },
          { "value": "zoom",     "label": "Zoom In"  }
        ],
        "default": "fade"
      },
      { "type": "checkbox", "id": "animations_hover_images", "label": "Zoom images on hover", "default": true }
    ]
  }
]
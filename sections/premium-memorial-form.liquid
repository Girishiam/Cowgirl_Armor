{%- comment -%} Build gradient directly in Liquid {%- endcomment -%}
{%- assign grad_dir   = settings.gradient_direction | default: '135deg' -%}
{%- assign grad_col_1 = settings.gradient_color_1   | default: '#3A6FE8' -%}
{%- assign grad_col_2 = settings.gradient_color_2   | default: '#8B52D4' -%}
{%- assign grad_col_3 = settings.gradient_color_3   | default: '#CC72E8' -%}
{%- assign brand_gradient = 'linear-gradient(' | append: grad_dir | append: ', ' | append: grad_col_1 | append: ' 0%, ' | append: grad_col_2 | append: ' 55%, ' | append: grad_col_3 | append: ' 100%)' -%}

<style>
  .premium-contact-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: {{ brand_gradient }};
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  .premium-contact-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  .premium-contact__container {
    max-width: {{ settings.page_width | default: 1400 }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media screen and (min-width: 1024px) {
    .premium-contact__container {
      grid-template-columns: 1fr 1.5fr;
      gap: 6rem;
      align-items: flex-start;
    }
  }

  .premium-contact__text-col {
    position: sticky;
    top: 120px;
  }

  .premium-contact__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    {%- if section.settings.use_gradient -%}
      color: rgba(255,255,255,0.75);
    {%- else -%}
      color: {{ grad_col_2 }};
    {%- endif -%}
  }
  {%- unless section.settings.use_gradient -%}
  .premium-contact__eyebrow::after {
    content: '';
    display: block;
    height: 2px;
    width: 2.5rem;
    margin-top: 6px;
    border-radius: 99px;
    background: {{ brand_gradient }};
  }
  {%- endunless -%}

  .premium-contact__heading {
    font-family: var(--font-heading-family, sans-serif);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.15;
    margin: 0 0 1.5rem;
    color: inherit;
    letter-spacing: -0.02em;
  }

  .premium-contact__subtext {
    font-size: 1rem;
    line-height: 1.75;
    opacity: 0.65;
    color: inherit;
  }

  {%- unless section.settings.use_gradient -%}
  .premium-contact__divider {
    height: 2px;
    width: 48px;
    background: {{ brand_gradient }};
    border-radius: 99px;
    margin: 1.5rem 0;
    border: none;
  }
  {%- endunless -%}

  .premium-contact__form-col { display: flex; flex-direction: column; }

  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .premium-form__message {
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    border-radius: 6px;
  }
  .premium-form__message--success {
    background-color: rgba(22,163,74,0.1);
    border: 1px solid rgba(22,163,74,0.3);
    color: {%- if section.settings.use_gradient -%} #FFFFFF {%- else -%} #16a34a {%- endif -%};
  }
  .premium-form__message--error {
    background-color: rgba(220,38,38,0.08);
    border: 1px solid rgba(220,38,38,0.25);
    color: #dc2626;
  }

  .premium-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  @media screen and (min-width: 768px) {
    .premium-form__row { grid-template-columns: 1fr 1fr; }
  }

  .premium-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .premium-form__label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: inherit;
    opacity: 0.9;
  }
  .premium-form__label span {
    font-weight: 400;
    opacity: 0.55;
    margin-left: 0.25rem;
  }

  .premium-form__input,
  .premium-form__textarea {
    width: 100%;
    font-family: var(--font-body-family, sans-serif);
    font-size: 1rem;
    color: inherit;
    border-radius: 6px;
    padding: 0.85rem 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.12);
      border: 1.5px solid rgba(255,255,255,0.35);
      caret-color: #FFFFFF;
    {%- else -%}
      background: #FFFFFF;
      border: 1.5px solid #E2E2E2;
    {%- endif -%}
  }

  .premium-form__textarea { resize: vertical; min-height: 140px; }

  .premium-form__input::placeholder,
  .premium-form__textarea::placeholder {
    {%- if section.settings.use_gradient -%}
      color: rgba(255,255,255,0.45);
    {%- else -%}
      color: rgba(0,0,0,0.3);
    {%- endif -%}
  }

  .premium-form__input:focus,
  .premium-form__textarea:focus {
    outline: none;
    {%- if section.settings.use_gradient -%}
      border-color: rgba(255,255,255,0.9);
      background: rgba(255,255,255,0.18);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.12);
    {%- else -%}
      border-color: {{ grad_col_2 }};
      box-shadow: 0 0 0 3px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.14);
    {%- endif -%}
  }

  .premium-form__checkbox-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
  }
  .premium-form__checkbox {
    -webkit-appearance: none;
    appearance: none;
    width: 18px; height: 18px;
    min-width: 18px;
    border: 1.5px solid
      {%- if section.settings.use_gradient -%} rgba(255,255,255,0.5)
      {%- else -%} #E2E2E2{%- endif -%};
    background: transparent;
    cursor: pointer;
    position: relative;
    border-radius: 3px;
    margin-top: 2px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .premium-form__checkbox:checked {
    background: {{ brand_gradient }};
    border-color: transparent;
  }
  .premium-form__checkbox:checked::after {
    content: '';
    position: absolute;
    top: 2px; left: 5px;
    width: 5px; height: 9px;
    border: 2px solid #FFFFFF;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }
  .premium-form__checkbox-label {
    font-size: 0.88rem;
    line-height: 1.5;
    color: inherit;
    opacity: 0.8;
    cursor: pointer;
  }

  .premium-form__submit {
    align-self: flex-start;
    padding: 1rem 3rem;
    font-family: var(--font-heading-family, sans-serif);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    margin-top: 0.5rem;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.15);
      color: #FFFFFF;
      border: 1.5px solid rgba(255,255,255,0.6);
    {%- elsif section.settings.btn_use_gradient -%}
      background: {{ brand_gradient }};
      color: #FFFFFF;
      border: none;
      box-shadow: 0 4px 20px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.22);
    {%- else -%}
      background: transparent;
      color: {{ section.settings.text_color }};
      border: 1.5px solid {{ section.settings.text_color }};
    {%- endif -%}
  }
  {%- if section.settings.btn_use_gradient and section.settings.use_gradient == false -%}
  .premium-form__submit::after {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ brand_gradient }};
    filter: brightness(0.88);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .premium-form__submit span { position: relative; z-index: 1; }
  {%- endif -%}
  .premium-form__submit:hover {
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.28);
      transform: translateY(-2px);
    {%- elsif section.settings.btn_use_gradient -%}
      transform: translateY(-2px);
      box-shadow: 0 8px 36px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.38);
    {%- else -%}
      background: {{ section.settings.text_color }};
      color: {{ section.settings.bg_color }};
    {%- endif -%}
  }
  {%- if section.settings.btn_use_gradient and section.settings.use_gradient == false -%}
  .premium-form__submit:hover::after { opacity: 1; }
  {%- endif -%}

  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUpAnim { to { opacity: 1; transform: translateY(0); } }
</style>

<div class="premium-contact-outer-{{ section.id }}">
  <div class="premium-contact-{{ section.id }}">
    <div class="premium-contact__container">

      <div class="premium-contact__text-col fade-up-anim">
        {%- if section.settings.eyebrow != blank -%}
          <span class="premium-contact__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="premium-contact__heading">{{ section.settings.heading }}</h2>
        {%- unless section.settings.use_gradient -%}
          <hr class="premium-contact__divider">
        {%- endunless -%}
        {%- if section.settings.subtext != blank -%}
          <p class="premium-contact__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>

      <div class="premium-contact__form-col fade-up-anim" style="animation-delay: 200ms;">
        {%- form 'contact', id: 'MemorialContactForm-{{ section.id }}', class: 'premium-form' -%}

          <input type="hidden" name="contact[Form]" value="{{ section.settings.form_identifier }}">

          {%- if form.posted_successfully? -%}
            <div class="premium-form__message premium-form__message--success" tabindex="-1" autofocus>
              {{ section.settings.success_message }}
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <div class="premium-form__message premium-form__message--error" tabindex="-1" autofocus>
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="premium-form__row">
              <div class="premium-form__field">
                <label class="premium-form__label" for="ContactForm-first-{{ section.id }}">
                  {{ section.settings.label_first_name }}
                  <span>{{ section.settings.label_required }}</span>
                </label>
                <input type="text" id="ContactForm-first-{{ section.id }}"
                       class="premium-form__input" name="contact[First Name]"
                       autocomplete="given-name" required>
              </div>
              <div class="premium-form__field">
                <label class="premium-form__label" for="ContactForm-last-{{ section.id }}">
                  {{ section.settings.label_last_name }}
                  <span>{{ section.settings.label_required }}</span>
                </label>
                <input type="text" id="ContactForm-last-{{ section.id }}"
                       class="premium-form__input" name="contact[Last Name]"
                       autocomplete="family-name" required>
              </div>
            </div>

            <div class="premium-form__field">
              <label class="premium-form__label" for="ContactForm-email-{{ section.id }}">
                {{ section.settings.label_email }}
                <span>{{ section.settings.label_required }}</span>
              </label>
              <input type="email" id="ContactForm-email-{{ section.id }}"
                     class="premium-form__input" name="contact[email]"
                     autocomplete="email" required>
            </div>

            {%- if section.settings.show_checkbox -%}
              <label class="premium-form__checkbox-wrapper">
                <input type="checkbox" class="premium-form__checkbox"
                       name="contact[Newsletter Signup]" value="Yes">
                <span class="premium-form__checkbox-label">{{ section.settings.checkbox_label }}</span>
              </label>
            {%- endif -%}

            <div class="premium-form__field">
              <label class="premium-form__label" for="ContactForm-body-{{ section.id }}">
                {{ section.settings.label_message }}
                <span>{{ section.settings.label_required }}</span>
              </label>
              <textarea id="ContactForm-body-{{ section.id }}"
                        class="premium-form__textarea"
                        name="contact[body]" required></textarea>
            </div>

            <button type="submit" class="premium-form__submit">
              {%- if section.settings.btn_use_gradient and section.settings.use_gradient == false -%}
                <span>{{ section.settings.button_label }}</span>
              {%- else -%}
                {{ section.settings.button_label }}
              {%- endif -%}
            </button>

          {%- endif -%}
        {%- endform -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Memorial Contact Form",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "checkbox", "id": "use_gradient", "label": "Use brand gradient background", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background Color (if not gradient)", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text Color (if not gradient)", "default": "#1A1A1A" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Label", "default": "Oaklynn Rae Domer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Share your love and prayers to the Domer Family:" },
    { "type": "textarea", "id": "subtext", "label": "Subtext (optional)" },
    { "type": "text", "id": "form_identifier", "label": "Form Identifier", "default": "Memorial — Domer Family", "info": "Shows in the email so you know which form it came from." },
    { "type": "header", "content": "Form Fields" },
    { "type": "checkbox", "id": "show_checkbox", "label": "Show Newsletter Checkbox", "default": true },
    { "type": "text", "id": "checkbox_label", "label": "Checkbox Label", "default": "Sign up for news and updates" },
    { "type": "text", "id": "label_first_name", "label": "First Name Label", "default": "First Name" },
    { "type": "text", "id": "label_last_name", "label": "Last Name Label", "default": "Last Name" },
    { "type": "text", "id": "label_email", "label": "Email Label", "default": "Email" },
    { "type": "text", "id": "label_message", "label": "Message Label", "default": "Message and prayers to send to the family:" },
    { "type": "text", "id": "label_required", "label": "Required Text", "default": "(required)" },
    { "type": "text", "id": "button_label", "label": "Submit Button", "default": "Send Message" },
    { "type": "text", "id": "success_message", "label": "Success Message", "default": "Thank you. Your message and prayers have been sent to the Domer Family. 🙏" },
    { "type": "header", "content": "Button Style" },
    { "type": "checkbox", "id": "btn_use_gradient", "label": "Use brand gradient on button", "default": true },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [{ "name": "Memorial Contact Form" }]
}
{% endschema %}
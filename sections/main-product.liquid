          "default": "pills"
        }
      ]
    },
    {
      "type": "quantity",
      "name": "Quantity Selector",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_quantity",    "label": "Show quantity selector", "default": true },
        { "type": "text",     "id": "quantity_label",   "label": "Quantity Label",         "default": "Quantity" }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_dynamic_checkout",  "label": "Show dynamic checkout buttons", "default": true },
        { "type": "text",     "id": "button_add_to_cart",     "label": "Add to Cart Text",              "default": "Add to Cart" },
        { "type": "text",     "id": "button_loading",         "label": "Loading Text",                  "default": "Adding..." },
        { "type": "text",     "id": "button_success",         "label": "Success Text",                  "default": "Added!" },
        { "type": "text",     "id": "button_sold_out",        "label": "Sold Out Text",                 "default": "Sold Out" }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "limit": 3
    },
    {
      "type": "share",
      "name": "Share Buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_share",    "label": "Show share buttons", "default": true },
        { "type": "text",     "id": "share_label",   "label": "Share Label",        "default": "Share" }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "limit": 2,
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Custom Liquid" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "vendor" },
      { "type": "title" },
      { "type": "price" },
      { "type": "variant_picker" },
      { "type": "quantity" },
      { "type": "buy_buttons" },
      { "type": "divider" },
      { "type": "description" },
      { "type": "divider" },
      { "type": "share" }
    ]
  }
}
{% endschema %}

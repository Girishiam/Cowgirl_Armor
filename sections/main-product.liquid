<style>
  .premium-pdp-{{ section.id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body);
  }

  .premium-pdp__breadcrumb {
    font-size: 0.85rem;
    opacity: 0.6;
    margin-bottom: 2rem;
    letter-spacing: 0.05em;
  }

  .premium-pdp__breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .premium-pdp__breadcrumb a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .premium-pdp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 1024px) {
    .premium-pdp__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 5rem;
      align-items: flex-start;
    }
  }

  /* MEDIA GALLERY (Left Side) */
  .premium-pdp__media-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .premium-pdp__media-item {
    width: 100%;
    background-color: rgba(0,0,0,0.03);
    border-radius: var(--border-radius);
    overflow: hidden;
  }

  .premium-pdp__media-item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* PRODUCT INFO (Right Side - Sticky) */
  .premium-pdp__info-container {
    position: sticky;
    top: 100px; /* Adjust based on your header height */
  }

  .premium-pdp__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1rem 0;
    color: {{ section.settings.text_color }};
  }

  .premium-pdp__price {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
  }

  .premium-pdp__description {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    opacity: 0.8;
  }

  /* FORM AND BUTTONS */
  .premium-pdp__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .premium-pdp__quantity-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid rgba(0,0,0,0.2);
    width: fit-content;
    border-radius: var(--border-radius);
  }

  .premium-pdp__quantity-btn {
    background: transparent;
    border: none;
    padding: 1rem 1.2rem;
    cursor: pointer;
    font-size: 1.2rem;
    color: {{ section.settings.text_color }};
  }

  .premium-pdp__quantity-input {
    width: 50px;
    text-align: center;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 1rem;
    color: {{ section.settings.text_color }};
    -moz-appearance: textfield;
  }
  .premium-pdp__quantity-input::-webkit-outer-spin-button,
  .premium-pdp__quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .premium-pdp__buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .premium-btn--add {
    width: 100%;
    padding: 1.2rem;
    background-color: transparent;
    color: {{ section.settings.text_color }};
    border: 1px solid {{ section.settings.text_color }};
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .premium-btn--add:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* Shopify Dynamic Checkout Button Styling overrides */
  .shopify-payment-button__button {
    border-radius: var(--border-radius) !important;
    font-family: var(--font-heading) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
  }
</style>

<div class="premium-pdp-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  {%- if section.settings.show_breadcrumbs -%}
    <nav class="premium-pdp__breadcrumb" aria-label="breadcrumbs">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true"> / </span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true"> / </span>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">All Products</a>
        <span aria-hidden="true"> / </span>
      {%- endif -%}
      <span>{{ product.title }}</span>
    </nav>
  {%- endif -%}

  <div class="premium-pdp__grid">
    <div class="premium-pdp__media-gallery fade-up-anim">
      {%- for media in product.media -%}
        <div class="premium-pdp__media-item">
          {%- if media.media_type == 'image' -%}
            <img
              src="{{ media | image_url: width: 1200 }}"
              alt="{{ media.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {%- else -%}
            {{ media | media_tag }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="premium-pdp__info-container">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'title' -%}
            <h1 class="premium-pdp__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

          {%- when 'price' -%}
            <div class="premium-pdp__price" {{ block.shopify_attributes }}>
              <span id="price-{{ section.id }}">{{ product.selected_or_first_available_variant.price | money }}</span>
            </div>

          {%- when 'description' -%}
            {%- if product.description != blank -%}
              <div class="premium-pdp__description" {{ block.shopify_attributes }}>
                {{ product.description }}
              </div>
            {%- endif -%}

          {%- when 'buy_buttons' -%}
            <div {{ block.shopify_attributes }}>
              {%- form 'product', product, id: 'premium-product-form', class: 'premium-pdp__form' -%}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

                <div class="premium-pdp__quantity-wrapper">
                  <button type="button" class="premium-pdp__quantity-btn" onclick="this.nextElementSibling.stepDown()">
                    -
                  </button>
                  <input type="number" name="quantity" class="premium-pdp__quantity-input" value="1" min="1">
                  <button
                    type="button"
                    class="premium-pdp__quantity-btn"
                    onclick="this.previousElementSibling.stepUp()"
                  >
                    +
                  </button>
                </div>

                <div class="premium-pdp__buttons">
                  <button
                    type="submit"
                    name="add"
                    class="premium-btn--add"
                    {% unless product.available %}
                      disabled
                    {% endunless %}
                  >
                    {%- if product.available -%}
                      Add to Cart
                    {%- else -%}
                      Sold Out
                    {%- endif -%}
                  </button>

                  {%- if block.settings.show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                </div>
              {%- endform -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Product Page",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show Breadcrumbs",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "Show dynamic checkout buttons",
          "default": true
        }
      ]
    }
  ],
  "default": {
    "blocks": [{ "type": "title" }, { "type": "price" }, { "type": "description" }, { "type": "buy_buttons" }]
  }
}
{% endschema %}

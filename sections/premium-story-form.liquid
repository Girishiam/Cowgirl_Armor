<style>
  .premium-story-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body);
  }

  .premium-story__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media screen and (min-width: 1024px) {
    .premium-story__container {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: flex-start;
    }
  }

  /* --- Left Column: Content --- */
  .premium-story__content-col {
    position: sticky;
    top: 120px;
  }

  .premium-story__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    color: inherit;
    letter-spacing: -0.01em;
  }

  .premium-story__text {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.8;
    opacity: 0.9;
    color: inherit;
  }

  .premium-story__text p {
    margin-bottom: 1.5rem;
  }
  .premium-story__text p:last-child {
    margin-bottom: 0;
  }

  /* --- Right Column: Form --- */
  .premium-story__form-col {
    display: flex;
    flex-direction: column;
  }

  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Form Status Messages */
  .premium-form__message {
    padding: 1rem;
    font-size: 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .premium-form__message--success {
    background-color: rgba(46, 204, 113, 0.1);
    color: #27ae60;
    border: 1px solid #27ae60;
  }
  .premium-form__message--error {
    background-color: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid #c0392b;
  }

  /* Input Styling */
  .premium-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 768px) {
    .premium-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .premium-form__field {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .premium-form__label {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: inherit;
    opacity: 0.9;
  }

  .premium-form__label span {
    font-weight: normal;
    opacity: 0.6;
    margin-left: 0.25rem;
  }

  .premium-form__input,
  .premium-form__textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0,0,0,0.2);
    color: inherit;
    font-family: inherit;
    font-size: 1rem;
    padding: 0.5rem 0;
    transition: border-color 0.3s ease;
  }

  .premium-form__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .premium-form__input:focus,
  .premium-form__textarea:focus {
    outline: none;
    border-bottom-color: {{ section.settings.text_color }};
  }

  /* Custom Premium Radio Buttons (Pill Style) */
  .premium-form__radio-group {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .premium-form__radio-input {
    display: none; /* Hide default radio button */
  }

  .premium-form__radio-label {
    padding: 0.6rem 2rem;
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: 30px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-heading);
  }

  /* When the hidden radio is checked, style the label next to it */
  .premium-form__radio-input:checked + .premium-form__radio-label {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
    border-color: {{ section.settings.text_color }};
  }

  /* Submit Button */
  .premium-form__submit {
    align-self: flex-start;
    background: transparent;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    padding: 1rem 3.5rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }

  .premium-form__submit:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* Sub-text for form fields */
  .premium-form__subtext {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 0.5rem;
  }

  /* Animation */
  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUpAnim {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="premium-story-{{ section.id }}">
  <div class="premium-story__container">
    <div class="premium-story__content-col fade-up-anim">
      {%- if section.settings.heading != blank -%}
        <h2 class="premium-story__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="premium-story__text">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>

    <div class="premium-story__form-col fade-up-anim" style="animation-delay: 200ms;">
      {%- form 'contact', id: 'PremiumStoryForm', class: 'premium-form' -%}
        <input type="hidden" name="contact[tags]" value="story_submission">

        {%- if form.posted_successfully? -%}
          <div class="premium-form__message premium-form__message--success" tabindex="-1" autofocus>
            {{ section.settings.success_message }}
          </div>
        {%- elsif form.errors -%}
          <div class="premium-form__message premium-form__message--error" tabindex="-1" autofocus>
            Please adjust the following fields: {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="premium-form__row">
          <div class="premium-form__field">
            <label class="premium-form__label" for="StoryForm-first_name">{{ section.settings.label_first_name | default: 'First Name' }} <span>{{ section.settings.label_required | default: '(required)' }}</span></label>
            <input
              type="text"
              id="StoryForm-first_name"
              class="premium-form__input"
              name="contact[First Name]"
              required
              autocomplete="given-name"
            >
          </div>
          <div class="premium-form__field">
            <label class="premium-form__label" for="StoryForm-last_name">{{ section.settings.label_last_name | default: 'Last Name' }}</label>
            <input
              type="text"
              id="StoryForm-last_name"
              class="premium-form__input"
              name="contact[Last Name]"
              autocomplete="family-name"
            >
          </div>
        </div>

        <div class="premium-form__field">
          <label class="premium-form__label" for="StoryForm-email">{{ section.settings.label_email | default: 'Email' }} <span>{{ section.settings.label_required | default: '(required)' }}</span></label>
          <input
            type="email"
            id="StoryForm-email"
            class="premium-form__input"
            name="contact[email]"
            required
            autocomplete="email"
          >
        </div>

        <div class="premium-form__field">
          <label class="premium-form__label" for="StoryForm-story">{{ section.settings.label_story | default: 'Your Cowgirl Story:' }} <span>{{ section.settings.label_required | default: '(required)' }}</span></label>
          <textarea
            id="StoryForm-story"
            class="premium-form__textarea"
            name="contact[Story]"
            style="min-height: 150px;"
            required
          ></textarea>
        </div>

        <div class="premium-form__field">
          <label class="premium-form__label">{{ section.settings.label_permission | default: 'Can we share this on our Cowgirl Stories?' }} <span>{{ section.settings.label_required | default: '(required)' }}</span></label>
          <div class="premium-form__subtext">{{ section.settings.subtext_permission | default: 'If always anonymous, please note that in the message above.' }}</div>

          <div class="premium-form__radio-group">
            <input
              type="radio"
              id="StoryForm-permission-yes"
              class="premium-form__radio-input"
              name="contact[Permission to Share]"
              value="{{ section.settings.label_yes | default: 'Yes' }}"
              required
            >
            <label for="StoryForm-permission-yes" class="premium-form__radio-label">{{ section.settings.label_yes | default: 'Yes' }}</label>

            <input
              type="radio"
              id="StoryForm-permission-no"
              class="premium-form__radio-input"
              name="contact[Permission to Share]"
              value="{{ section.settings.label_no | default: 'No' }}"
              required
            >
            <label for="StoryForm-permission-no" class="premium-form__radio-label">{{ section.settings.label_no | default: 'No' }}</label>
          </div>
        </div>

        <div class="premium-form__field">
          <label class="premium-form__label" for="StoryForm-prayer">{{ section.settings.label_prayer | default: 'How can we be praying for you?' }}</label>
          <input type="text" id="StoryForm-prayer" class="premium-form__input" name="contact[Prayer Request]">
        </div>

        <button type="submit" class="premium-form__submit">
          {{ section.settings.button_label }}
        </button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Story Submission Form",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F9F9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Share your Cowgirl Story!"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>We are all in this journey together, and we are anonymous sharing other inspirational Cowgirl Stories on our blog, with \"Signed A Cowgirl.\" If it's on your heart to share your story, please send it to us here, and we will get back to you asap! We are all in this together cowgirls!</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit Button Label",
      "default": "Send it!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thank you for sharing your story with us!"
    },
    {
      "type": "header",
      "content": "Form Labels"
    },
    {
      "type": "text",
      "id": "label_first_name",
      "label": "First Name Label",
      "default": "First Name"
    },
    {
      "type": "text",
      "id": "label_last_name",
      "label": "Last Name Label",
      "default": "Last Name"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Email Label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "label_story",
      "label": "Story Label",
      "default": "Your Cowgirl Story:"
    },
    {
      "type": "text",
      "id": "label_permission",
      "label": "Permission Label",
      "default": "Can we share this on our Cowgirl Stories?"
    },
    {
      "type": "text",
      "id": "subtext_permission",
      "label": "Permission Subtext",
      "default": "If always anonymous, please note that in the message above."
    },
    {
      "type": "text",
      "id": "label_yes",
      "label": "Yes Option",
      "default": "Yes"
    },
    {
      "type": "text",
      "id": "label_no",
      "label": "No Option",
      "default": "No"
    },
    {
      "type": "text",
      "id": "label_prayer",
      "label": "Prayer Label",
      "default": "How can we be praying for you?"
    },
    {
      "type": "text",
      "id": "label_required",
      "label": "Required text",
      "default": "(required)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Story Submission Form",
      "category": "Form"
    }
  ]
}
{% endschema %}

<style>
  .blog-listing-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .blog-listing__inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .blog-listing__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    color: {{ section.settings.heading_color }};
    margin-bottom: 3rem;
    text-align: center;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .blog-listing__list {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.gap }}px;
  }

  .blog-listing__article {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding-bottom: {{ section.settings.gap }}px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    text-decoration: none;
    color: {{ section.settings.text_color }};
  }

  .blog-listing__article:last-child {
    border-bottom: none;
  }

  .blog-listing__article:nth-child(even) .blog-listing__image-col {
    order: 2;
  }

  .blog-listing__article:nth-child(even) .blog-listing__text-col {
    order: 1;
  }

  .blog-listing__image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
  }

  .blog-listing__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    display: block;
  }

  .blog-listing__article:hover .blog-listing__image-wrap img {
    transform: scale(1.04);
  }

  .blog-listing__date {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    margin-bottom: 0.75rem;
  }

  .blog-listing__title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: {{ section.settings.heading_color }};
    transition: opacity 0.3s ease;
  }

  .blog-listing__article:hover .blog-listing__title {
    opacity: 0.7;
  }

  .blog-listing__excerpt {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.75;
    margin-bottom: 1.5rem;
  }

  .blog-listing__read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.3s ease;
  }

  .blog-listing__read-more:hover {
    opacity: 0.6;
  }

  .blog-listing__pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 4rem;
    flex-wrap: wrap;
  }

  .blog-listing__pagination a,
  .blog-listing__pagination span {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.6rem 1.2rem;
    border: 1px solid {{ section.settings.text_color }};
    text-decoration: none;
    color: {{ section.settings.text_color }};
    transition: background 0.3s ease, color 0.3s ease;
  }

  .blog-listing__pagination a:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  .blog-listing__pagination .current {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  @media screen and (max-width: 767px) {
    .blog-listing__article {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .blog-listing__article:nth-child(even) .blog-listing__image-col,
    .blog-listing__article:nth-child(even) .blog-listing__text-col {
      order: unset;
    }
  }
</style>

{%- paginate blog.articles by section.settings.posts_per_page -%}

<div class="blog-listing-{{ section.id }}">
  <div class="blog-listing__inner">

    {%- if section.settings.show_heading and blog.title != blank -%}
      <h1 class="blog-listing__heading">{{ blog.title }}</h1>
    {%- endif -%}

    <div class="blog-listing__list">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="blog-listing__article">

          <div class="blog-listing__image-col">
            <div class="blog-listing__image-wrap">
              {%- if article.image -%}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="600"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>

          <div class="blog-listing__text-col">
            {%- if section.settings.show_date -%}
              <p class="blog-listing__date">{{ article.published_at | date: '%m/%d/%y' }}</p>
            {%- endif -%}

            <h2 class="blog-listing__title">{{ article.title }}</h2>

            {%- if section.settings.show_excerpt and article.excerpt != blank -%}
              <p class="blog-listing__excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
            {%- endif -%}

            <span class="blog-listing__read-more">
              Read More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>

        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="blog-listing__pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">&larr; Prev</a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="current">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">Next &rarr;</a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "Blog Listing",
  "templates": ["blog"],
  "settings": [
    {
      "type": "range",
      "id": "posts_per_page",
      "label": "Posts Per Page",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show Blog Title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show Excerpt",
      "default": true
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space Between Posts",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Blog Listing"
    }
  ]
}
{% endschema %}

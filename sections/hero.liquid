<style>
  .premium-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: calc({{ section.settings.hero_height }}vh - var(--nav-total-height, 80px));
    min-height: 400px;
    overflow: hidden;
    {%- if section.settings.use_gradient and section.settings.bg_image == blank -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  .premium-hero-{{ section.id }} .premium-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .premium-hero-{{ section.id }} .premium-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    {%- if section.settings.use_gradient and section.settings.bg_image != blank -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background-color: {{ section.settings.overlay_color }};
    {%- endif -%}
  }

  /* ── Use position:absolute + left:50% + translateX(-50%)
     This centers based on the IMAGE's rendered width, not its PNG canvas ── */
  .premium-hero-{{ section.id }} .premium-hero__content-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: fit-content;
    max-width: {{ section.settings.image_width }}px;
  }

  .premium-hero-{{ section.id }} .center-hero-img {
    display: block;
    width: {{ section.settings.image_width }}px;
    max-width: 90vw;
    height: auto;
    {%- if section.settings.invert_image -%}
      filter: drop-shadow(0 25px 35px rgba(0,0,0,0.3)) brightness(0) invert(1);
    {%- else -%}
      filter: drop-shadow(0 25px 35px rgba(0,0,0,0.4));
    {%- endif -%}
    opacity: 0;
    animation:
      heroImageEntrance 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards,
      float 6s ease-in-out 2s infinite alternate;
  }

  .premium-hero-{{ section.id }} .shield-container {
    border: 2px solid rgba(255,255,255,0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 4px;
    background: rgba(0,0,0,0.2);
    backdrop-filter: blur(5px);
  }

  .premium-hero-{{ section.id }} .fallback-text {
    color: #fff;
    font-size: 2rem;
    letter-spacing: 4px;
    font-family: var(--font-heading-family, serif);
    margin: 0;
  }

  @keyframes heroImageEntrance {
    0%   { opacity: 0; transform: translateY(50px) scale(0.95); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes float {
    0%   { transform: translateY(0px) scale(1); }
    100% { transform: translateY(-15px) scale(1.02); }
  }
</style>

<div class="premium-hero-{{ section.id }}">

  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 2000 }}"
      alt="{{ section.settings.bg_image.alt | default: 'Hero Background' | escape }}"
      class="premium-hero__bg"
      loading="eager"
    >
  {%- endif -%}

  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="premium-hero__overlay"></div>
  {%- endif -%}

  <div class="premium-hero__content-container">
    {%- if section.settings.center_image != blank -%}
      <img
        src="{{ section.settings.center_image | image_url: width: section.settings.image_width }}"
        alt="{{ section.settings.center_image.alt | default: 'Center Image' | escape }}"
        class="center-hero-img"
        loading="eager"
      >
    {%- else -%}
      <div class="shield-container center-hero-img"
           style="width:{{ section.settings.image_width }}px;height:{{ section.settings.image_width | times: 1.25 }}px;">
        <h2 class="fallback-text">C.A.</h2>
      </div>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Premium Center Image Hero",
  "settings": [
    {
      "type": "range",
      "id": "hero_height",
      "min": 40, "max": 100, "step": 5, "unit": "vh",
      "label": "Section Height",
      "default": 90
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient",
      "default": true,
      "info": "No image = gradient background. With image = gradient overlay tint."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (if not gradient)",
      "default": "#F8F6F4"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color (if not gradient)",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "label": "Overlay Opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Center Image"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Overlay Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 100, "max": 1000, "step": 20, "unit": "px",
      "label": "Image Max Width",
      "default": 400
    },
    {
      "type": "checkbox",
      "id": "invert_image",
      "label": "Invert image to white",
      "default": true,
      "info": "Turn on for black logos on gradient/dark backgrounds."
    }
  ],
  "presets": [
    {
      "name": "Premium Root Hero Image",
      "category": "Image"
    }
  ]
}
{% endschema %}

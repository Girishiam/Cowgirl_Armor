<div class="premium-hero" style="--bg-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};">
  {%- if section.settings.bg_image != blank -%}
    <img src="{{ section.settings.bg_image | img_url: 'master' }}" alt="{{ section.settings.bg_image.alt | default: 'Hero Background' }}" class="premium-hero__bg">
  {%- endif -%}
  
  <div class="premium-hero__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: var(--bg-overlay-opacity);"></div>
  
  <div class="premium-hero__content-container">
    <div class="premium-hero__center-image">
      {%- if section.settings.center_image != blank -%}
        <img 
          src="{{ section.settings.center_image | img_url: 'master' }}" 
          alt="{{ section.settings.center_image.alt | default: 'Center Image' }}" 
          class="center-hero-img floating-anim" 
          style="max-width: {{ section.settings.image_width }}px; width: 100%; height: auto; object-fit: contain;"
        >
      {%- else -%}
        <!-- Fallback if no center image is selected -->
        <div class="shield-container center-hero-img floating-anim" style="width: {{ section.settings.image_width }}px; height: {{ section.settings.image_width | times: 1.25 }}px;">
           <h2 class="fallback-text">C.A.</h2>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .premium-hero {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height }}vh;
    overflow: hidden;
    background: {{ section.settings.bg_color | default: '#d9d9d9' }};
  }
  .premium-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .premium-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    transition: opacity 0.8s ease;
  }
  .premium-hero__content-container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
    position: relative;
    z-index: 2;
    padding: 0 2rem;
  }
  .premium-hero__center-image {
    perspective: 1000px;
  }
  .center-hero-img {
    filter: drop-shadow(0 25px 35px rgba(0,0,0,0.4));
    opacity: 0;
    transform: translateY(50px) scale(0.95);
    animation: heroImageEntrance 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards, float 6s ease-in-out infinite alternate;
    animation-delay: 0.2s, 2s;
  }
  .shield-container {
    border: 2px solid rgba(255,255,255,0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 4px;
    background: rgba(0,0,0,0.2);
    backdrop-filter: blur(5px);
  }
  .fallback-text {
    color: #fff;
    font-size: 2rem;
    letter-spacing: 4px;
    font-family: serif;
    margin: 0;
  }

  @keyframes heroImageEntrance {
    0% {
      opacity: 0;
      transform: translateY(50px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes float {
    0% {
      transform: translateY(0px) scale(1);
    }
    100% {
      transform: translateY(-15px) scale(1.02);
    }
  }
</style>

{% schema %}
{
  "name": "Premium Center Image Hero",
  "settings": [
    {
      "type": "range",
      "id": "hero_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Section Height",
      "default": 90
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#d9d9d9"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Background Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "label": "Overlay Opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Center Image Settings"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Overlay Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 100,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Image Max Width",
      "default": 400
    }
  ],
  "presets": [
    {
      "name": "Premium Root Hero Image",
      "category": "Image"
    }
  ]
}
{% endschema %}

<div class="premium-hero {{ section.settings.animation_style }}"
     style="--bg-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
     data-parallax="{{ section.settings.enable_parallax }}"
     data-animation-speed="{{ section.settings.animation_speed }}">

  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | img_url: 'master' }}"
      alt="{{ section.settings.bg_image.alt | default: 'Hero Background' }}"
      class="premium-hero__bg"
      style="object-position: {{ section.settings.bg_position }};"
      loading="eager"
      fetchpriority="high"
    >
  {%- endif -%}

  <div class="premium-hero__overlay"
       style="background: {% if section.settings.use_gradient %}{{ section.settings.overlay_gradient }}{% else %}{{ section.settings.overlay_color }}{% endif %};
              opacity: var(--bg-overlay-opacity);"></div>

  <div class="premium-hero__content-container"
       style="justify-content: {{ section.settings.content_horizontal }};
              align-items: {{ section.settings.content_vertical }};">

    <div class="premium-hero__center-image"
         style="--shadow-x: {{ section.settings.shadow_x }}px;
                --shadow-y: {{ section.settings.shadow_y }}px;
                --shadow-blur: {{ section.settings.shadow_blur }}px;
                --shadow-opacity: {{ section.settings.shadow_opacity | divided_by: 100.0 }};">

      {%- if section.settings.center_image != blank -%}
        <img
          src="{{ section.settings.center_image | img_url: 'master' }}"
          alt="{{ section.settings.center_image.alt | default: 'Center Image' }}"
          class="center-hero-img floating-anim"
          style="max-width: min({{ section.settings.image_width }}px, 90vw);
                 width: 100%;
                 height: auto;
                 object-fit: contain;
                 border-radius: {{ section.settings.image_border_radius }}px;"
          loading="eager"
        >
      {%- else -%}
        <div class="shield-container center-hero-img floating-anim"
             style="width: {{ section.settings.image_width }}px;
                    height: {{ section.settings.image_width | times: 1.25 }}px;
                    border-radius: {{ section.settings.fallback_border_radius }}px;
                    background: {{ section.settings.fallback_bg_color }};
                    border: {{ section.settings.fallback_border_width }}px solid {{ section.settings.fallback_border_color }};
                    backdrop-filter: blur({{ section.settings.fallback_blur }}px);">
           <h2 class="fallback-text"
               style="color: {{ section.settings.fallback_text_color }};
                      font-size: {{ section.settings.fallback_text_size }}px;
                      letter-spacing: {{ section.settings.fallback_letter_spacing }}px;">
             {{ section.settings.fallback_text }}
           </h2>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <div class="scroll-indicator" style="color: {{ section.settings.scroll_indicator_color }};">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14M19 12l-7 7-7-7"/>
      </svg>
      {%- if section.settings.scroll_indicator_text != blank -%}
        <span class="scroll-text">{{ section.settings.scroll_indicator_text }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<style>
  .premium-hero {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height }}vh;
    min-height: {{ section.settings.min_height }}px;
    overflow: hidden;
    background: {{ section.settings.bg_color | default: '#d9d9d9' }};
  }

  .premium-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform {{ section.settings.bg_transition_speed }}s ease-out;
  }

  /* Parallax effect */
  .premium-hero[data-parallax="true"] .premium-hero__bg {
    transform: scale(1.1);
  }

  .premium-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    transition: opacity {{ section.settings.overlay_transition }}s ease;
  }

  .premium-hero__content-container {
    display: flex;
    height: 100%;
    position: relative;
    z-index: 2;
    padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_horizontal }}px {{ section.settings.content_padding_bottom }}px;
  }

  .premium-hero__center-image {
    perspective: {{ section.settings.perspective }}px;
  }

  .center-hero-img {
    filter: drop-shadow(
      var(--shadow-x, 0)
      var(--shadow-y, 10px)
      var(--shadow-blur, 20px)
      rgba(0, 0, 0, var(--shadow-opacity, 0.15))
    );
    opacity: 0;
    transform: translateY({{ section.settings.entrance_distance }}px) scale({{ section.settings.entrance_scale | divided_by: 100.0 }});
    animation:
      heroImageEntrance {{ section.settings.entrance_duration }}s cubic-bezier({{ section.settings.entrance_easing }}) forwards,
      {% if section.settings.enable_float %}float {{ section.settings.float_duration }}s ease-in-out infinite alternate{% endif %};
    animation-delay: {{ section.settings.entrance_delay }}s, {{ section.settings.float_delay }}s;
    transition: transform {{ section.settings.hover_transition }}s ease;
  }

  {% if section.settings.enable_hover_effect %}
  .center-hero-img:hover {
    transform: translateY(-{{ section.settings.hover_lift }}px) scale({{ section.settings.hover_scale | divided_by: 100.0 }}) !important;
  }
  {% endif %}

  /* Animation styles */
  .premium-hero.animation-fade .center-hero-img {
    animation: heroFadeIn {{ section.settings.entrance_duration }}s ease forwards;
  }

  .premium-hero.animation-zoom .center-hero-img {
    animation: heroZoomIn {{ section.settings.entrance_duration }}s ease forwards;
  }

  .premium-hero.animation-slide-up .center-hero-img {
    animation: heroSlideUp {{ section.settings.entrance_duration }}s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Mobile Responsive Adjustments */
  @media screen and (max-width: 767px) {
    .premium-hero {
      height: {{ section.settings.mobile_height }}vh;
      min-height: {{ section.settings.mobile_min_height }}px;
    }
    .premium-hero__content-container {
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_horizontal }}px {{ section.settings.mobile_padding_bottom }}px;
    }
    .center-hero-img {
      max-width: {{ section.settings.mobile_image_width }}vw !important;
      width: {{ section.settings.mobile_image_width }}vw !important;
    }
  }

  @media screen and (min-width: 768px) and (max-width: 1023px) {
    .premium-hero {
      height: {{ section.settings.tablet_height }}vh;
    }
    .center-hero-img {
      max-width: {{ section.settings.tablet_image_width }}vw !important;
    }
  }

  /* Fallback shield container */
  .shield-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .fallback-text {
    font-family: {{ section.settings.fallback_font }}, serif;
    margin: 0;
    font-weight: {{ section.settings.fallback_font_weight }};
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: {{ section.settings.scroll_indicator_bottom }}px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: scrollBounce 2s ease-in-out infinite;
    cursor: pointer;
    opacity: {{ section.settings.scroll_indicator_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .scroll-indicator:hover {
    opacity: 1;
  }

  .scroll-text {
    font-size: {{ section.settings.scroll_text_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* Keyframe Animations */
  @keyframes heroImageEntrance {
    0% {
      opacity: 0;
      transform: translateY({{ section.settings.entrance_distance }}px) scale({{ section.settings.entrance_scale | divided_by: 100.0 }});
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes heroFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes heroZoomIn {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes heroSlideUp {
    from {
      opacity: 0;
      transform: translateY(100px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0% {
      transform: translateY(0px) scale(1);
    }
    100% {
      transform: translateY(-{{ section.settings.float_distance }}px) scale({{ section.settings.float_scale | divided_by: 100.0 }});
    }
  }

  @keyframes scrollBounce {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(10px);
    }
  }
</style>

<script>
  // Parallax effect on scroll
  {%- if section.settings.enable_parallax -%}
  document.addEventListener('DOMContentLoaded', function() {
    const hero = document.querySelector('.premium-hero[data-parallax="true"]');
    if (!hero) return;

    const bg = hero.querySelector('.premium-hero__bg');
    const speed = parseFloat(hero.dataset.animationSpeed) || 0.5;

    let ticking = false;

    function updateParallax() {
      const scrolled = window.pageYOffset;
      const heroHeight = hero.offsetHeight;

      if (scrolled < heroHeight) {
        const yPos = scrolled * speed;
        bg.style.transform = `translateY(${yPos}px) scale(1.1)`;
      }

      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    });
  });
  {%- endif -%}

  // Smooth scroll indicator
  {%- if section.settings.show_scroll_indicator -%}
  document.addEventListener('DOMContentLoaded', function() {
    const scrollIndicator = document.querySelector('.scroll-indicator');
    if (scrollIndicator) {
      scrollIndicator.addEventListener('click', function() {
        window.scrollTo({
          top: window.innerHeight,
          behavior: 'smooth'
        });
      });
    }
  });
  {%- endif -%}
</script>


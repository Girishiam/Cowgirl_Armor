<style>
  /* ── Overlay ── */
  .cart-drawer__overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 800;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .cart-drawer__overlay.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Panel ── */
  .cart-drawer__panel {
    position: fixed;
    top: 0;
    right: 0;
    width: min(420px, 92vw);
    height: 100%;
    z-index: 801;
    background: {{ section.settings.drawer_bg | default: '#F8F6F4' }};
    color: {{ section.settings.drawer_text | default: '#1A1A1A' }};
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -8px 0 40px rgba(0,0,0,0.12);
  }
  .cart-drawer__panel.is-open {
    transform: translateX(0);
  }

  /* ── Header ── */
  .cart-drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    flex-shrink: 0;
  }
  .cart-drawer__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: inherit;
    opacity: 0.6;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
  }
  .cart-drawer__close:hover { opacity: 1; }

  /* ── Empty state ── */
  .cart-drawer__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
    opacity: 0.5;
  }
  .cart-drawer__empty svg { opacity: 0.4; }
  .cart-drawer__empty p { font-size: 0.95rem; margin: 0; }

  /* ── Body (items list) ── */
  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .cart-drawer__items {
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Cart Item ── */
  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 1rem;
    align-items: start;
  }
  .cart-item__img-wrap {
    display: block;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(0,0,0,0.04);
  }
  .cart-item__img {
    display: block;
    width: 80px;
    height: 80px;
    object-fit: cover;
  }
  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .cart-item__title {
    font-size: 0.88rem;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cart-item__variant {
    font-size: 0.78rem;
    opacity: 0.55;
    margin: 0;
  }
  .cart-item__price {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
  }
  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
  }
  .cart-item__qty-btn {
    width: 26px;
    height: 26px;
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: 4px;
    background: none;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .cart-item__qty-btn:hover {
    background: rgba(139,82,212,0.08);
    border-color: rgba(139,82,212,0.4);
  }
  .cart-item__qty-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .cart-item__qty-num { font-size: 0.88rem; min-width: 20px; text-align: center; }
  .cart-item__remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: inherit;
    opacity: 0.35;
    transition: opacity 0.2s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .cart-item__remove:hover { opacity: 0.8; }

  /* ── Footer ── */
  .cart-drawer__foot {
    border-top: 1px solid rgba(0,0,0,0.08);
    padding: 1.25rem 1.5rem 1.5rem;
    flex-shrink: 0;
  }
  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  .cart-drawer__subtotal-label { opacity: 0.6; }
  .cart-drawer__subtotal-amount { font-weight: 700; font-size: 1.1rem; }
  .cart-drawer__note {
    font-size: 0.75rem;
    opacity: 0.45;
    text-align: center;
    margin: 0.75rem 0 0;
  }

  /* Checkout button */
  .cart-drawer__checkout {
    display: block;
    width: 100%;
    text-align: center;
    padding: 15px 20px;
    background: {{ section.settings.btn_bg | default: '#3A6FE8' }};
    color: {{ section.settings.btn_text | default: '#ffffff' }};
    border: none;
    border-radius: {{ section.settings.btn_radius | default: 6 }}px;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .cart-drawer__checkout:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  .cart-drawer__view-cart {
    display: block;
    width: 100%;
    text-align: center;
    padding: 12px;
    font-size: 0.82rem;
    opacity: 0.5;
    text-decoration: underline;
    color: inherit;
    margin-top: 0.5rem;
    transition: opacity 0.2s;
  }
  .cart-drawer__view-cart:hover { opacity: 0.8; }
</style>

<cart-drawer aria-hidden="true">
  <div class="cart-drawer__overlay"></div>
  <div class="cart-drawer__panel" role="dialog" aria-label="Shopping cart" aria-modal="true">

    <!-- Head -->
    <div class="cart-drawer__head">
      <h2 class="cart-drawer__heading">{{ section.settings.heading | default: 'Your Cart' }}</h2>
      <button class="cart-drawer__close" aria-label="Close cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Empty state -->
    <div class="cart-drawer__empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>
      </svg>
      <p>{{ section.settings.empty_text | default: 'Your cart is empty' }}</p>
    </div>

    <!-- Body with items -->
    <div class="cart-drawer__body" style="display:none;">
      <div class="cart-drawer__items"></div>
    </div>

    <!-- Footer -->
    <div class="cart-drawer__foot">
      <div class="cart-drawer__subtotal">
        <span class="cart-drawer__subtotal-label">{{ section.settings.subtotal_label | default: 'Subtotal' }}</span>
        <span class="cart-drawer__subtotal-amount">$0.00</span>
      </div>
      <a href="/checkout" class="cart-drawer__checkout">
        {{ section.settings.checkout_label | default: 'Checkout' }}
      </a>
      <a href="/cart" class="cart-drawer__view-cart">
        {{ section.settings.view_cart_label | default: 'View full cart' }}
      </a>
      {%- if section.settings.show_note -%}
        <p class="cart-drawer__note">{{ section.settings.note_text | default: 'Taxes and shipping calculated at checkout' }}</p>
      {%- endif -%}
    </div>

  </div>
</cart-drawer>

{% schema %}
{
  "name": "Cart Drawer",
  "limit": 1,
  "settings": [
    { "type": "text",     "id": "heading",        "label": "Drawer Heading",       "default": "Your Cart" },
    { "type": "text",     "id": "empty_text",      "label": "Empty Cart Text",      "default": "Your cart is empty" },
    { "type": "text",     "id": "subtotal_label",  "label": "Subtotal Label",       "default": "Subtotal" },
    { "type": "text",     "id": "checkout_label",  "label": "Checkout Button",      "default": "Checkout" },
    { "type": "text",     "id": "view_cart_label", "label": "View Cart Link",       "default": "View full cart" },
    { "type": "checkbox", "id": "show_note",       "label": "Show checkout note",   "default": true },
    { "type": "text",     "id": "note_text",       "label": "Checkout Note",        "default": "Taxes and shipping calculated at checkout" },
    { "type": "color",    "id": "drawer_bg",       "label": "Drawer Background",    "default": "#F8F6F4" },
    { "type": "color",    "id": "drawer_text",     "label": "Drawer Text Color",    "default": "#1A1A1A" },
    { "type": "color",    "id": "btn_bg",          "label": "Checkout Button Bg",   "default": "#3A6FE8" },
    { "type": "color",    "id": "btn_text",        "label": "Checkout Button Text", "default": "#FFFFFF" },
    { "type": "range",    "id": "btn_radius",      "label": "Button Radius", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 6 }
  ],
  "presets": [{ "name": "Cart Drawer" }]
}
{% endschema %}

<style>
  .premium-waitlist-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body);
  }

  .premium-waitlist__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media screen and (min-width: 1024px) {
    .premium-waitlist__container {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: flex-start;
    }
  }

  /* --- Left Column: Content --- */
  .premium-waitlist__content-col {
    position: sticky;
    top: 120px;
  }

  .premium-waitlist__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    color: inherit;
    letter-spacing: -0.01em;
  }

  .premium-waitlist__text {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.8;
    opacity: 0.9;
    color: inherit;
  }

  .premium-waitlist__text p {
    margin-bottom: 1.5rem;
  }
  .premium-waitlist__text p:last-child {
    margin-bottom: 0;
  }

  /* --- Right Column: Form --- */
  .premium-waitlist__form-col {
    display: flex;
    flex-direction: column;
  }

  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Form Status Messages */
  .premium-form__message {
    padding: 1rem;
    font-size: 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .premium-form__message--success {
    background-color: rgba(46, 204, 113, 0.1);
    color: #27ae60;
    border: 1px solid #27ae60;
  }
  .premium-form__message--error {
    background-color: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid #c0392b;
  }

  /* Input Styling */
  .premium-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 768px) {
    .premium-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .premium-form__field {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .premium-form__label {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: inherit;
    opacity: 0.9;
  }

  .premium-form__label span {
    font-weight: normal;
    opacity: 0.6;
    margin-left: 0.25rem;
  }

  .premium-form__input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0,0,0,0.2);
    color: inherit;
    font-family: inherit;
    font-size: 1rem;
    padding: 0.5rem 0;
    transition: border-color 0.3s ease;
  }

  .premium-form__input:focus {
    outline: none;
    border-bottom-color: {{ section.settings.text_color }};
  }

  /* Custom Phone Input Group */
  .premium-form__phone-group {
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(0,0,0,0.2);
    transition: border-color 0.3s ease;
  }

  .premium-form__phone-group:focus-within {
    border-bottom-color: {{ section.settings.text_color }};
  }

  .premium-form__country-code {
    background: transparent;
    border: none;
    color: inherit;
    font-family: inherit;
    font-size: 1rem;
    padding: 0.5rem 0.5rem 0.5rem 0;
    cursor: pointer;
    outline: none;
    opacity: 0.9;
  }

  .premium-form__phone-group .premium-form__input {
    border-bottom: none; /* Let the group handle the border */
    flex-grow: 1;
    padding-left: 0.5rem;
  }

  /* Submit Button */
  .premium-form__submit {
    align-self: flex-start;
    background: transparent;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    padding: 1rem 3.5rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }

  .premium-form__submit:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* Animation */
  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUpAnim {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="premium-waitlist-{{ section.id }}">
  <div class="premium-waitlist__container">
    <div class="premium-waitlist__content-col fade-up-anim">
      {%- if section.settings.heading != blank -%}
        <h2 class="premium-waitlist__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="premium-waitlist__text">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>

    <div class="premium-waitlist__form-col fade-up-anim" style="animation-delay: 200ms;">
      {%- form 'customer', id: 'PremiumWaitlistForm', class: 'premium-form' -%}
        <input type="hidden" name="contact[tags]" value="waitlist, prospect">

        {%- if form.posted_successfully? -%}
          <div class="premium-form__message premium-form__message--success" tabindex="-1" autofocus>
            {{ section.settings.success_message }}
          </div>
        {%- elsif form.errors -%}
          <div class="premium-form__message premium-form__message--error" tabindex="-1" autofocus>
            {{ section.settings.error_message_prefix }} {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="premium-form__row">
          <div class="premium-form__field">
            <label class="premium-form__label" for="WaitlistForm-first_name">{{ section.settings.first_name_label }} {%- if section.settings.required_text != blank -%}<span>{{ section.settings.required_text }}</span>{%- endif -%}</label>
            <input
              type="text"
              id="WaitlistForm-first_name"
              class="premium-form__input"
              name="contact[first_name]"
              required
              autocomplete="given-name"
            >
          </div>
          <div class="premium-form__field">
            <label class="premium-form__label" for="WaitlistForm-last_name">{{ section.settings.last_name_label }}</label>
            <input
              type="text"
              id="WaitlistForm-last_name"
              class="premium-form__input"
              name="contact[last_name]"
              autocomplete="family-name"
            >
          </div>
        </div>

        <div class="premium-form__field">
          <label class="premium-form__label" for="WaitlistForm-email">{{ section.settings.email_label }} {%- if section.settings.required_text != blank -%}<span>{{ section.settings.required_text }}</span>{%- endif -%}</label>
          <input
            type="email"
            id="WaitlistForm-email"
            class="premium-form__input"
            name="contact[email]"
            required
            autocomplete="email"
            pattern="^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$"
          >
        </div>

        <div class="premium-form__field">
          <label class="premium-form__label" for="WaitlistForm-phone">{{ section.settings.phone_label }} {%- if section.settings.required_text != blank -%}<span>{{ section.settings.required_text }}</span>{%- endif -%}</label>
          <div class="premium-form__phone-group">
            <select class="premium-form__country-code" name="contact[country_code]" aria-label="Country Code">
              <option value="US">United States (+1)</option>
              <option value="CA">Canada (+1)</option>
              <option value="UK">United Kingdom (+44)</option>
              <option value="AU">Australia (+61)</option>
            </select>
            <input
              type="tel"
              id="WaitlistForm-phone"
              class="premium-form__input"
              name="contact[phone]"
              required
              autocomplete="tel"
              placeholder="{{ section.settings.phone_placeholder }}"
            >
          </div>
        </div>

        <button type="submit" class="premium-form__submit">
          {{ section.settings.button_label }}
        </button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Waitlist Form",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F9F9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We have exciting news in March... but until then"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Some things aren't meant to be missed. The pieces that speak to your faith, your fire, and the cowgirl you're becoming — they don't always stay on the shelf long.</p><p>Join the Cowgirl Armor first-come, first-served list and be first in line for every drop, every restock, and every piece created to remind you who you are and whose you are.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit Button Label",
      "default": "I want in!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "You're on the list! Keep an eye on your inbox."
    },
    {
      "type": "text",
      "id": "error_message_prefix",
      "label": "Error Message Prefix",
      "default": "Please adjust the following fields:"
    },
    {
      "type": "header",
      "content": "Form Text & Labels"
    },
    {
      "type": "text",
      "id": "first_name_label",
      "label": "First Name Label",
      "default": "First Name"
    },
    {
      "type": "text",
      "id": "last_name_label",
      "label": "Last Name Label",
      "default": "Last Name"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email Label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone Label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone Placeholder",
      "default": "(555) 000-0000"
    },
    {
      "type": "text",
      "id": "required_text",
      "label": "Required Field Text",
      "default": "(required)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Premium Waitlist Form",
      "category": "Form"
    }
  ]
}
{% endschema %}

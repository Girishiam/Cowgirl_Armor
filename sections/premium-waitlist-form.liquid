<style>
  /* ── Outer wrapper — full width, background lives here ── */
  .premium-waitlist-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  /* ── Inner — layout + color only ── */
  .premium-waitlist-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body);
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  .premium-waitlist__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media screen and (min-width: 1024px) {
    .premium-waitlist__container {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: flex-start;
    }
  }

  .premium-waitlist__content-col {
    position: sticky;
    top: 120px;
  }

  .premium-waitlist__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: inherit;
    letter-spacing: -0.01em;
  }

  .premium-waitlist__text {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.8;
    opacity: 0.88;
    color: inherit;
  }
  .premium-waitlist__text p { margin-bottom: 1.5rem; }
  .premium-waitlist__text p:last-child { margin-bottom: 0; }

  .premium-waitlist__form-col { display: flex; flex-direction: column; }

  /* ── Form ── */
  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .premium-form__message {
    padding: 1rem;
    font-size: 1rem;
    border-radius: 6px;
    margin-bottom: 1rem;
  }
  .premium-form__message--success {
    background-color: rgba(46,204,113,0.15);
    border: 1px solid rgba(46,204,113,0.5);
    {%- if section.settings.use_gradient -%}color: #FFFFFF;{%- else -%}color: #27ae60;{%- endif -%}
  }
  .premium-form__message--error {
    background-color: rgba(231,76,60,0.12);
    border: 1px solid rgba(231,76,60,0.4);
    color: #c0392b;
  }

  .premium-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 768px) {
    .premium-form__row { grid-template-columns: 1fr 1fr; }
  }

  .premium-form__field { display: flex; flex-direction: column; position: relative; }

  .premium-form__label {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: inherit;
    opacity: 0.9;
  }
  .premium-form__label span { font-weight: normal; opacity: 0.6; margin-left: 0.25rem; }

  /* ── Inputs — full bordered box, crisp on any bg ── */
  .premium-form__input {
    width: 100%;
    font-family: inherit;
    font-size: 1rem;
    color: inherit;
    border-radius: 6px;
    padding: 0.85rem 1rem;
    transition: border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    -webkit-appearance: none;
    appearance: none;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.12);
      border: 1.5px solid rgba(255,255,255,0.35);
      caret-color: #FFFFFF;
    {%- else -%}
      background: transparent;
      border: 1.5px solid rgba(0,0,0,0.18);
    {%- endif -%}
  }

  .premium-form__input:focus {
    outline: none;
    {%- if section.settings.use_gradient -%}
      border-color: rgba(255,255,255,0.9);
      background: rgba(255,255,255,0.2);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.12);
    {%- else -%}
      border-color: {{ section.settings.text_color }};
      box-shadow: 0 0 0 3px rgba(139,82,212,0.12);
    {%- endif -%}
  }

  .premium-form__input::placeholder {
    {%- if section.settings.use_gradient -%}
      color: rgba(255,255,255,0.45);
    {%- else -%}
      color: rgba(0,0,0,0.35);
    {%- endif -%}
  }

  /* ── Submit ── */
  .premium-form__submit {
    align-self: flex-start;
    padding: 1rem 3.5rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: opacity 0.25s ease, transform 0.2s ease, background-color 0.25s ease, color 0.25s ease;
    margin-top: 1rem;
    border-radius: 4px;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.15);
      color: #FFFFFF;
      border: 1.5px solid rgba(255,255,255,0.5);
    {%- elsif section.settings.btn_use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
      color: #FFFFFF;
      border: none;
    {%- else -%}
      background: transparent;
      color: {{ section.settings.text_color }};
      border: 1.5px solid {{ section.settings.text_color }};
    {%- endif -%}
  }

  .premium-form__submit:hover {
    transform: translateY(-2px);
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.28);
      border-color: #FFFFFF;
    {%- elsif section.settings.btn_use_gradient -%}
      opacity: 0.85;
    {%- else -%}
      background-color: {{ section.settings.text_color }};
      color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUpAnim { to { opacity: 1; transform: translateY(0); } }
</style>

<div class="premium-waitlist-outer-{{ section.id }}">
  <div class="premium-waitlist-{{ section.id }}">
    <div class="premium-waitlist__container">

      <div class="premium-waitlist__content-col fade-up-anim">
        {%- if section.settings.heading != blank -%}
          <h2 class="premium-waitlist__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="premium-waitlist__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>

      <div class="premium-waitlist__form-col fade-up-anim" style="animation-delay: 200ms;">
        {%- form 'customer', id: 'PremiumWaitlistForm-{{ section.id }}', class: 'premium-form' -%}

          <input type="hidden" name="customer[tags]"              value="waitlist,prospect">
          <input type="hidden" name="customer[accepts_marketing]" value="true">

          {%- if form.posted_successfully? -%}
            <div class="premium-form__message premium-form__message--success" tabindex="-1" autofocus>
              {{ section.settings.success_message }}
            </div>

          {%- else -%}

            {%- if form.errors -%}
              <div class="premium-form__message premium-form__message--error" tabindex="-1" autofocus>
                {{ section.settings.error_message_prefix }} {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="premium-form__row">
              <div class="premium-form__field">
                <label class="premium-form__label" for="WaitlistForm-first-{{ section.id }}">
                  {{ section.settings.first_name_label }}
                  {%- if section.settings.required_text != blank -%}
                    <span>{{ section.settings.required_text }}</span>
                  {%- endif -%}
                </label>
                <input type="text" id="WaitlistForm-first-{{ section.id }}"
                       class="premium-form__input"
                       name="contact[first_name]"
                       autocomplete="given-name" required>
              </div>
              <div class="premium-form__field">
                <label class="premium-form__label" for="WaitlistForm-last-{{ section.id }}">
                  {{ section.settings.last_name_label }}
                </label>
                <input type="text" id="WaitlistForm-last-{{ section.id }}"
                       class="premium-form__input"
                       name="contact[last_name]"
                       autocomplete="family-name">
              </div>
            </div>

            <div class="premium-form__field">
              <label class="premium-form__label" for="WaitlistForm-email-{{ section.id }}">
                {{ section.settings.email_label }}
                {%- if section.settings.required_text != blank -%}
                  <span>{{ section.settings.required_text }}</span>
                {%- endif -%}
              </label>
              <input type="email" id="WaitlistForm-email-{{ section.id }}"
                     class="premium-form__input"
                     name="contact[email]"
                     autocomplete="email"
                     pattern="^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$"
                     required>
            </div>

            <div class="premium-form__field">
              <label class="premium-form__label" for="WaitlistForm-phone-{{ section.id }}">
                {{ section.settings.phone_label }}
              </label>
              <input type="tel" id="WaitlistForm-phone-{{ section.id }}"
                     class="premium-form__input"
                     name="contact[phone]"
                     autocomplete="tel"
                     placeholder="{{ section.settings.phone_placeholder }}">
            </div>

            <button type="submit" class="premium-form__submit">
              {{ section.settings.button_label }}
            </button>

          {%- endif -%}

        {%- endform -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Waitlist Form",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": false,
      "info": "Spans full width. All text and inputs auto-switch to white frosted glass."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (if not gradient)",
      "default": "#F8F6F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We have exciting news in March... but until then"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Some things aren't meant to be missed. Join the Cowgirl Armor first-come, first-served list and be first in line for every drop, every restock, and every piece created to remind you who you are and whose you are.</p>"
    },
    {
      "type": "text", "id": "button_label",         "label": "Submit Button Label",  "default": "I want in!" },
    { "type": "text", "id": "success_message",      "label": "Success Message",       "default": "You're on the list! Keep an eye on your inbox." },
    { "type": "text", "id": "error_message_prefix", "label": "Error Message Prefix",  "default": "Please adjust the following fields:" },

    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "checkbox",
      "id": "btn_use_gradient",
      "label": "Use brand gradient on button",
      "default": true,
      "info": "Ignored when section background is gradient — button auto-adapts to frosted glass."
    },

    {
      "type": "header",
      "content": "Form Labels"
    },
    { "type": "text", "id": "first_name_label",  "label": "First Name Label",    "default": "First Name" },
    { "type": "text", "id": "last_name_label",   "label": "Last Name Label",     "default": "Last Name"  },
    { "type": "text", "id": "email_label",       "label": "Email Label",         "default": "Email"      },
    { "type": "text", "id": "phone_label",       "label": "Phone Label",         "default": "Phone"      },
    { "type": "text", "id": "phone_placeholder", "label": "Phone Placeholder",   "default": "(555) 000-0000" },
    { "type": "text", "id": "required_text",     "label": "Required Field Text", "default": "(required)" },

    {
      "type": "header",
      "content": "Spacing"
    },
    { "type": "range", "id": "padding_top",    "label": "Top Padding",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [{ "name": "Premium Waitlist Form" }]
}
{% endschema %}

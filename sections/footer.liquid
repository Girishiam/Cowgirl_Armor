<footer class="site-footer" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding: 4rem 2rem; border-top: 1px solid {{ section.settings.border_color }};">
  <div class="grid grid-3-col" style="max-width: 1200px; margin: 0 auto; gap: 3rem;">
    {%- for block in section.blocks -%}
      <div class="footer-block" {{ block.shopify_attributes }} style="margin-bottom: 2rem;">
        <h4 style="margin-bottom: 1.5rem; color: {{ section.settings.text_color }};">{{ block.settings.title }}</h4>
        
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <ul style="list-style: none; padding: 0;">
              {%- for link in linklists[block.settings.menu].links -%}
                <li style="margin-bottom: 0.5rem;"><a href="{{ link.url }}" style="color: {{ section.settings.text_color }}; text-decoration: none;">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- when 'text' -%}
            <div style="opacity: 0.8;">{{ block.settings.text }}</div>
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
  <div style="text-align: center; margin-top: 4rem; opacity: 0.6; font-size: 0.8rem;">
    &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#E2E2E2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#1A1A1A"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "About Us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Dedicated to blending faith with frontier heritage.</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text"
      },
      {
        "type": "link_list"
      }
    ]
  }
}
{% endschema %}

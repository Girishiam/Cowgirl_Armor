<style>
  .armor-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  @media screen and (min-width: 768px) {
    .armor-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (min-width: 1024px) {
    .armor-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
  .armor-grid__item {
    position: relative;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  .armor-grid__item:hover {
    transform: translateY(-5px);
  }
.armor-grid__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.75);  /* zoom in to push black edges out of frame */
    padding: 0;
  }
</style>

<div
  class="icon-grid-section"
  style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="armor-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div
        class="armor-grid__item"
        {{ block.shopify_attributes }}
        style="background-color: {{ block.settings.card_bg }};"
      >
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="armor-grid__image"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg armor-grid__image' }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Armor Category Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Grid Gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Grid Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "color", "id": "card_bg", "label": "Card Background Color", "default": "#8BA4AC" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Armor Category Grid",
      "category": "Grid",
      "blocks": [
        { "type": "card", "settings": { "card_bg": "#8BA4AC" } },
        { "type": "card", "settings": { "card_bg": "#6B858D" } },
        { "type": "card", "settings": { "card_bg": "#8BA4AC" } },
        { "type": "card", "settings": { "card_bg": "#6B858D" } },
        { "type": "card", "settings": { "card_bg": "#8BA4AC" } },
        { "type": "card", "settings": { "card_bg": "#6B858D" } }
      ]
    }
  ]
}
{% endschema %}

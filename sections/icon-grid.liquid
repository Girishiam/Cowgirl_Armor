<div class="icon-grid-section" style="background-color: {{ section.settings.bg_color }}; padding-top: clamp({{ section.settings.padding_top | divided_by: 2 }}px, 5vw, {{ section.settings.padding_top }}px); padding-bottom: clamp({{ section.settings.padding_bottom | divided_by: 2 }}px, 5vw, {{ section.settings.padding_bottom }}px);">
  
  {%- if section.settings.title != blank -%}
    <h2 style="text-align: {{ section.settings.title_align }}; color: {{ section.settings.title_color }}; font-size: clamp(28px, 8vw, {{ section.settings.title_size }}px); margin-bottom: {{ section.settings.title_margin }}px;">
      {{ section.settings.title }}
    </h2>
  {%- endif -%}

  <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(min(100%, {{ section.settings.column_min_width }}px), 1fr)); gap: {{ section.settings.grid_gap }}px;">
    {%- for block in section.blocks -%}
      <div class="category-card" {{ block.shopify_attributes }} style="background-color: {{ block.settings.card_bg }}; border-color: {{ block.settings.card_border }}; border-width: {{ section.settings.card_border_width }}px; border-radius: {{ section.settings.card_radius }}px; padding: {{ section.settings.card_padding }}px;">
        
        {%- if section.settings.show_shield_icon -%}
          <div class="shield-container" style="padding: 1rem; width: {{ section.settings.icon_size }}px; height: {{ section.settings.icon_size | times: 1.25 }}px; border-width: {{ section.settings.shield_border_width }}px; border-color: {{ block.settings.card_border }}; background-color: {{ block.settings.shield_bg }};">
            {%- if block.settings.icon != blank -%}
              <img src="{{ block.settings.icon | img_url: 'master' }}" alt="{{ block.settings.title }}" style="max-width: 100%; object-fit: contain;">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}  
          </div>
        {%- elsif block.settings.icon != blank -%}
          <img src="{{ block.settings.icon | img_url: 'master' }}" alt="{{ block.settings.title }}" style="width: {{ section.settings.icon_size }}px; object-fit: contain; margin-bottom: 1rem;">
        {%- else -%}
          <div style="width: {{ section.settings.icon_size }}px; height: {{ section.settings.icon_size }}px; margin-bottom: 1rem;">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        <h3 style="color: {{ block.settings.text_color }}; font-size: clamp(18px, 5vw, {{ section.settings.text_size }}px); margin-top: 1rem;">{{ block.settings.title }}</h3>
        
        {%- if block.settings.text != blank -%}
          <div style="color: {{ block.settings.text_color }}; opacity: 0.9; margin-top: 0.5rem; font-size: clamp(14px, 4vw, 16px);">
            {{ block.settings.text }}
          </div>
        {%- endif -%}

        {%- if block.settings.button_label != blank -%}
          <a href="{{ block.settings.button_link }}" class="btn" style="margin-top: 1.5rem; padding: 0.5rem 1.5rem; font-size: 0.9rem; border-color: {{ block.settings.card_border }}; color: {{ block.settings.text_color }};">
            {{ block.settings.button_label }}
          </a>
        {%- endif -%}
        
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Icon Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Top Padding", "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Bottom Padding", "default": 80
    },
    {
      "type": "header", "content": "Heading Settings"
    },
    {
      "type": "text", "id": "title", "label": "Section Heading", "default": "The Armor"
    },
    {
      "type": "color", "id": "title_color", "label": "Heading Color", "default": "#1A1A1A"
    },
    {
      "type": "range", "id": "title_size", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Heading Size", "default": 48
    },
    {
      "type": "range", "id": "title_margin", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Heading Bottom Margin", "default": 48
    },
    {
      "type": "select", "id": "title_align", "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header", "content": "Grid & Card Settings"
    },
    {
      "type": "range", "id": "column_min_width", "min": 200, "max": 500, "step": 10, "unit": "px", "label": "Min Column Width (Desktop)", "default": 300
    },
    {
      "type": "range", "id": "grid_gap", "min": 10, "max": 80, "step": 2, "unit": "px", "label": "Grid Gap", "default": 32
    },
    {
      "type": "range", "id": "card_padding", "min": 10, "max": 80, "step": 2, "unit": "px", "label": "Card Padding", "default": 48
    },
    {
      "type": "range", "id": "card_radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Card Border Radius", "default": 0
    },
    {
      "type": "range", "id": "card_border_width", "min": 0, "max": 10, "step": 1, "unit": "px", "label": "Card Border Width", "default": 1
    },
    {
      "type": "range", "id": "text_size", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Card Title Size", "default": 24
    },
    {
      "type": "checkbox", "id": "show_shield_icon", "label": "Wrap Icons in Shield", "default": true
    },
    {
      "type": "range", "id": "icon_size", "min": 40, "max": 200, "step": 10, "unit": "px", "label": "Icon/Shield Size", "default": 80
    },
    {
      "type": "range", "id": "shield_border_width", "min": 1, "max": 10, "step": 1, "unit": "px", "label": "Shield Border Width", "default": 2
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Armor Piece",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon/Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Sword of the Spirit" },
        { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Description of the item</p>" },
        { "type": "text", "id": "button_label", "label": "Button Label (Optional)" },
        { "type": "url", "id": "button_link", "label": "Button Link" },
        { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#8BA4AC" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1A1A1A" },
        { "type": "color", "id": "card_border", "label": "Border/Shield Color", "default": "#1A1A1A" },
        { "type": "color", "id": "shield_bg", "label": "Inner Shield Background", "default": "transparent" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Armor Category Grid",
      "category": "Grid",
      "blocks": [
        { "type": "card", "settings": { "title": "Sword of the Spirit" } },
        { "type": "card", "settings": { "title": "Shield of Faith" } },
        { "type": "card", "settings": { "title": "Armor of God" } }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%} Build gradient directly in Liquid {%- endcomment -%}
{%- assign grad_dir   = settings.gradient_direction | default: '135deg' -%}
{%- assign grad_col_1 = settings.gradient_color_1   | default: '#3A6FE8' -%}
{%- assign grad_col_2 = settings.gradient_color_2   | default: '#8B52D4' -%}
{%- assign grad_col_3 = settings.gradient_color_3   | default: '#CC72E8' -%}
{%- assign brand_gradient = 'linear-gradient(' | append: grad_dir | append: ', ' | append: grad_col_1 | append: ' 0%, ' | append: grad_col_2 | append: ' 55%, ' | append: grad_col_3 | append: ' 100%)' -%}

<style>
  /* ── Section wrapper ── */
  .armor-section-{{ section.id }} {
    width: 100%;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #FFFFFF;
  }

  /* ── Inner grid ── */
  .armor-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap }}px;
    max-width: {{ settings.page_width | default: 1400 }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media screen and (min-width: 768px) {
    .armor-grid-{{ section.id }} { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (min-width: 1024px) {
    .armor-grid-{{ section.id }} { grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); }
  }

  /* ── Grid card ── */
  .armor-grid-{{ section.id }} .armor-grid__item {
    position: relative;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    border-radius: {{ section.settings.card_radius }}px;
    /* Gradient background on every card */
    background: {{ brand_gradient }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.18);
  }
  .armor-grid-{{ section.id }} .armor-grid__item:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.35);
  }

  /* ── Image inside card ── */
  .armor-grid-{{ section.id }} .armor-grid__image {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ section.settings.icon_size }}%;
    height: {{ section.settings.icon_size }}%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .armor-grid-{{ section.id }} .armor-grid__item:hover .armor-grid__image {
    transform: translate(-50%, -50%) scale(1.06);
  }

  /* ── Placeholder svg ── */
  .armor-grid-{{ section.id }} .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    fill: rgba(255,255,255,0.25);
    padding: 20%;
  }
</style>

<div class="armor-section-{{ section.id }}">
  <div class="armor-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div
        class="armor-grid__item"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            srcset="
              {{ block.settings.image | image_url: width: 300 }} 300w,
              {{ block.settings.image | image_url: width: 600 }} 600w"
            sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, {{ 100 | divided_by: section.settings.columns_desktop }}vw"
            alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
            class="armor-grid__image"
            loading="lazy"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Armor Category Grid",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 75,
      "info": "How much of the card the icon fills. 100% = edge to edge."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Grid Gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Grid Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon / Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Alt text / label",
          "info": "Used as image alt text for accessibility"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Armor Category Grid",
      "category": "Grid",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}

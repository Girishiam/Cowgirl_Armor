{% comment %}
  Cart page — sections/main-cart.liquid
{% endcomment %}

<style>
  .cart-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px 80px;
  }
  .cart-page__title {
    font-family: var(--font-heading-family, serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    margin: 0 0 2.5rem;
    letter-spacing: -0.02em;
  }
  .cart-page__empty { text-align: center; padding: 4rem 0; }
  .cart-page__empty p { opacity: 0.5; margin-bottom: 1.5rem; }

  /* ── CTA buttons — gradient applied directly ── */
  .cart-page__continue,
  .cart-page__checkout-btn {
    background: linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%);
    color: #FFFFFF;
    border: none;
  }
  .cart-page__continue:hover,
  .cart-page__checkout-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .cart-page__continue {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    padding: 13px 28px;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    transition: opacity 0.2s, transform 0.2s;
  }

  .cart-page__grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 3rem;
    align-items: start;
  }
  .cart-page__items { display: flex; flex-direction: column; }
  .cart-page__item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border, rgba(0,0,0,0.08));
    align-items: start;
  }
  .cart-page__item-img {
    width: 100px; height: 100px;
    object-fit: cover; border-radius: 8px;
    background: rgba(0,0,0,0.04); display: block;
  }
  .cart-page__item-info { display: flex; flex-direction: column; gap: 6px; }
  .cart-page__item-title {
    font-size: 0.95rem; font-weight: 600;
    text-decoration: none; color: inherit; line-height: 1.35;
  }
  .cart-page__item-variant { font-size: 0.82rem; opacity: 0.5; margin: 0; }
  .cart-page__item-price   { font-size: 0.9rem; font-weight: 600; margin: 0; }

  .cart-page__qty { display: flex; align-items: center; gap: 8px; margin-top: 8px; }
  .cart-page__qty-btn {
    width: 30px; height: 30px;
    border: 1px solid rgba(0,0,0,0.18);
    border-radius: 4px; background: none; cursor: pointer;
    font-size: 1rem; display: flex; align-items: center; justify-content: center;
    color: inherit; transition: background 0.15s, border-color 0.15s;
  }
  .cart-page__qty-btn:hover {
    background: rgba(139,82,212,0.08);
    border-color: rgba(139,82,212,0.35);
  }
  .cart-page__qty-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .cart-page__qty-num { font-size: 0.9rem; min-width: 24px; text-align: center; }

  .cart-page__item-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
  .cart-page__line-price { font-size: 0.95rem; font-weight: 700; }
  .cart-page__remove {
    background: none; border: none; cursor: pointer;
    font-size: 0.78rem; opacity: 0.4; color: inherit;
    text-decoration: underline; padding: 0; transition: opacity 0.2s;
  }
  .cart-page__remove:hover { opacity: 0.8; }

  .cart-page__summary {
    background: var(--color-base-bg, #F8F6F4);
    border: 1px solid var(--color-border, #CCCCCC);
    border-radius: 12px;
    padding: 1.75rem;
    position: sticky;
    top: 100px;
  }
  .cart-page__summary-title {
    font-family: var(--font-heading-family, serif);
    font-size: 1.1rem; font-weight: 700; margin: 0 0 1.25rem;
  }
  .cart-page__summary-row {
    display: flex; justify-content: space-between;
    align-items: center; font-size: 0.9rem; margin-bottom: 0.75rem;
  }
  .cart-page__summary-row--total {
    font-size: 1rem; font-weight: 700;
    padding-top: 0.75rem; margin-top: 0.75rem;
    border-top: 1px solid var(--color-border, rgba(0,0,0,0.1));
  }
  .cart-page__summary-label { opacity: 0.6; }

  .cart-page__checkout-btn {
    display: block; width: 100%; text-align: center;
    padding: 15px; border-radius: 6px;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.95rem; font-weight: 600; cursor: pointer;
    text-decoration: none; margin-top: 1.25rem;
    transition: opacity 0.2s, transform 0.2s;
  }

  .cart-page__summary-note {
    font-size: 0.75rem; text-align: center;
    opacity: 0.4; margin: 0.75rem 0 0;
  }

  @media (max-width: 768px) {
    .cart-page { padding: 40px 20px 60px; }
    .cart-page__grid { grid-template-columns: 1fr; }
    .cart-page__summary { position: static; }
  }
  @media (max-width: 480px) {
    .cart-page__item { grid-template-columns: 80px 1fr; }
    .cart-page__item-right { grid-column: 2; flex-direction: row; align-items: center; justify-content: space-between; }
  }
</style>

<div class="cart-page">
  <h1 class="cart-page__title">Your Cart</h1>

  {%- if cart.item_count == 0 -%}
    <div class="cart-page__empty">
      <p>Your cart is currently empty.</p>
      <a href="/collections/all" class="cart-page__continue">Continue Shopping</a>
    </div>

  {%- else -%}
    <div class="cart-page__grid">

      <div class="cart-page__items" id="cart-page-items">
        {%- for item in cart.items -%}
          <div class="cart-page__item" data-variant-id="{{ item.variant_id }}">
            <a href="{{ item.url }}">
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}"
                   class="cart-page__item-img" width="100" height="100" loading="lazy">
            </a>
            <div class="cart-page__item-info">
              <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product_title }}</a>
              {%- if item.variant_title != 'Default Title' -%}
                <p class="cart-page__item-variant">{{ item.variant_title }}</p>
              {%- endif -%}
              <p class="cart-page__item-price">{{ item.price | money }}</p>
              <div class="cart-page__qty">
                <button class="cart-page__qty-btn" data-qty-change data-id="{{ item.variant_id }}" data-delta="-1" aria-label="Decrease">−</button>
                <span class="cart-page__qty-num">{{ item.quantity }}</span>
                <button class="cart-page__qty-btn" data-qty-change data-id="{{ item.variant_id }}" data-delta="1" aria-label="Increase">+</button>
              </div>
            </div>
            <div class="cart-page__item-right">
              <span class="cart-page__line-price">{{ item.final_line_price | money }}</span>
              <button class="cart-page__remove" data-remove-item data-id="{{ item.variant_id }}">Remove</button>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="cart-page__summary">
        <h2 class="cart-page__summary-title">Order Summary</h2>
        <div class="cart-page__summary-row">
          <span class="cart-page__summary-label">Subtotal ({{ cart.item_count }} items)</span>
          <span id="cart-page-subtotal">{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-page__summary-row">
          <span class="cart-page__summary-label">Shipping</span>
          <span>Calculated at checkout</span>
        </div>
        <div class="cart-page__summary-row cart-page__summary-row--total">
          <span>Total</span>
          <span id="cart-page-total">{{ cart.total_price | money }}</span>
        </div>
        <a href="/checkout" class="cart-page__checkout-btn">Proceed to Checkout</a>
        <p class="cart-page__summary-note">Taxes and shipping calculated at checkout</p>
      </div>

    </div>
  {%- endif -%}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var container = document.getElementById('cart-page-items');
  if (!container) return;

  container.addEventListener('click', async function(e) {
    var qtyBtn = e.target.closest('[data-qty-change]');
    var remBtn = e.target.closest('[data-remove-item]');

    if (qtyBtn) {
      var id      = Number(qtyBtn.dataset.id);
      var delta   = Number(qtyBtn.dataset.delta);
      var row     = qtyBtn.closest('.cart-page__item');
      var qtyNum  = row.querySelector('.cart-page__qty-num');
      var current = parseInt(qtyNum.textContent);
      var newQty  = Math.max(0, current + delta);
      qtyBtn.disabled = true;
      var cart = await Cart.changeItem(id, newQty);
      Cart.dispatchUpdate(cart);
      location.reload();
    }

    if (remBtn) {
      var id = Number(remBtn.dataset.id);
      remBtn.disabled = true;
      var cart = await Cart.changeItem(id, 0);
      Cart.dispatchUpdate(cart);
      location.reload();
    }
  });
});
</script>

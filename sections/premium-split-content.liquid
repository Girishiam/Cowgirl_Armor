<style>
  .split-content-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .split-content__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    align-items: center;
  }

  @media screen and (min-width: 1024px) {
    .split-content__grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
    .split-content__image-col {
      order: {% if section.settings.image_position == 'right' %}2{% else %}1{% endif %};
    }
    .split-content__text-col {
      order: {% if section.settings.image_position == 'right' %}1{% else %}2{% endif %};
      padding: 2rem 0;
    }
  }

  .split-content__image-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .split-content__image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .split-content__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    color: {{ section.settings.text_color }};
    margin-bottom: 2rem;
    line-height: 1.2;
    text-align: {{ section.settings.text_align }};
  }

  .split-content__body {
    color: {{ section.settings.text_color }};
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .split-content__body p {
    margin-bottom: 1.5rem;
  }

  .split-content__body strong {
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: 1.05rem;
  }
</style>

<div class="split-content-{{ section.id }}">
  <div class="split-content__grid">
    
    <div class="split-content__image-col fade-up-anim">
      <div class="split-content__image-wrapper">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.heading | escape }}" class="split-content__image">
        {%- else -%}
          <div style="width: 100%; aspect-ratio: 1/1; background: rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center;">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="split-content__text-col fade-up-anim" style="animation-delay: 200ms;">
      {%- if section.settings.heading != blank -%}
        <h2 class="split-content__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.text != blank -%}
        <div class="split-content__body">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Premium Split Content",
  "settings": [
    {
      "type": "color", "id": "bg_color", "label": "Background Color", "default": "transparent"
    },
    {
      "type": "color", "id": "text_color", "label": "Text Color", "default": "#1A1A1A"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "image_picker", "id": "image", "label": "Image"
    },
    {
      "type": "text", "id": "heading", "label": "Heading", "default": "Ephesians 6"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text Content",
      "default": "<p><strong>Cowgirl Armor is founded on Ephesians 6 and The Full Armor of God for all cowgirls.</strong></p><p>11 Put on God's complete set of armor provided for us...</p>"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top Padding", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom Padding", "default": 80 }
  ],
  "presets": [
    {
      "name": "Premium Split Content"
    }
  ]
}
{% endschema %}
<style>
  /* ── Outer wrapper — full width, background lives here ── */
  .split-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  /* ── Inner — constrained width, layout only ── */
  .split-content-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .split-content__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    align-items: center;
  }

  @media screen and (min-width: 1024px) {
    .split-content__grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
    .split-content__image-col {
      order: {% if section.settings.image_position == 'right' %}2{% else %}1{% endif %};
    }
    .split-content__text-col {
      order: {% if section.settings.image_position == 'right' %}1{% else %}2{% endif %};
      padding: 2rem 0;
    }
  }

  .split-content__image-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .split-content__image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .split-content__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 2rem;
    line-height: 1.2;
    text-align: {{ section.settings.text_align }};
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  .split-content__body {
    font-size: 0.95rem;
    line-height: 1.8;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  .split-content__body p { margin-bottom: 1.5rem; }

  .split-content__body strong {
    font-family: var(--font-heading);
    font-weight: bold;
    font-size: 1.05rem;
  }
</style>

<div class="split-outer-{{ section.id }}">
  <div class="split-content-{{ section.id }}">
    <div class="split-content__grid">

      <div class="split-content__image-col fade-up-anim">
        <div class="split-content__image-wrapper">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1000 }}"
              alt="{{ section.settings.heading | escape }}"
              class="split-content__image"
              loading="lazy"
            >
          {%- else -%}
            <div style="width:100%;aspect-ratio:1/1;background:rgba(0,0,0,0.05);display:flex;align-items:center;justify-content:center;">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="split-content__text-col fade-up-anim" style="animation-delay: 200ms;">
        {%- if section.settings.heading != blank -%}
          <h2 class="split-content__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="split-content__body">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Split Content",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": false,
      "info": "Spans full width. Text auto-switches to white."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (if not gradient)",
      "default": "#F8F6F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "left",  "label": "Left"  },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ephesians 6"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text Content",
      "default": "<p><strong>Cowgirl Armor is founded on Ephesians 6 and The Full Armor of God for all cowgirls.</strong></p><p>11 Put on God's complete set of armor provided for us...</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [{ "name": "Premium Split Content" }]
}
{% endschema %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap');

:root {
  --s-cream:      #FAF7F2;
  --s-cream-mid:  #F2EDE4;
  --s-border:     #DDD5C5;
  --s-brown:      #2C1A0E;
  --s-brown-mid:  #5C3D22;
  --s-gold:       #B8863C;
  --s-gold-dim:   rgba(184,134,60,0.10);
  --s-muted:      #8A7560;
  --s-white:      #FFFFFF;
  --s-ff-display: 'Playfair Display', Georgia, serif;
  --s-ff-serif:   'Cormorant Garamond', Georgia, serif;
  --s-ff-body:    'Jost', sans-serif;
}

.sp *, .sp *::before, .sp *::after { box-sizing: border-box; margin: 0; padding: 0; }
.sp a { text-decoration: none; }
.sp ul { list-style: none; }

.sp {
  background: var(--s-cream);
  min-height: 100vh;
  font-family: var(--s-ff-body);
  color: var(--s-brown);
}

/* ── Hero ── */
.sp-hero {
  background: var(--s-white);
  border-bottom: 1px solid var(--s-border);
  padding: clamp(3.5rem,9vw,6rem) clamp(1.5rem,5vw,4rem) clamp(2.5rem,5vw,4rem);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.sp-hero::before {
  content: '✝';
  position: absolute;
  right: 5%;
  top: 50%;
  transform: translateY(-50%);
  font-size: clamp(7rem,15vw,12rem);
  color: var(--s-gold);
  opacity: 0.035;
  line-height: 1;
  pointer-events: none;
  font-family: serif;
}

.sp-hero::after {
  content: '';
  position: absolute;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 56px; height: 2px;
  background: var(--s-gold);
}

.sp-eyebrow {
  font-size: 0.67rem;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--s-gold);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
}
.sp-eyebrow span { display: inline-block; width: 26px; height: 1px; background: var(--s-gold); opacity: 0.45; }

.sp-title {
  font-family: var(--s-ff-display);
  font-size: clamp(2.2rem,6vw,4rem);
  font-weight: 600;
  color: var(--s-brown);
  line-height: 1.1;
  margin-bottom: 2.8rem;
}
.sp-title em { font-style: italic; color: var(--s-gold); }

/* Search bar */
.sp-form { max-width: 620px; margin: 0 auto; }

.sp-field {
  display: flex;
  align-items: stretch;
  height: 56px;
  background: var(--s-white);
  border: 1.5px solid var(--s-border);
  box-shadow: 0 2px 14px rgba(44,26,14,0.06);
  transition: border-color .25s, box-shadow .25s;
}
.sp-field:focus-within {
  border-color: var(--s-gold);
  box-shadow: 0 2px 20px rgba(184,134,60,0.14);
}

.sp-icon {
  display: flex; align-items: center;
  padding: 0 1rem 0 1.25rem;
  color: var(--s-muted); flex-shrink: 0;
}
.sp-icon svg { width:18px;height:18px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round; }

.sp-input {
  flex: 1; min-width: 0;
  background: transparent; border: none;
  padding: 0 0.5rem;
  color: var(--s-brown);
  font-family: var(--s-ff-body);
  font-size: 0.97rem; font-weight: 400;
  height: 100%;
}
.sp-input:focus { outline: none; }
.sp-input::placeholder { color: var(--s-muted); font-style: italic; font-weight: 300; }

.sp-clear {
  display: none; align-items: center; justify-content: center;
  background: transparent; border: none;
  padding: 0 0.6rem; color: var(--s-muted);
  cursor: pointer; transition: color .2s; flex-shrink: 0;
}
.sp-clear:hover { color: var(--s-brown); }
.sp-clear svg { width:13px;height:13px;stroke:currentColor;stroke-width:2.5;fill:none; }

.sp-submit {
  background: var(--s-brown); color: var(--s-cream);
  border: none; padding: 0 1.8rem;
  font-family: var(--s-ff-body);
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  cursor: pointer; flex-shrink: 0;
  transition: background .2s; height: 100%;
}
.sp-submit:hover { background: var(--s-brown-mid); }

.sp-count {
  margin-top: 1.25rem;
  font-size: 0.83rem; color: var(--s-muted);
  letter-spacing: 0.03em; font-style: italic;
}
.sp-count strong { color: var(--s-gold); font-style: normal; font-weight: 600; }

/* ── Body ── */
.sp-body {
  max-width: 1280px; margin: 0 auto;
  padding: clamp(2.5rem,6vw,4rem) clamp(1.5rem,4vw,3rem);
}

/* Filters */
.sp-filters {
  display: flex; flex-wrap: wrap; align-items: center;
  gap: 0.5rem; margin-bottom: 2.5rem;
  padding-bottom: 2rem; border-bottom: 1px solid var(--s-border);
}
.sp-filter-label { font-size: 0.67rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--s-muted); font-weight: 700; margin-right: 0.25rem; }
.sp-filter-btn {
  background: transparent; border: 1px solid var(--s-border);
  color: var(--s-muted); padding: 0.42rem 1.1rem;
  font-family: var(--s-ff-body); font-size: 0.74rem;
  letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer; transition: all .2s; font-weight: 500;
}
.sp-filter-btn:hover, .sp-filter-btn.active { border-color: var(--s-gold); color: var(--s-gold); background: var(--s-gold-dim); }

/* Section header */
.sp-section-hd {
  font-size: 0.67rem; font-weight: 700; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--s-muted);
  margin: 3rem 0 1.5rem;
  display: flex; align-items: center; gap: 1rem;
}
.sp-section-hd::after { content: ''; flex: 1; height: 1px; background: var(--s-border); }

/* Product grid */
.sp-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(240px,1fr)); gap: 1.5rem; }

.sp-card {
  display: block; background: var(--s-white);
  border: 1px solid var(--s-border);
  color: inherit; overflow: hidden; position: relative;
  transition: border-color .25s, box-shadow .25s, transform .25s;
}
.sp-card:hover { border-color: var(--s-gold); box-shadow: 0 8px 32px rgba(44,26,14,0.10); transform: translateY(-3px); }
.sp-card:hover .sp-card-img img { transform: scale(1.05); }

.sp-card-img { aspect-ratio: 3/4; overflow: hidden; background: var(--s-cream-mid); position: relative; }
.sp-card-img img { width:100%;height:100%;object-fit:cover;display:block;transition:transform .55s cubic-bezier(.25,.46,.45,.94); }

.sp-card-placeholder { width:100%;height:100%;display:flex;align-items:center;justify-content:center; }
.sp-card-placeholder svg { width:40px;height:40px;opacity:.16;fill:var(--s-brown); }

.sp-badge { position:absolute;top:.85rem;left:.85rem;background:var(--s-brown);color:var(--s-cream);font-size:.6rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;padding:.28rem .65rem; }
.sp-badge.sale { background:var(--s-gold); }

.sp-card-body { padding: 1.1rem 1.2rem 1.4rem; }
.sp-card-vendor { font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;color:var(--s-gold);font-weight:700;margin-bottom:.3rem; }
.sp-card-title { font-family:var(--s-ff-display);font-size:1rem;font-weight:600;color:var(--s-brown);line-height:1.3;margin-bottom:.6rem; }
.sp-card-price { display:flex;align-items:baseline;gap:.5rem; }
.sp-price { font-size:.95rem;font-weight:600;color:var(--s-brown); }
.sp-compare { font-size:.82rem;color:var(--s-muted);text-decoration:line-through; }
.sp-card-cta { display:inline-flex;align-items:center;gap:.4rem;margin-top:.9rem;font-size:.67rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--s-gold);opacity:0;transform:translateY(5px);transition:opacity .25s,transform .25s; }
.sp-card-cta svg { width:12px;height:12px;stroke:currentColor;stroke-width:2.5;fill:none;stroke-linecap:round;stroke-linejoin:round; }
.sp-card:hover .sp-card-cta { opacity:1;transform:translateY(0); }

/* Page/article rows */
.sp-rows { border: 1px solid var(--s-border); background: var(--s-white); }
.sp-row {
  display: block; padding: 1.5rem 3rem 1.5rem 1.75rem;
  border-bottom: 1px solid var(--s-border);
  color: inherit; transition: background .2s; position: relative;
}
.sp-row:last-child { border-bottom: none; }
.sp-row:hover { background: var(--s-cream); }
.sp-row::after { content:'→';position:absolute;right:1.5rem;top:50%;transform:translateY(-50%);color:var(--s-gold);opacity:0;transition:opacity .2s,right .2s; }
.sp-row:hover::after { opacity:1;right:1.25rem; }
.sp-row-type { font-size:.63rem;letter-spacing:.18em;text-transform:uppercase;color:var(--s-gold);font-weight:700;margin-bottom:.3rem; }
.sp-row-title { font-family:var(--s-ff-display);font-size:1.1rem;font-weight:600;color:var(--s-brown);line-height:1.3;margin-bottom:.3rem; }
.sp-row-excerpt { font-size:.88rem;color:var(--s-muted);line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; }

/* Empty */
.sp-empty { text-align:center;padding:clamp(4rem,10vw,7rem) 1.5rem; }
.sp-empty-icon { width:56px;height:56px;margin:0 auto 2rem;color:var(--s-muted);opacity:.25; }
.sp-empty-icon svg { width:100%;height:100%;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round; }
.sp-empty h2 { font-family:var(--s-ff-display);font-size:clamp(1.5rem,4vw,2rem);font-weight:600;color:var(--s-brown);margin-bottom:.75rem; }
.sp-empty p { color:var(--s-muted);font-size:.95rem;max-width:380px;margin:0 auto 2.5rem;line-height:1.7; }
.sp-tags { display:flex;flex-wrap:wrap;justify-content:center;gap:.5rem; }
.sp-tag { background:var(--s-white);border:1px solid var(--s-border);color:var(--s-brown-mid);padding:.5rem 1.2rem;font-size:.82rem;font-weight:500;letter-spacing:.06em;transition:all .2s; }
.sp-tag:hover { border-color:var(--s-gold);color:var(--s-gold);background:var(--s-gold-dim); }

/* Pagination */
.sp-pages { display:flex;justify-content:center;align-items:center;gap:.4rem;padding:4rem 0 1rem; }
.sp-page { width:40px;height:40px;display:flex;align-items:center;justify-content:center;border:1px solid var(--s-border);color:var(--s-muted);font-size:.85rem;font-family:var(--s-ff-body);transition:all .2s; }
.sp-page:hover,.sp-page.cur { border-color:var(--s-gold);color:var(--s-gold);background:var(--s-gold-dim); }
.sp-page.nav { width:auto;padding:0 1.25rem;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700; }

/* Scripture */
.sp-verse {
  text-align:center;
  padding:clamp(3rem,8vw,5rem) 1.5rem;
  border-top:1px solid var(--s-border);
  margin-top:4rem;
  background:var(--s-white);
  position:relative;overflow:hidden;
}
.sp-verse::before { content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 100% at 50% 100%,rgba(184,134,60,0.05),transparent 70%);pointer-events:none; }
.sp-verse-cross { font-size:1rem;color:var(--s-gold);letter-spacing:.35em;margin-bottom:1.25rem;opacity:.5; }
.sp-verse-text { font-family:var(--s-ff-serif);font-style:italic;font-size:clamp(1.1rem,3vw,1.55rem);font-weight:300;color:var(--s-brown-mid);max-width:560px;margin:0 auto 1rem;line-height:1.65; }
.sp-verse-ref { font-size:.69rem;letter-spacing:.2em;text-transform:uppercase;color:var(--s-gold);font-weight:700; }

@media screen and (max-width:600px) {
  .sp-grid { grid-template-columns:repeat(2,1fr);gap:1rem; }
  .sp-hero::before { display:none; }
}
</style>

<div class="sp">

  <div class="sp-hero">
    <p class="sp-eyebrow"><span></span>{{ shop.name }}<span></span></p>
    <h1 class="sp-title">
      {%- if search.performed -%}
        Results for <em>{{ search.terms | escape }}</em>
      {%- else -%}
        What are you <em>looking for?</em>
      {%- endif -%}
    </h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="sp-form">
      <input type="hidden" name="type" value="product,article,page">
      <div class="sp-field">
        <span class="sp-icon">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input type="search" name="q" id="SpInput" class="sp-input"
          value="{{ search.terms | escape }}"
          placeholder="Search apparel, gifts, devotionals…"
          autocomplete="off" spellcheck="false">
        <button type="button" class="sp-clear" id="SpClear" aria-label="Clear">
          <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button type="submit" class="sp-submit">Search</button>
      </div>

      {%- if search.performed -%}
        <p class="sp-count">
          {%- if search.results_count == 0 -%}
            No results found for <strong>"{{ search.terms | escape }}"</strong>
          {%- elsif search.results_count == 1 -%}
            <strong>1</strong> result found
          {%- else -%}
            <strong>{{ search.results_count }}</strong> results found
          {%- endif -%}
        </p>
      {%- endif -%}
    </form>
  </div>

  <div class="sp-body">
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <div class="sp-empty">
          <div class="sp-empty-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
          <h2>Nothing found for "{{ search.terms | escape }}"</h2>
          <p>Try a different spelling, or browse our collections below.</p>
          <div class="sp-tags">
            <a href="{{ routes.collections_url }}" class="sp-tag">All Collections</a>
            <a href="/collections/apparel" class="sp-tag">Apparel</a>
            <a href="/collections/accessories" class="sp-tag">Accessories</a>
            <a href="/collections/gifts" class="sp-tag">Gifts</a>
            <a href="/collections/new-arrivals" class="sp-tag">New Arrivals</a>
            <a href="/pages/faq" class="sp-tag">FAQ</a>
          </div>
        </div>
      {%- else -%}

        {%- assign sp_products = search.results | where: 'object_type', 'product' -%}
        {%- assign sp_articles = search.results | where: 'object_type', 'article' -%}
        {%- assign sp_pages    = search.results | where: 'object_type', 'page' -%}

        <div class="sp-filters">
          <span class="sp-filter-label">Show:</span>
          <button class="sp-filter-btn active" data-filter="all">All ({{ search.results_count }})</button>
          {%- if sp_products.size > 0 -%}<button class="sp-filter-btn" data-filter="product">Products ({{ sp_products.size }})</button>{%- endif -%}
          {%- if sp_articles.size > 0 -%}<button class="sp-filter-btn" data-filter="article">Articles ({{ sp_articles.size }})</button>{%- endif -%}
          {%- if sp_pages.size > 0 -%}<button class="sp-filter-btn" data-filter="page">Pages ({{ sp_pages.size }})</button>{%- endif -%}
        </div>

        {%- if sp_products.size > 0 -%}
          <p class="sp-section-hd" data-hd="product">Products</p>
          <div class="sp-grid" data-section="product">
            {%- for item in sp_products -%}
              <a href="{{ item.url }}" class="sp-card" data-type="product">
                <div class="sp-card-img">
                  {%- if item.featured_image -%}
                    <img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.featured_image.alt | escape }}" loading="lazy" width="600">
                  {%- else -%}
                    <div class="sp-card-placeholder"><svg viewBox="0 0 24 24"><path d="M20 7l-1-4H5L4 7H1v2h1l2 11h16l2-11h1V7h-3zm-2.5 0h-11l.75-3h9.5l.75 3z"/></svg></div>
                  {%- endif -%}
                  {%- if item.compare_at_price > item.price -%}<span class="sp-badge sale">Sale</span>
                  {%- elsif item.tags contains 'new' -%}<span class="sp-badge">New</span>{%- endif -%}
                </div>
                <div class="sp-card-body">
                  {%- if item.vendor != blank -%}<p class="sp-card-vendor">{{ item.vendor }}</p>{%- endif -%}
                  <h3 class="sp-card-title">{{ item.title }}</h3>
                  <div class="sp-card-price">
                    <span class="sp-price">{{ item.price | money }}</span>
                    {%- if item.compare_at_price > item.price -%}<span class="sp-compare">{{ item.compare_at_price | money }}</span>{%- endif -%}
                  </div>
                  <span class="sp-card-cta">View Product <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if sp_articles.size > 0 -%}
          <p class="sp-section-hd" data-hd="article">Articles &amp; Devotionals</p>
          <div class="sp-rows" data-section="article">
            {%- for item in sp_articles -%}
              <a href="{{ item.url }}" class="sp-row" data-type="article">
                <p class="sp-row-type">Article</p>
                <p class="sp-row-title">{{ item.title }}</p>
                {%- if item.excerpt_or_content != blank -%}<p class="sp-row-excerpt">{{ item.excerpt_or_content | strip_html }}</p>{%- endif -%}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if sp_pages.size > 0 -%}
          <p class="sp-section-hd" data-hd="page">Pages</p>
          <div class="sp-rows" data-section="page">
            {%- for item in sp_pages -%}
              <a href="{{ item.url }}" class="sp-row" data-type="page">
                <p class="sp-row-type">Page</p>
                <p class="sp-row-title">{{ item.title }}</p>
                {%- if item.content != blank -%}<p class="sp-row-excerpt">{{ item.content | strip_html }}</p>{%- endif -%}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <nav class="sp-pages" aria-label="Search pagination">
            {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="sp-page nav">← Prev</a>{%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}<a href="{{ part.url }}" class="sp-page">{{ part.title }}</a>
              {%- else -%}<span class="sp-page cur">{{ part.title }}</span>{%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="sp-page nav">Next →</a>{%- endif -%}
          </nav>
        {%- endif -%}

      {%- endif -%}
    {%- else -%}
      <div class="sp-empty">
        <div class="sp-empty-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
        <h2>Explore the Store</h2>
        <p>Search for apparel, gifts, devotionals, or anything that speaks to your heart.</p>
        <div class="sp-tags">
          <a href="{{ routes.collections_url }}" class="sp-tag">All Collections</a>
          <a href="/collections/apparel" class="sp-tag">Apparel</a>
          <a href="/collections/accessories" class="sp-tag">Accessories</a>
          <a href="/collections/gifts" class="sp-tag">Gifts</a>
          <a href="/collections/new-arrivals" class="sp-tag">New Arrivals</a>
          <a href="/blogs/devotionals" class="sp-tag">Devotionals</a>
        </div>
      </div>
    {%- endif -%}

    <div class="sp-verse">
      <p class="sp-verse-cross">✝ &nbsp; ✝ &nbsp; ✝</p>
      <p class="sp-verse-text">"Put on the full armor of God, so that you can take your stand against the devil's schemes."</p>
      <p class="sp-verse-ref">Ephesians 6:11</p>
    </div>
  </div>
</div>

<script>
  const spInput = document.getElementById('SpInput');
  const spClear = document.getElementById('SpClear');
  function toggleClear() {
    if (spInput && spClear) spClear.style.display = spInput.value.length ? 'flex' : 'none';
  }
  if (spInput) {
    spInput.addEventListener('input', toggleClear);
    toggleClear();
    if (spClear) spClear.addEventListener('click', () => { spInput.value = ''; spInput.focus(); toggleClear(); });
  }
  document.querySelectorAll('.sp-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sp-filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.dataset.filter;
      document.querySelectorAll('[data-type]').forEach(el => { el.style.display = (f==='all'||el.dataset.type===f)?'':'none'; });
      document.querySelectorAll('[data-section]').forEach(el => { el.style.display = (f==='all'||el.dataset.section===f)?'':'none'; });
      document.querySelectorAll('[data-hd]').forEach(el => { el.style.display = (f==='all'||el.dataset.hd===f)?'':'none'; });
    });
  });
</script>

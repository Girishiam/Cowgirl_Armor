<style>
  /* ── Fonts ── */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Jost:wght@300;400;500;600&display=swap');

  :root {
    --search-bg: #0f0f0f;
    --search-surface: #1a1a1a;
    --search-border: #2a2a2a;
    --search-text: #f0ece4;
    --search-muted: #888880;
    --search-accent: #c9a96e;
    --search-accent-dim: rgba(201,169,110,0.12);
    --search-font-display: 'Playfair Display', Georgia, serif;
    --search-font-body: 'Jost', sans-serif;
  }

  .search-page {
    background-color: var(--search-bg);
    min-height: 100vh;
    color: var(--search-text);
    font-family: var(--search-font-body);
  }

  /* ── Hero bar ── */
  .search-hero {
    background: var(--search-surface);
    border-bottom: 1px solid var(--search-border);
    padding: clamp(3rem, 8vw, 5rem) clamp(1.5rem, 5vw, 3rem) clamp(2rem, 5vw, 3rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .search-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 50% 120%, rgba(201,169,110,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .search-eyebrow {
    font-family: var(--search-font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--search-accent);
    margin: 0 0 1rem;
  }

  .search-title {
    font-family: var(--search-font-display);
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 500;
    margin: 0 0 2.5rem;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--search-text);
  }

  .search-title em {
    font-style: italic;
    color: var(--search-accent);
  }

  /* ── Search input ── */
  .search-form {
    max-width: 660px;
    margin: 0 auto;
    position: relative;
  }

  .search-field-wrap {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--search-border);
    background: #111;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .search-field-wrap:focus-within {
    border-color: var(--search-accent);
    box-shadow: 0 0 0 3px rgba(201,169,110,0.1);
  }

  .search-icon-left {
    display: flex;
    align-items: center;
    padding: 0 1rem 0 1.25rem;
    color: var(--search-muted);
    flex-shrink: 0;
  }

  .search-icon-left svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 1.1rem 0.5rem;
    color: var(--search-text);
    font-family: var(--search-font-body);
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    min-width: 0;
  }

  .search-input:focus {
    outline: none;
  }

  .search-input::placeholder {
    color: var(--search-muted);
    font-style: italic;
  }

  .search-clear-btn {
    display: none;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0 0.75rem;
    color: var(--search-muted);
    cursor: pointer;
    transition: color 0.2s;
  }

  .search-clear-btn:hover { color: var(--search-text); }
  .search-clear-btn svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 2; fill: none; }

  .search-submit {
    background: var(--search-accent);
    color: #0f0f0f;
    border: none;
    padding: 0 1.75rem;
    font-family: var(--search-font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .search-submit:hover { opacity: 0.88; }

  .search-count {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--search-muted);
    letter-spacing: 0.03em;
  }

  .search-count strong {
    color: var(--search-accent);
    font-weight: 500;
  }

  /* ── Main layout ── */
  .search-body {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 4vw, 3rem);
  }

  /* ── Filters bar ── */
  .search-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--search-border);
  }

  .filter-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--search-muted);
    margin-right: 0.5rem;
    font-weight: 600;
  }

  .filter-btn {
    background: transparent;
    border: 1px solid var(--search-border);
    color: var(--search-muted);
    padding: 0.45rem 1rem;
    font-family: var(--search-font-body);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .filter-btn:hover,
  .filter-btn.active {
    border-color: var(--search-accent);
    color: var(--search-accent);
    background: var(--search-accent-dim);
  }

  /* ── No results ── */
  .search-empty {
    text-align: center;
    padding: clamp(4rem, 10vw, 7rem) 1.5rem;
  }

  .search-empty-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 2rem;
    opacity: 0.2;
  }

  .search-empty-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: var(--search-text);
    stroke-width: 1.5;
    stroke-linecap: round;
  }

  .search-empty h2 {
    font-family: var(--search-font-display);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 500;
    margin: 0 0 0.75rem;
    color: var(--search-text);
  }

  .search-empty p {
    color: var(--search-muted);
    font-size: 0.95rem;
    max-width: 400px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .search-suggestions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 2rem;
  }

  .suggestion-tag {
    background: var(--search-surface);
    border: 1px solid var(--search-border);
    color: var(--search-muted);
    padding: 0.5rem 1.1rem;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
    letter-spacing: 0.04em;
  }

  .suggestion-tag:hover {
    border-color: var(--search-accent);
    color: var(--search-accent);
  }

  /* ── Results grid ── */
  .search-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5px;
    background: var(--search-border);
  }

  /* ── Product card ── */
  .search-product-card {
    background: var(--search-bg);
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: background 0.25s ease;
  }

  .search-product-card:hover {
    background: var(--search-surface);
  }

  .search-product-card:hover .card-image img {
    transform: scale(1.04);
  }

  .card-image {
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--search-surface);
    position: relative;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #161616;
  }

  .card-image-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.12;
    fill: var(--search-text);
  }

  .card-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--search-accent);
    color: #0f0f0f;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
  }

  .card-body {
    padding: 1.25rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .card-vendor {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--search-accent);
    font-weight: 600;
  }

  .card-title {
    font-family: var(--search-font-display);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--search-text);
  }

  .card-price {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  .price-current {
    font-size: 1rem;
    font-weight: 600;
    color: var(--search-text);
    letter-spacing: 0.02em;
  }

  .price-compare {
    font-size: 0.85rem;
    color: var(--search-muted);
    text-decoration: line-through;
  }

  .card-cta {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--search-accent);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .card-cta svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-product-card:hover .card-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Page / article result ── */
  .search-page-result {
    background: var(--search-bg);
    border-bottom: 1px solid var(--search-border);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .search-page-result:hover {
    background: var(--search-surface);
  }

  .result-type {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--search-accent);
    font-weight: 600;
  }

  .result-title {
    font-family: var(--search-font-display);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--search-text);
    line-height: 1.3;
  }

  .result-excerpt {
    font-size: 0.9rem;
    color: var(--search-muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Pagination ── */
  .search-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    padding: 4rem 0 1rem;
  }

  .page-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--search-border);
    color: var(--search-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s;
    font-family: var(--search-font-body);
  }

  .page-link:hover,
  .page-link.current {
    border-color: var(--search-accent);
    color: var(--search-accent);
    background: var(--search-accent-dim);
  }

  .page-link.prev-next {
    width: auto;
    padding: 0 1.25rem;
    gap: 0.4rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ── Section divider ── */
  .results-section-header {
    font-family: var(--search-font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--search-muted);
    margin: 3rem 0 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .results-section-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--search-border);
  }

  /* ── Promo verse strip ── */
  .search-verse {
    text-align: center;
    padding: 4rem 1.5rem;
    border-top: 1px solid var(--search-border);
    margin-top: 4rem;
  }

  .verse-cross {
    font-size: 1.4rem;
    color: var(--search-accent);
    margin-bottom: 1rem;
    opacity: 0.6;
    letter-spacing: 0.1em;
  }

  .verse-text {
    font-family: var(--search-font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--search-muted);
    max-width: 560px;
    margin: 0 auto 0.75rem;
    line-height: 1.5;
  }

  .verse-ref {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--search-accent);
    font-weight: 600;
    opacity: 0.7;
  }

  /* ── Responsive tweaks ── */
  @media screen and (max-width: 640px) {
    .search-results-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .search-filters {
      gap: 0.4rem;
    }
  }
</style>

<div class="search-page">

  <!-- Hero / Search Bar -->
  <div class="search-hero">
    <p class="search-eyebrow">Armored in Faith &nbsp;·&nbsp; {{ shop.name }}</p>
    <h1 class="search-title">
      {%- if search.performed -%}
        Results for <em>{{ search.terms | escape }}</em>
      {%- else -%}
        What are you <em>seeking?</em>
      {%- endif -%}
    </h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="hidden" name="type" value="product,article,page">
      <div class="search-field-wrap">
        <span class="search-icon-left">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input
          type="search"
          name="q"
          id="Search"
          class="search-input"
          value="{{ search.terms | escape }}"
          placeholder="Search apparel, devotionals, gifts…"
          autocomplete="off"
          spellcheck="false"
        >
        <button type="button" class="search-clear-btn" id="SearchClear" aria-label="Clear search">
          <svg viewBox="0 0 24 24" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button type="submit" class="search-submit">Search</button>
      </div>

      {%- if search.performed -%}
        <p class="search-count">
          {%- if search.results_count == 0 -%}
            No results found
          {%- else -%}
            <strong>{{ search.results_count }}</strong> result{{ search.results_count | plural: '', 's' }} found
          {%- endif -%}
        </p>
      {%- endif -%}
    </form>
  </div>

  <!-- Body -->
  <div class="search-body">

    {%- if search.performed -%}

      {%- if search.results_count == 0 -%}
        <!-- Empty state -->
        <div class="search-empty">
          <div class="search-empty-icon">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h2>Nothing found for "{{ search.terms | escape }}"</h2>
          <p>Try a different word, check your spelling, or explore our collections below.</p>
          <div class="search-suggestions">
            <a href="{{ routes.collections_url }}" class="suggestion-tag">All Collections</a>
            <a href="/collections/apparel" class="suggestion-tag">Apparel</a>
            <a href="/collections/gifts" class="suggestion-tag">Gifts</a>
            <a href="/collections/new-arrivals" class="suggestion-tag">New Arrivals</a>
            <a href="/pages/faq" class="suggestion-tag">FAQ</a>
          </div>
        </div>

      {%- else -%}

        <!-- Filter bar -->
        {%- assign products = search.results | where: 'object_type', 'product' -%}
        {%- assign articles = search.results | where: 'object_type', 'article' -%}
        {%- assign pages    = search.results | where: 'object_type', 'page' -%}

        <div class="search-filters">
          <span class="filter-label">Filter:</span>
          <button class="filter-btn active" data-filter="all">All ({{ search.results_count }})</button>
          {%- if products.size > 0 -%}
            <button class="filter-btn" data-filter="product">Products ({{ products.size }})</button>
          {%- endif -%}
          {%- if articles.size > 0 -%}
            <button class="filter-btn" data-filter="article">Articles ({{ articles.size }})</button>
          {%- endif -%}
          {%- if pages.size > 0 -%}
            <button class="filter-btn" data-filter="page">Pages ({{ pages.size }})</button>
          {%- endif -%}
        </div>

        <!-- Product results -->
        {%- if products.size > 0 -%}
          <p class="results-section-header" data-section="product">Products</p>
          <div class="search-results-grid" data-section="product">
            {%- for item in products -%}
              <a href="{{ item.url }}" class="search-product-card" data-type="product">
                <div class="card-image">
                  {%- if item.featured_image -%}
                    <img
                      src="{{ item.featured_image | image_url: width: 600 }}"
                      alt="{{ item.featured_image.alt | escape }}"
                      loading="lazy"
                      width="600"
                    >
                  {%- else -%}
                    <div class="card-image-placeholder">
                      <svg viewBox="0 0 24 24"><path d="M20 7l-1-4H5L4 7H1v2h1l2 11h16l2-11h1V7h-3zm-2.5 0h-11l.75-3h9.5l.75 3z"/></svg>
                    </div>
                  {%- endif -%}
                  {%- if item.compare_at_price > item.price -%}
                    <span class="card-badge">Sale</span>
                  {%- elsif item.tags contains 'new' -%}
                    <span class="card-badge">New</span>
                  {%- endif -%}
                </div>
                <div class="card-body">
                  {%- if item.vendor != blank -%}
                    <span class="card-vendor">{{ item.vendor }}</span>
                  {%- endif -%}
                  <h3 class="card-title">{{ item.title }}</h3>
                  <div class="card-price">
                    <span class="price-current">{{ item.price | money }}</span>
                    {%- if item.compare_at_price > item.price -%}
                      <span class="price-compare">{{ item.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>
                  <span class="card-cta">
                    View Product
                    <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Article results -->
        {%- if articles.size > 0 -%}
          <p class="results-section-header" data-section="article">Articles &amp; Devotionals</p>
          <div data-section="article">
            {%- for item in articles -%}
              <a href="{{ item.url }}" class="search-page-result" data-type="article">
                <span class="result-type">Article</span>
                <span class="result-title">{{ item.title }}</span>
                {%- if item.excerpt_or_content != blank -%}
                  <span class="result-excerpt">{{ item.excerpt_or_content | strip_html }}</span>
                {%- endif -%}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Page results -->
        {%- if pages.size > 0 -%}
          <p class="results-section-header" data-section="page">Pages</p>
          <div data-section="page">
            {%- for item in pages -%}
              <a href="{{ item.url }}" class="search-page-result" data-type="page">
                <span class="result-type">Page</span>
                <span class="result-title">{{ item.title }}</span>
                {%- if item.content != blank -%}
                  <span class="result-excerpt">{{ item.content | strip_html }}</span>
                {%- endif -%}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Pagination -->
        {%- if paginate.pages > 1 -%}
          <nav class="search-pagination" role="navigation" aria-label="Search pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="page-link prev-next">
                ← Prev
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="page-link">{{ part.title }}</a>
              {%- else -%}
                <span class="page-link current">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="page-link prev-next">
                Next →
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endif -%}

    {%- else -%}

      <!-- Pre-search: show suggestions -->
      <div class="search-empty">
        <div class="search-empty-icon">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <h2>Explore the Store</h2>
        <p>Search for apparel, gifts, devotionals, or any topic that speaks to your heart.</p>
        <div class="search-suggestions">
          <a href="{{ routes.collections_url }}" class="suggestion-tag">All Collections</a>
          <a href="/collections/apparel" class="suggestion-tag">Apparel</a>
          <a href="/collections/accessories" class="suggestion-tag">Accessories</a>
          <a href="/collections/gifts" class="suggestion-tag">Gifts</a>
          <a href="/collections/new-arrivals" class="suggestion-tag">New Arrivals</a>
          <a href="/blogs/devotionals" class="suggestion-tag">Devotionals</a>
        </div>
      </div>

    {%- endif -%}

    <!-- Scripture strip -->
    <div class="search-verse">
      <div class="verse-cross">✝</div>
      <p class="verse-text">"Put on the full armor of God, so that you can take your stand against the devil's schemes."</p>
      <p class="verse-ref">Ephesians 6:11</p>
    </div>

  </div><!-- /.search-body -->
</div>

<script>
  // Clear button visibility
  const searchInput = document.getElementById('Search');
  const clearBtn    = document.getElementById('SearchClear');

  function toggleClear() {
    if (searchInput && clearBtn) {
      clearBtn.style.display = searchInput.value.length ? 'flex' : 'none';
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', toggleClear);
    toggleClear();

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        searchInput.focus();
        toggleClear();
      });
    }
  }

  // Filter buttons
  const filterBtns = document.querySelectorAll('.filter-btn');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter;

      document.querySelectorAll('[data-type]').forEach(card => {
        const show = filter === 'all' || card.dataset.type === filter;
        card.style.display = show ? '' : 'none';
      });

      document.querySelectorAll('[data-section]').forEach(section => {
        const show = filter === 'all' || section.dataset.section === filter;
        section.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .purpose-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    {%- liquid
      assign spacing_top = section.settings.spacing_top | default: 'md'
      assign spacing_bottom = section.settings.spacing_bottom | default: 'lg'
    -%}
    padding-top: var(--spacing-{{ spacing_top }});
    padding-bottom: var(--spacing-{{ spacing_bottom }});
  }

  .purpose-{{ section.id }} .purpose-inner {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: clamp(1.5rem, 5vw, 5rem);
    padding-right: clamp(1.5rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .purpose-{{ section.id }} .purpose-image-col {
    order: {% if section.settings.image_position == 'left' %}1{% else %}2{% endif %};
  }

  .purpose-{{ section.id }} .purpose-text-col {
    order: {% if section.settings.image_position == 'left' %}2{% else %}1{% endif %};
  }

  .purpose-{{ section.id }} .purpose-image-wrap {
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    box-shadow: {{ section.settings.image_shadow }};
    aspect-ratio: {{ section.settings.image_ratio }};
  }

  .purpose-{{ section.id }} .purpose-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .purpose-{{ section.id }} .purpose-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.label_color }};
    margin-bottom: 1rem;
  }

  .purpose-{{ section.id }} .purpose-heading {
    font-size: clamp(2rem, 4vw, {{ section.settings.heading_size }}px);
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    line-height: 1.15;
    margin: 0 0 1.5rem;
  }

  .purpose-{{ section.id }} .purpose-text {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: {{ section.settings.text_color }};
    line-height: 1.8;
    margin: 0 0 2.5rem;
    opacity: 0.85;
  }

  .purpose-{{ section.id }} .purpose-btn {
    display: inline-block;
    text-decoration: none;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    border: 2px solid {{ section.settings.btn_border }};
    border-radius: {{ section.settings.btn_radius }}px;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .purpose-{{ section.id }} .purpose-btn:hover {
    background-color: {{ section.settings.btn_hover_bg }};
    color: {{ section.settings.btn_hover_text }};
    border-color: {{ section.settings.btn_hover_bg }};
  }

  @media screen and (max-width: 767px) {
    .purpose-{{ section.id }} .purpose-inner {
      grid-template-columns: 1fr;
    }
    .purpose-{{ section.id }} .purpose-image-col {
      order: {% if section.settings.mobile_image_first %}1{% else %}2{% endif %};
    }
    .purpose-{{ section.id }} .purpose-text-col {
      order: {% if section.settings.mobile_image_first %}2{% else %}1{% endif %};
    }
    .purpose-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
  }
</style>

<div class="purpose-{{ section.id }}">
  <div class="purpose-inner">

    <div class="purpose-image-col">
      <div class="purpose-image-wrap">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="{{ section.settings.image | image_url: width: 450 }} 450w,
                    {{ section.settings.image | image_url: width: 750 }} 750w,
                    {{ section.settings.image | image_url: width: 900 }} 900w"
            sizes="(max-width: 767px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            loading="lazy"
            width="900"
            height="auto"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="purpose-text-col">
      {%- if section.settings.label != blank -%}
        <span class="purpose-label">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="purpose-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="purpose-text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank -%}
        <a
          href="{{ section.settings.btn_link | default: '#' }}"
          class="purpose-btn"
        >
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Purpose",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "checkbox",
      "id": "mobile_image_first",
      "label": "Show image first on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Ratio",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "16 / 9", "label": "Wide (16:9)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Top Spacing",
      "options": [
        { "value": "xs", "label": "Extra Small (20px)" },
        { "value": "sm", "label": "Small (40px)" },
        { "value": "md", "label": "Medium (60px)" },
        { "value": "lg", "label": "Large (80px)" },
        { "value": "xl", "label": "Extra Large (100px)" },
        { "value": "2xl", "label": "2X Large (120px)" }
      ],
      "default": "md"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Bottom Spacing",
      "options": [
        { "value": "xs", "label": "Extra Small (20px)" },
        { "value": "sm", "label": "Small (40px)" },
        { "value": "md", "label": "Medium (60px)" },
        { "value": "lg", "label": "Large (80px)" },
        { "value": "xl", "label": "Extra Large (100px)" },
        { "value": "2xl", "label": "2X Large (120px)" }
      ],
      "default": "lg"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "text",
      "id": "image_shadow",
      "label": "Image Shadow",
      "default": "0 20px 60px rgba(0,0,0,0.12)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow Label",
      "default": "Who We Are"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Purpose"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>We want to build a community of women that can lean on one another and God's word throughout this journey in life. Cowgirl Armor is the idea that you are equipped with God's word and by staying true to that word you have everything you need to go into battle with everyday.</p>"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Our Inspiration"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#8B7355"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Heading Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size (Desktop)",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Heading Weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "btn_border",
      "label": "Button Border",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button Hover Background",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Button Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "btn_padding_v",
      "label": "Button Vertical Padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "btn_padding_h",
      "label": "Button Horizontal Padding",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Purpose"
    }
  ]
}
{% endschema %}

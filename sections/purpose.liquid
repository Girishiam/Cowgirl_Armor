<div class="purpose-section" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="grid grid-2-col" style="align-items: center;">
    
    <div class="purpose-content" style="order: {% if section.settings.image_position == 'left' %}2{% else %}1{% endif %};">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'heading' -%}
            <h2 {{ block.shopify_attributes }} style="color: {{ block.settings.color }}; font-size: clamp(24px, 8vw, {{ block.settings.size }}px); margin-bottom: {{ block.settings.margin_bottom }}px; text-align: {{ block.settings.align }};">
              {{ block.settings.text }}
            </h2>
            
          {%- when 'text' -%}
            <div {{ block.shopify_attributes }} class="purpose-text" style="color: {{ block.settings.color }}; font-size: clamp(14px, 4vw, {{ block.settings.size }}px); margin-bottom: {{ block.settings.margin_bottom }}px; text-align: {{ block.settings.align }};">
              {{ block.settings.text }}
            </div>
            
          {%- when 'button' -%}
            <div {{ block.shopify_attributes }} style="margin-bottom: {{ block.settings.margin_bottom }}px; text-align: {{ block.settings.align }};">
              <a href="{{ block.settings.button_link }}" class="btn" style="border-color: {{ block.settings.border_color }}; color: {{ block.settings.text_color }}; background-color: {{ block.settings.bg_color }};">
                {{ block.settings.button_label }}
              </a>
            </div>
            
        {%- endcase -%}
      {%- endfor -%}
    </div>
    
    <div class="purpose-image" style="order: {% if section.settings.image_position == 'left' %}1{% else %}2{% endif %};">
      {%- if section.settings.image_style == 'shield' -%}
        <div class="shield-container" style="min-height: 400px; height: 100%; border-color: {{ section.settings.shield_border }}; border-width: {{ section.settings.shield_border_width }}px;">
          {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | img_url: '600x' }}" alt="Purpose feature" style="max-width: 100%; height: auto; border-radius: {{ section.settings.image_radius }}px;">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- else -%}
        <div style="text-align: center; display: flex; align-items: center; justify-content: center; min-height: 400px; background-color: rgba(0,0,0,0.05); border-radius: {{ section.settings.image_radius }}px;">
          {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | img_url: '600x' }}" alt="Purpose feature" style="max-width: 100%; height: auto; border-radius: {{ section.settings.image_radius }}px;">
          {%- else -%}
            <div style="width: 100%; height: 100%; max-width: 400px;">
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Image with Text (Armor)",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_style",
      "label": "Image Container Style",
      "options": [
        { "value": "shield", "label": "Shield Outline" },
        { "value": "standard", "label": "Standard Image" }
      ],
      "default": "shield"
    },
    {
      "type": "color",
      "id": "shield_border",
      "label": "Shield Border Color",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "shield_border_width",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Shield Border Width",
      "default": 1
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "text", "id": "text", "label": "Heading", "default": "Our Purpose" },
        { "type": "color", "id": "color", "label": "Text Color", "default": "#1A1A1A" },
        { "type": "range", "id": "size", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Font Size", "default": 48 },
        { "type": "range", "id": "margin_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Bottom Margin", "default": 24 },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Content",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>A mix of spiritual armor and western heritage. Uniting the essence of the frontier with the steadfastness of faith.</p>" },
        { "type": "color", "id": "color", "label": "Text Color", "default": "#1A1A1A" },
        { "type": "range", "id": "size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Font Size", "default": 16 },
        { "type": "range", "id": "margin_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Bottom Margin", "default": 32 },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Learn More" },
        { "type": "url", "id": "button_link", "label": "Button Link" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1A1A1A" },
        { "type": "color", "id": "bg_color", "label": "Background Color", "default": "transparent" },
        { "type": "color", "id": "border_color", "label": "Border Color", "default": "#1A1A1A" },
        { "type": "range", "id": "margin_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Bottom Margin", "default": 20 },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Text (Armor)",
      "category": "Image",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}

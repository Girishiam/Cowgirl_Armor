<style>
  /* ── Outer wrapper — full width, background lives here ── */
  .massive-banner-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  /* ── Inner — layout only ── */
  .massive-banner-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .massive-banner__link {
    text-decoration: none;
    display: block;
    width: 100%;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .massive-banner__link:hover { transform: scale(1.02); }

  .massive-banner__text {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, {{ section.settings.max_font_size }}px);
    text-transform: uppercase;
    text-align: center;
    margin: 0;
    line-height: 1.1;
    letter-spacing: 0.05em;
    padding: 0 1rem;
    white-space: nowrap;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }
</style>

<div class="massive-banner-outer-{{ section.id }}">
  <div class="massive-banner-{{ section.id }}">

    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="massive-banner__link">
    {%- endif -%}

    <h2 class="massive-banner__text">{{ section.settings.text }}</h2>

    {%- if section.settings.link != blank -%}
      </a>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Massive CTA Banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": true,
      "info": "Spans full width. Text auto-switches to white."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Banner Text",
      "default": "JOIN THE COWGIRL ARMY"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link (Optional)"
    },
    {
      "type": "range",
      "id": "max_font_size",
      "min": 40, "max": 150, "step": 5, "unit": "px",
      "label": "Max Font Size (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 160, "step": 4, "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 160, "step": 4, "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [{ "name": "Massive CTA Banner" }]
}
{% endschema %}

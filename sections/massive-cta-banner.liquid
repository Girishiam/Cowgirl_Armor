<style>
  .massive-banner-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .massive-banner__link {
    text-decoration: none;
    display: block;
    width: 100%;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .massive-banner__link:hover {
    transform: scale(1.02);
  }

  .massive-banner__text {
    font-family: var(--font-heading);
    color: {{ section.settings.text_color }};
    font-size: clamp(2.5rem, 8vw, {{ section.settings.max_font_size }}px);
    text-transform: uppercase;
    text-align: center;
    margin: 0;
    line-height: 1.1;
    letter-spacing: 0.05em;
    padding: 0 1rem;
    white-space: nowrap;
  }
</style>

<div class="massive-banner-{{ section.id }}">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="massive-banner__link">
  {%- endif -%}

  <h2 class="massive-banner__text">{{ section.settings.text }}</h2>

  {%- if section.settings.link != blank -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Massive CTA Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#8a8a8a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Banner Text",
      "default": "JOIN THE COWGIRL ARMY"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link (Optional)"
    },
    {
      "type": "range",
      "id": "max_font_size",
      "min": 40,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Max Font Size (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Massive CTA Banner"
    }
  ]
}
{% endschema %}

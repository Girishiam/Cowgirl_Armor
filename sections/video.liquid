<div class="video-section{% if section.settings.enable_animation %} has-animation{% endif %}"
     id="Video-{{ section.id }}"
     style="background-color: {{ section.settings.background_color }};
            background-image: {% if section.settings.bg_pattern != blank %}url('{{ section.settings.bg_pattern | img_url: 'master' }}'){% else %}none{% endif %};
            background-size: {{ section.settings.bg_size }};
            padding-top: {{ section.settings.padding_top }}px;
            padding-bottom: {{ section.settings.padding_bottom }}px;">

  <div class="page-width" style="max-width: {{ section.settings.content_max_width }}px; margin: 0 auto; padding: 0 {{ section.settings.content_padding_h }}px;">
    {%- if section.settings.heading != blank -%}
      <h2 class="video-heading{% if section.settings.enable_animation %} fade-up{% endif %}"
          data-animation-delay="0"
          style="color: {{ section.settings.text_color }};
                 text-align: {{ section.settings.heading_align }};
                 font-size: clamp({{ section.settings.heading_size_min }}px, 5vw, {{ section.settings.heading_size }}px);
                 font-weight: {{ section.settings.heading_weight }};
                 margin-bottom: {{ section.settings.heading_margin }}px;">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="video-wrapper{% if section.settings.enable_animation %} fade-up{% endif %}"
         data-animation-delay="{{ section.settings.video_animation_delay }}"
         style="max-width: {{ section.settings.max_width }}px;
                margin: 0 auto;
                border-radius: {{ section.settings.video_border_radius }}px;
                overflow: hidden;
                box-shadow: {{ section.settings.video_shadow }};">

      {%- if section.settings.video_url != blank -%}
        {%- liquid
          assign video_id = section.settings.video_url.id
          assign video_type = section.settings.video_url.type
        -%}

        <div class="video-container"
             style="position: relative;
                    padding-bottom: {% if section.settings.aspect_ratio == '16-9' %}56.25%{% elsif section.settings.aspect_ratio == '4-3' %}75%{% elsif section.settings.aspect_ratio == '1-1' %}100%{% elsif section.settings.aspect_ratio == '21-9' %}42.86%{% endif %};
                    height: 0;
                    overflow: hidden;
                    background-color: {{ section.settings.video_bg_color }};">

          {%- if section.settings.show_poster and section.settings.poster_image != blank -%}
            <div class="video-poster"
                 id="poster-{{ section.id }}"
                 style="position: absolute;
                        top: 0;
                        left: 0;
                        width: 100%;
                        height: 100%;
                        background-image: url('{{ section.settings.poster_image | img_url: 'master' }}');
                        background-size: cover;
                        background-position: center;
                        cursor: pointer;
                        z-index: 2;">

              <button class="video-play-btn"
                      aria-label="Play video"
                      style="position: absolute;
                             top: 50%;
                             left: 50%;
                             transform: translate(-50%, -50%);
                             width: {{ section.settings.play_button_size }}px;
                             height: {{ section.settings.play_button_size }}px;
                             background: {{ section.settings.play_button_bg }};
                             border: {{ section.settings.play_button_border_width }}px solid {{ section.settings.play_button_border_color }};
                             border-radius: {{ section.settings.play_button_radius }}%;
                             cursor: pointer;
                             transition: all {{ section.settings.play_button_transition }}s ease;
                             display: flex;
                             align-items: center;
                             justify-content: center;">
                <svg width="{{ section.settings.play_icon_size }}" height="{{ section.settings.play_icon_size }}" viewBox="0 0 24 24" fill="{{ section.settings.play_icon_color }}">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>

              {%- if section.settings.show_duration and section.settings.video_duration != blank -%}
                <span class="video-duration"
                      style="position: absolute;
                             bottom: {{ section.settings.duration_offset }}px;
                             right: {{ section.settings.duration_offset }}px;
                             background: {{ section.settings.duration_bg }};
                             color: {{ section.settings.duration_text_color }};
                             padding: {{ section.settings.duration_padding }}px;
                             border-radius: {{ section.settings.duration_radius }}px;
                             font-size: {{ section.settings.duration_font_size }}px;
                             font-weight: {{ section.settings.duration_font_weight }};">
                  {{ section.settings.video_duration }}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if video_type == 'youtube' -%}
            <iframe
              id="video-{{ section.id }}"
              src="https://www.youtube.com/embed/{{ video_id }}?{% if section.settings.youtube_autoplay %}autoplay=1&{% endif %}rel={{ section.settings.youtube_rel }}&modestbranding={{ section.settings.youtube_modest }}&controls={{ section.settings.youtube_controls }}&showinfo={{ section.settings.youtube_showinfo }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              style="position: absolute;
                     top: 0;
                     left: 0;
                     width: 100%;
                     height: 100%;"
              title="{{ section.settings.heading | escape }}"
            ></iframe>
          {%- elsif video_type == 'vimeo' -%}
            <iframe
              id="video-{{ section.id }}"
              src="https://player.vimeo.com/video/{{ video_id }}?{% if section.settings.vimeo_autoplay %}autoplay=1&{% endif %}portrait={{ section.settings.vimeo_portrait }}&byline={{ section.settings.vimeo_byline }}&color={{ section.settings.vimeo_color | remove: '#' }}"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              style="position: absolute;
                     top: 0;
                     left: 0;
                     width: 100%;
                     height: 100%;"
              title="{{ section.settings.heading | escape }}"
            ></iframe>
          {%- endif -%}
        </div>

      {%- elsif section.settings.video_file != blank -%}
        <div class="video-file-wrapper" style="position: relative;">
          {%- if section.settings.show_poster and section.settings.poster_image != blank -%}
            <div class="video-poster"
                 id="poster-file-{{ section.id }}"
                 style="position: absolute;
                        top: 0;
                        left: 0;
                        width: 100%;
                        height: 100%;
                        background-image: url('{{ section.settings.poster_image | img_url: 'master' }}');
                        background-size: cover;
                        background-position: center;
                        cursor: pointer;
                        z-index: 2;">
              <button class="video-play-btn"
                      aria-label="Play video"
                      style="position: absolute;
                             top: 50%;
                             left: 50%;
                             transform: translate(-50%, -50%);
                             width: {{ section.settings.play_button_size }}px;
                             height: {{ section.settings.play_button_size }}px;
                             background: {{ section.settings.play_button_bg }};
                             border: {{ section.settings.play_button_border_width }}px solid {{ section.settings.play_button_border_color }};
                             border-radius: {{ section.settings.play_button_radius }}%;
                             cursor: pointer;
                             transition: all {{ section.settings.play_button_transition }}s ease;">
                <svg width="{{ section.settings.play_icon_size }}" height="{{ section.settings.play_icon_size }}" viewBox="0 0 24 24" fill="{{ section.settings.play_icon_color }}">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            </div>
          {%- endif -%}

          <video
            id="video-file-{{ section.id }}"
            {% if section.settings.file_controls %}controls{% endif %}
            {% if section.settings.autoplay %}autoplay{% endif %}
            {% if section.settings.loop %}loop{% endif %}
            {% if section.settings.muted %}muted{% endif %}
            playsinline
            preload="{{ section.settings.preload }}"
            style="width: 100%;
                   height: auto;
                   display: block;
                   background-color: {{ section.settings.video_bg_color }};"
          >
            <source src="{{ section.settings.video_file }}" type="video/mp4">
            {%- if section.settings.video_file_webm != blank -%}
              <source src="{{ section.settings.video_file_webm }}" type="video/webm">
            {%- endif -%}
            {%- if section.settings.captions_file != blank -%}
              <track kind="captions" src="{{ section.settings.captions_file }}" srclang="{{ section.settings.captions_lang }}" label="{{ section.settings.captions_label }}">
            {%- endif -%}
            Your browser does not support the video tag.
          </video>
        </div>

      {%- else -%}
        <div class="video-placeholder"
             style="padding-bottom: {% if section.settings.aspect_ratio == '16-9' %}56.25%{% elsif section.settings.aspect_ratio == '4-3' %}75%{% elsif section.settings.aspect_ratio == '1-1' %}100%{% elsif section.settings.aspect_ratio == '21-9' %}42.86%{% endif %};
                    position: relative;
                    background-color: {{ section.settings.placeholder_bg }};">
          {{ 'lifestyle-2' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.description != blank -%}
      <div class="video-description{% if section.settings.enable_animation %} fade-up{% endif %}"
           data-animation-delay="{{ section.settings.description_animation_delay }}"
           style="text-align: {{ section.settings.description_align }};
                  color: {{ section.settings.text_color }};
                  font-size: {{ section.settings.description_size }}px;
                  line-height: {{ section.settings.description_line_height }};
                  max-width: {{ section.settings.description_max_width }}px;
                  margin: {{ section.settings.description_margin }}px auto 0;
                  padding: 0 {{ section.settings.content_padding_h }}px;">
        {{ section.settings.description }}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .video-play-btn:hover {
    transform: translate(-50%, -50%) scale({{ section.settings.play_button_hover_scale | divided_by: 100.0 }});
    background: {{ section.settings.play_button_hover_bg }};
    box-shadow: {{ section.settings.play_button_hover_shadow }};
  }

  /* Animation classes */
  .fade-up {
    opacity: 0;
    transform: translateY({{ section.settings.animation_distance }}px);
    transition: opacity {{ section.settings.animation_duration }}s {{ section.settings.animation_easing }},
                transform {{ section.settings.animation_duration }}s {{ section.settings.animation_easing }};
  }

  .fade-up.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mobile responsive */
  @media screen and (max-width: 767px) {
    .video-section {
      padding-top: {{ section.settings.mobile_padding_top }}px !important;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px !important;
    }

    .video-play-btn {
      width: {{ section.settings.mobile_play_button_size }}px !important;
      height: {{ section.settings.mobile_play_button_size }}px !important;
    }
  }
</style>

<script>
  // Poster image click to play
  {%- if section.settings.show_poster -%}
  (function() {
    const poster = document.getElementById('poster-{{ section.id }}') || document.getElementById('poster-file-{{ section.id }}');
    const video = document.getElementById('video-{{ section.id }}') || document.getElementById('video-file-{{ section.id }}');

    if (poster && video) {
      poster.addEventListener('click', function() {
        this.style.display = 'none';

        {%- if section.settings.video_url != blank -%}
          // For embedded videos, reload with autoplay
          const currentSrc = video.src;
          if (currentSrc.includes('youtube')) {
            video.src = currentSrc.replace('autoplay=0', 'autoplay=1') + (currentSrc.includes('?') ? '&' : '?') + 'autoplay=1';
          } else if (currentSrc.includes('vimeo')) {
            video.src = currentSrc + (currentSrc.includes('?') ? '&' : '?') + 'autoplay=1';
          }
        {%- else -%}
          // For uploaded videos
          video.play();
        {%- endif -%}
      });
    }
  })();
  {%- endif -%}

  // Scroll animations
  {%- if section.settings.enable_animation -%}
  (function() {
    const options = {
      threshold: {{ section.settings.animation_threshold | divided_by: 100.0 }},
      rootMargin: '{{ section.settings.animation_margin }}px'
    };

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.dataset.animationDelay || 0;
          setTimeout(() => {
            entry.target.classList.add('in-view');
          }, parseFloat(delay) * 1000);

          {%- unless section.settings.repeat_animation -%}
          observer.unobserve(entry.target);
          {%- endunless -%}
        } {%- if section.settings.repeat_animation -%} else {
          entry.target.classList.remove('in-view');
        } {%- endif -%}
      });
    }, options);

    document.querySelectorAll('.video-section .fade-up').forEach(el => {
      observer.observe(el);
    });
  })();
  {%- endif -%}
</script>


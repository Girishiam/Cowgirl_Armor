<style>
  /* ── Outer wrapper — full width, background lives here ── */
  .premium-split-faq-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  /* ── Inner — padding + color ── */
  .premium-split-faq-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  /* ── Watermark ── */
  .premium-split-faq__watermark {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: 1200px;
    height: 100%;
    object-fit: contain;
    object-position: center;
    opacity: {{ section.settings.watermark_opacity | divided_by: 100.0 }};
    z-index: 1;
    pointer-events: none;
    {%- if section.settings.use_gradient -%}
      filter: brightness(0) invert(1);
    {%- endif -%}
  }

  /* ── Container ── */
  .premium-split-faq__container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .premium-split-faq__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .premium-split-faq__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    margin: 0;
    color: inherit;
  }

  /* ── Two-column grid ── */
  .premium-split-faq__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media screen and (min-width: 1024px) {
    .premium-split-faq__grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: flex-start;
    }
  }

  .premium-split-faq__column { display: flex; flex-direction: column; }

  /* ── Accordion ── */
  .premium-faq-item {
    border-top: 1px solid
      {%- if section.settings.use_gradient -%} rgba(255,255,255,0.25)
      {%- else -%} color-mix(in srgb, {{ section.settings.text_color }} 20%, transparent){%- endif -%};
  }

  .premium-faq-item:last-child {
    border-bottom: 1px solid
      {%- if section.settings.use_gradient -%} rgba(255,255,255,0.25)
      {%- else -%} color-mix(in srgb, {{ section.settings.text_color }} 20%, transparent){%- endif -%};
  }

  .premium-faq-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    border: none;
    padding: 1.5rem 0;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2vw, 1.15rem);
    color: inherit;
    text-align: left;
    transition: opacity 0.3s ease;
  }
  .premium-faq-btn:hover { opacity: 0.7; }

  /* ── Cross icon ── */
  .premium-faq-icon {
    position: relative;
    width: 14px; height: 14px;
    flex-shrink: 0;
    margin-left: 1.5rem;
  }
  .premium-faq-icon::before,
  .premium-faq-icon::after {
    content: '';
    position: absolute;
    background-color: currentColor;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .premium-faq-icon::before { top: 6px; left: 0; width: 14px; height: 1px; }
  .premium-faq-icon::after  { top: 0; left: 6px; width: 1px; height: 14px; }
  .premium-faq-item.is-active .premium-faq-icon::after { transform: rotate(90deg); }

  /* ── Answer expand ── */
  .premium-faq-answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .premium-faq-item.is-active .premium-faq-answer-wrapper { grid-template-rows: 1fr; }
  .premium-faq-answer-inner { overflow: hidden; }

  .premium-faq-answer-content {
    padding-bottom: 1.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    {%- if section.settings.use_gradient -%}
      opacity: 0.88;
      color: #FFFFFF;
    {%- else -%}
      opacity: 0.85;
    {%- endif -%}
  }

  /* ── Animations ── */
  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUpAnim { to { opacity: 1; transform: translateY(0); } }
</style>

<div class="premium-split-faq-outer-{{ section.id }}">
  <div class="premium-split-faq-{{ section.id }}">

    {%- if section.settings.watermark_image != blank -%}
      <img
        src="{{ section.settings.watermark_image | image_url: width: 1600 }}"
        alt=""
        class="premium-split-faq__watermark"
        loading="lazy"
      >
    {%- endif -%}

    <div class="premium-split-faq__container">

      <div class="premium-split-faq__header fade-up-anim">
        <h2 class="premium-split-faq__heading">{{ section.settings.heading }}</h2>
      </div>

      <div class="premium-split-faq__grid">

        <div class="premium-split-faq__column fade-up-anim" style="animation-delay: 100ms;">
          {%- for block in section.blocks -%}
            {%- assign mod = forloop.index0 | modulo: 2 -%}
            {%- if mod == 0 -%}
              <div class="premium-faq-item" {{ block.shopify_attributes }}>
                <button class="premium-faq-btn" aria-expanded="false">
                  <span>{{ block.settings.question }}</span>
                  <div class="premium-faq-icon"></div>
                </button>
                <div class="premium-faq-answer-wrapper">
                  <div class="premium-faq-answer-inner">
                    <div class="premium-faq-answer-content">{{ block.settings.answer }}</div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="premium-split-faq__column fade-up-anim" style="animation-delay: 200ms;">
          {%- for block in section.blocks -%}
            {%- assign mod = forloop.index0 | modulo: 2 -%}
            {%- if mod != 0 -%}
              <div class="premium-faq-item" {{ block.shopify_attributes }}>
                <button class="premium-faq-btn" aria-expanded="false">
                  <span>{{ block.settings.question }}</span>
                  <div class="premium-faq-icon"></div>
                </button>
                <div class="premium-faq-answer-wrapper">
                  <div class="premium-faq-answer-inner">
                    <div class="premium-faq-answer-content">{{ block.settings.answer }}</div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.querySelector('.premium-split-faq-{{ section.id }}');
    if (!section) return;
    var faqBtns = section.querySelectorAll('.premium-faq-btn');
    faqBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = this.closest('.premium-faq-item');
        var isActive = item.classList.contains('is-active');
        {% if section.settings.close_others %}
          section.querySelectorAll('.premium-faq-item').forEach(function(other) {
            other.classList.remove('is-active');
            other.querySelector('.premium-faq-btn').setAttribute('aria-expanded', 'false');
          });
        {% endif %}
        if (!isActive) {
          item.classList.add('is-active');
          this.setAttribute('aria-expanded', 'true');
        } else {
          item.classList.remove('is-active');
          this.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Two-Column FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions Cowgirl Armor"
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "Close other items when one opens",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": false,
      "info": "Spans full width. Text and dividers auto-switch to white."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (if not gradient)",
      "default": "#F8F6F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Watermark Background"
    },
    {
      "type": "image_picker",
      "id": "watermark_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "watermark_opacity",
      "min": 0, "max": 100, "step": 5, "unit": "%",
      "label": "Image Opacity",
      "default": 10,
      "info": "On gradient bg the image is auto-inverted to white. Keep low for readability."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 160, "step": 4, "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 160, "step": 4, "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "When Can I expect my order?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Provide the answer to the frequently asked question here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Two-Column FAQ",
      "category": "Text",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}

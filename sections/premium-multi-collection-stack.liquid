{%- comment -%} Build gradient directly in Liquid {%- endcomment -%}
{%- assign grad_dir   = settings.gradient_direction | default: '135deg' -%}
{%- assign grad_col_1 = settings.gradient_color_1   | default: '#3A6FE8' -%}
{%- assign grad_col_2 = settings.gradient_color_2   | default: '#8B52D4' -%}
{%- assign grad_col_3 = settings.gradient_color_3   | default: '#CC72E8' -%}
{%- assign brand_gradient = 'linear-gradient(' | append: grad_dir | append: ', ' | append: grad_col_1 | append: ' 0%, ' | append: grad_col_2 | append: ' 55%, ' | append: grad_col_3 | append: ' 100%)' -%}

<style>
  /* ── Outer wrapper ── */
  .mcs-outer-{{ section.id }} {
    width: 100%;
    --mcs-text:       {%- if section.settings.use_gradient -%} #FFFFFF {%- else -%} {{ section.settings.text_color }} {%- endif -%};
    --mcs-border:     {%- if section.settings.use_gradient -%} rgba(255,255,255,0.2) {%- else -%} #E8E8E8 {%- endif -%};
    --mcs-card-bg:    {%- if section.settings.use_gradient -%} rgba(255,255,255,0.1) {%- else -%} #F5F5F7 {%- endif -%};
    --mcs-qty-border: {%- if section.settings.use_gradient -%} rgba(255,255,255,0.3) {%- else -%} #E2E2E2 {%- endif -%};
    color: var(--mcs-text);
    {%- if section.settings.use_gradient -%}
      background: {{ brand_gradient }};
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  /* ── Inner stack ── */
  .multi-coll-stack-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .multi-coll-stack__container {
    max-width: {{ settings.page_width | default: 1400 }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.stack_gap }}px;
  }

  .multi-coll-row { display: flex; flex-direction: column; }

  /* ── Row Header ── */
  .multi-coll-row__header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1.5px solid var(--mcs-border);
  }

  .multi-coll-row__title {
    font-family: var(--font-heading-family, sans-serif);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--mcs-text);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.02em;
    {%- unless section.settings.use_gradient -%}
    /* Gradient text on white mode */
    background: {{ brand_gradient }};
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    {%- endunless -%}
  }

  .multi-coll-row__shop-all {
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    white-space: nowrap;
    margin-left: 1rem;
    position: relative;
    padding-bottom: 3px;
    transition: opacity 0.2s ease;
    {%- if section.settings.use_gradient -%}
      color: rgba(255,255,255,0.7);
    {%- else -%}
      color: {{ grad_col_2 }};
    {%- endif -%}
  }
  /* Gradient underline on shop all */
  .multi-coll-row__shop-all::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5px;
    border-radius: 99px;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.5);
    {%- else -%}
      background: {{ brand_gradient }};
    {%- endif -%}
    transform: scaleX(0.4);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .multi-coll-row__shop-all:hover::after { transform: scaleX(1); }
  .multi-coll-row__shop-all:hover { opacity: 1; }

  /* ── Product Grid ── */
  .multi-coll-row__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 768px) {
    .multi-coll-row__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (min-width: 1024px) {
    .multi-coll-row__grid {
      grid-template-columns: repeat(var(--desktop-cols), 1fr);
      gap: 3rem 2rem;
    }
  }

  /* ── Product Card ── */
  .premium-stacked-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 12px;
      padding: 0 0 1rem;
      overflow: hidden;
      backdrop-filter: blur(4px);
      transition: background 0.2s ease, box-shadow 0.2s ease;
    {%- else -%}
      background: transparent;
      border-radius: 0;
      padding: 0;
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    {%- endif -%}
  }

  {%- if section.settings.use_gradient -%}
  .premium-stacked-card-{{ section.id }}:hover {
    background: rgba(255,255,255,0.13);
    box-shadow: 0 12px 32px rgba(0,0,0,0.15);
  }
  {%- else -%}
  .premium-stacked-card-{{ section.id }}:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.12);
  }
  {%- endif -%}

  .premium-stacked-card-{{ section.id }} .psc__link {
    text-decoration: none;
    color: var(--mcs-text);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .premium-stacked-card-{{ section.id }} .psc__img-wrap {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--mcs-card-bg);
    margin-bottom: 1rem;
    border-radius: {%- if section.settings.use_gradient -%} 0 {%- else -%} {{ section.settings.card_radius }}px {%- endif -%};
    position: relative;
  }

  /* Gradient shimmer overlay on image hover */
  {%- unless section.settings.use_gradient -%}
  .premium-stacked-card-{{ section.id }} .psc__img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ brand_gradient }};
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: multiply;
  }
  .premium-stacked-card-{{ section.id }}:hover .psc__img-wrap::after { opacity: 0.08; }
  {%- endunless -%}

  .premium-stacked-card-{{ section.id }} .psc__img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .premium-stacked-card-{{ section.id }}:hover .psc__img { transform: scale(1.04); }

  .premium-stacked-card-{{ section.id }} .psc__info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex-grow: 1;
    {%- if section.settings.use_gradient -%}padding: 0 1rem;{%- endif -%}
  }

  .premium-stacked-card-{{ section.id }} .psc__title {
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
    color: var(--mcs-text);
    transition: color 0.2s ease;
  }
  {%- unless section.settings.use_gradient -%}
  .premium-stacked-card-{{ section.id }}:hover .psc__title { color: {{ grad_col_2 }}; }
  {%- endunless -%}

  .premium-stacked-card-{{ section.id }} .psc__price {
    font-size: 0.9rem;
    color: var(--mcs-text);
    opacity: 0.75;
  }
  .premium-stacked-card-{{ section.id }} .psc__compare {
    text-decoration: line-through;
    opacity: 0.4;
    margin-right: 0.4rem;
  }

  /* ── Action Row ── */
  .premium-stacked-card-{{ section.id }} .psc__action {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.25rem;
    width: 100%;
    {%- if section.settings.use_gradient -%}padding: 0 1rem;{%- endif -%}
  }

  /* ── Quantity ── */
  .premium-stacked-card-{{ section.id }} .psc__qty {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--mcs-qty-border);
    border-radius: {{ section.settings.btn_radius }}px;
    overflow: hidden;
    width: 36%;
    flex-shrink: 0;
    background: {%- if section.settings.use_gradient -%} rgba(255,255,255,0.08) {%- else -%} transparent {%- endif -%};
  }
  .premium-stacked-card-{{ section.id }} .psc__qty-btn {
    background: transparent;
    border: none;
    width: 32%;
    height: 100%;
    padding: 0.65rem 0;
    cursor: pointer;
    font-size: 1rem;
    color: var(--mcs-text);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .premium-stacked-card-{{ section.id }} .psc__qty-btn:hover {
    background: {%- if section.settings.use_gradient -%} rgba(255,255,255,0.12) {%- else -%} rgba(0,0,0,0.04) {%- endif -%};
    {%- unless section.settings.use_gradient -%}color: {{ grad_col_2 }};{%- endunless -%}
  }
  .premium-stacked-card-{{ section.id }} .psc__qty-input {
    width: 36%;
    border: none;
    background: transparent;
    text-align: center;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--mcs-text);
    -moz-appearance: textfield;
    padding: 0;
  }
  .premium-stacked-card-{{ section.id }} .psc__qty-input::-webkit-outer-spin-button,
  .premium-stacked-card-{{ section.id }} .psc__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  /* ── Add to Cart Button — FIXED HOVER ── */
  .premium-stacked-card-{{ section.id }} .psc__add-btn {
    flex-grow: 1;
    border-radius: {{ section.settings.btn_radius }}px;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    cursor: pointer;
    padding: 0.65rem 0.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.2s ease, opacity 0.2s ease;

    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.15);
      color: #FFFFFF;
      border: 1.5px solid rgba(255,255,255,0.5);
    {%- else -%}
      /* Gradient button — same as rest of site */
      background: {{ brand_gradient }};
      color: #FFFFFF;
      border: none;
      box-shadow: 0 4px 16px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.2);
    {%- endif -%}
  }

  /* Gradient hover overlay — for white mode */
  {%- unless section.settings.use_gradient -%}
  .premium-stacked-card-{{ section.id }} .psc__add-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ brand_gradient }};
    filter: brightness(0.88);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .premium-stacked-card-{{ section.id }} .psc__add-btn span { position: relative; z-index: 1; }
  {%- endunless -%}

  .premium-stacked-card-{{ section.id }} .psc__add-btn:hover:not([disabled]) {
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.28);
      border-color: #FFFFFF;
    {%- else -%}
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.38);
    {%- endif -%}
  }

  {%- unless section.settings.use_gradient -%}
  .premium-stacked-card-{{ section.id }} .psc__add-btn:hover:not([disabled])::after { opacity: 1; }
  {%- endunless -%}

  .premium-stacked-card-{{ section.id }} .psc__add-btn[disabled] {
    opacity: 0.35;
    cursor: not-allowed;
    box-shadow: none;
  }

  /* ── Section Header ── */
  {%- if section.settings.show_section_header -%}
  .mcs-header-{{ section.id }} {
    {%- if section.settings.use_gradient -%}
      text-align: center;
      padding: clamp(2.5rem, 6vw, 4rem) 2rem clamp(1.5rem, 3vw, 2.5rem);
    {%- else -%}
      padding: clamp(2rem, 5vw, 3.5rem) 2rem clamp(1rem, 2vw, 2rem);
      text-align: {{ section.settings.header_align }};
      max-width: {{ settings.page_width | default: 1400 }}px;
      margin: 0 auto;
    {%- endif -%}
  }
  .mcs-header__eyebrow-{{ section.id }} {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: {{ grad_col_2 }};
    margin-bottom: 0.75rem;
  }
  .mcs-header__eyebrow-{{ section.id }}::after {
    content: '';
    display: block;
    height: 2px;
    width: 2.5rem;
    margin-top: 6px;
    border-radius: 99px;
    background: {{ brand_gradient }};
    {%- if section.settings.header_align == 'center' -%}
      margin-left: auto; margin-right: auto;
    {%- endif -%}
  }
  .mcs-header__title-{{ section.id }} {
    font-family: var(--font-heading-family, sans-serif);
    font-size: clamp(1.8rem, 5vw, {{ section.settings.header_size }}px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 0.5rem;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      background: {{ brand_gradient }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {%- endif -%}
  }
  .mcs-header__sub-{{ section.id }} {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    opacity: 0.7;
    color: var(--mcs-text);
    margin: 0;
    line-height: 1.6;
  }
  {%- endif -%}

  /* ── Fade-up animation ── */
  .mcs-fade-up {
    opacity: 0;
    transform: translateY(18px);
    animation: mcsFadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes mcsFadeUp { to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 599px) {
    .multi-coll-stack__container { padding: 0 1rem; }
    .multi-coll-row__header { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>

<div class="mcs-outer-{{ section.id }}">

  {%- if section.settings.show_section_header and section.settings.header_title != blank -%}
    <div class="mcs-header-{{ section.id }}">
      {%- if section.settings.header_eyebrow != blank -%}
        <span class="mcs-header__eyebrow-{{ section.id }}">{{ section.settings.header_eyebrow }}</span>
      {%- endif -%}
      <h2 class="mcs-header__title-{{ section.id }}">{{ section.settings.header_title }}</h2>
      {%- if section.settings.header_subtitle != blank -%}
        <p class="mcs-header__sub-{{ section.id }}">{{ section.settings.header_subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="multi-coll-stack-{{ section.id }}">
    <div class="multi-coll-stack__container">

      {%- for block in section.blocks -%}
        {%- assign target_collection = block.settings.collection -%}
        {%- assign anim_delay = forloop.index0 | times: 120 -%}

        <div
          class="multi-coll-row mcs-fade-up"
          style="--desktop-cols: {{ block.settings.columns_desktop }}; animation-delay: {{ anim_delay }}ms;"
          {{ block.shopify_attributes }}
        >
          <div class="multi-coll-row__header">
            <h2 class="multi-coll-row__title">
              {{ block.settings.title_override | default: target_collection.title | default: 'Featured Collection' }}
            </h2>
            {%- if block.settings.show_view_all and target_collection != blank -%}
              <a href="{{ target_collection.url }}" class="multi-coll-row__shop-all">
                {{ block.settings.shop_all_text | default: 'Shop All' | escape }} →
              </a>
            {%- endif -%}
          </div>

          <div class="multi-coll-row__grid">
            {%- for product in target_collection.products limit: block.settings.product_limit -%}
              {%- assign card_delay = forloop.index0 | times: 60 | plus: anim_delay -%}

              <div class="premium-stacked-card-{{ section.id }} mcs-fade-up" style="animation-delay: {{ card_delay }}ms;">

                <a href="{{ product.url }}" class="psc__link" aria-label="{{ product.title | escape }}">
                  <div class="psc__img-wrap">
                    {%- if product.featured_image != blank -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                                {{ product.featured_image | image_url: width: 700 }} 700w"
                        sizes="(max-width: 599px) 50vw, (max-width: 1023px) 50vw, 25vw"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        class="psc__img"
                        loading="lazy"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'psc__img placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <div class="psc__info">
                    <h3 class="psc__title">{{ product.title }}</h3>
                    <div class="psc__price">
                      {%- if product.compare_at_price > product.price -%}
                        <span class="psc__compare">{{ product.compare_at_price | money }}</span>
                      {%- endif -%}
                      <span>{{ product.price | money }}</span>
                    </div>
                  </div>
                </a>

                {%- form 'product', product, class: 'psc__action' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

                  <div class="psc__qty">
                    <button type="button" class="psc__qty-btn" onclick="this.nextElementSibling.stepDown()" aria-label="Decrease">−</button>
                    <input type="number" name="quantity" class="psc__qty-input" value="1" min="1" aria-label="Quantity">
                    <button type="button" class="psc__qty-btn" onclick="this.previousElementSibling.stepUp()" aria-label="Increase">+</button>
                  </div>

                  <button
                    type="submit"
                    name="add"
                    class="psc__add-btn"
                    {% unless product.available %}disabled{% endunless %}
                  >
                    {%- if section.settings.use_gradient -%}
                      {%- if product.available -%}{{ section.settings.button_add_to_cart | default: 'Add to cart' }}{%- else -%}{{ section.settings.button_sold_out | default: 'Sold Out' }}{%- endif -%}
                    {%- else -%}
                      <span>{%- if product.available -%}{{ section.settings.button_add_to_cart | default: 'Add to cart' }}{%- else -%}{{ section.settings.button_sold_out | default: 'Sold Out' }}{%- endif -%}</span>
                    {%- endif -%}
                  </button>
                {%- endform -%}

              </div>

            {%- else -%}
              {%- for i in (1..block.settings.columns_desktop) -%}
                <div class="premium-stacked-card-{{ section.id }}">
                  <div class="psc__link">
                    <div class="psc__img-wrap">
                      {{ 'product-' | append: i | placeholder_svg_tag: 'psc__img placeholder-svg' }}
                    </div>
                    <div class="psc__info">
                      <h3 class="psc__title">Sample Product</h3>
                      <div class="psc__price">$29.99</div>
                    </div>
                  </div>
                  <div class="psc__action">
                    <div class="psc__qty">
                      <button type="button" class="psc__qty-btn">−</button>
                      <input type="number" class="psc__qty-input" value="1">
                      <button type="button" class="psc__qty-btn">+</button>
                    </div>
                    <button class="psc__add-btn" disabled><span>Add to cart</span></button>
                  </div>
                </div>
              {%- endfor -%}
            {%- endfor -%}

          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Multi-Collection Stack",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background (if not gradient)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Section Header (Optional)"
    },
    {
      "type": "checkbox",
      "id": "show_section_header",
      "label": "Show section header",
      "default": false
    },
    {
      "type": "text",
      "id": "header_eyebrow",
      "label": "Eyebrow Label"
    },
    {
      "type": "text",
      "id": "header_title",
      "label": "Header Title"
    },
    {
      "type": "text",
      "id": "header_subtitle",
      "label": "Header Subtitle"
    },
    {
      "type": "range",
      "id": "header_size",
      "label": "Header Font Size (max)",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "stack_gap",
      "min": 40,
      "max": 160,
      "step": 10,
      "unit": "px",
      "label": "Spacing Between Collections",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",

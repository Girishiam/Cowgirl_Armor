<style>
  .page-hero-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-bg-color: {{ section.settings.bg_color }};
    --section-text-color: {{ section.settings.text_color }};
    --logo-margin: {{ section.settings.logo_margin_bottom }}px;
    --title-margin: {{ section.settings.title_margin_bottom }}px;
    --subtitle-margin: {{ section.settings.subtitle_margin_top }}px;
    --max-width: {{ section.settings.max_width }}px;

    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background-color: var(--section-bg-color);
    position: relative;
    overflow: hidden;
  }

  {%- if section.settings.bg_image != blank -%}
  .page-hero-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: {{ section.settings.bg_image_position }};
    opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
    z-index: 0;
  }
  {%- endif -%}

  {%- if section.settings.enable_gradient_overlay -%}
  .page-hero-{{ section.id }}::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      {{ section.settings.gradient_angle }}deg,
      {{ section.settings.gradient_color_1 }} 0%,
      {{ section.settings.gradient_color_2 }} 100%
    );
    opacity: {{ section.settings.gradient_opacity | divided_by: 100.0 }};
    z-index: 1;
  }
  {%- endif -%}

  .page-hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.content_alignment }};
    max-width: var(--max-width);
    margin: 0 auto;
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .page-hero__inner {
      padding-left: {{ section.settings.padding_horizontal_tablet }}px;
      padding-right: {{ section.settings.padding_horizontal_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .page-hero__inner {
      padding-left: {{ section.settings.padding_horizontal }}px;
      padding-right: {{ section.settings.padding_horizontal }}px;
    }
  }

  .page-hero__breadcrumb {
    font-size: {{ section.settings.breadcrumb_font_size }}px;
    color: var(--section-text-color);
    opacity: {{ section.settings.breadcrumb_opacity | divided_by: 100.0 }};
    margin-bottom: {{ section.settings.breadcrumb_margin }}px;
    text-transform: {{ section.settings.breadcrumb_text_transform }};
    letter-spacing: {{ section.settings.breadcrumb_letter_spacing }}px;
    font-weight: {{ section.settings.breadcrumb_font_weight }};
  }

  .page-hero__breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: opacity {{ section.settings.hover_transition_duration }}ms ease;
  }

  .page-hero__breadcrumb a:hover {
    opacity: 0.6;
  }

  .page-hero__logo {
    margin-bottom: var(--logo-margin);
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .page-hero__logo img {
    max-width: {{ section.settings.logo_width_mobile }}px;
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(
      {{ section.settings.logo_shadow_x }}px
      {{ section.settings.logo_shadow_y }}px
      {{ section.settings.logo_shadow_blur }}px
      rgba(0, 0, 0, {{ section.settings.logo_shadow_opacity | divided_by: 100.0 }})
    );
  }

  @media screen and (min-width: 768px) {
    .page-hero__logo img {
      max-width: {{ section.settings.logo_width_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .page-hero__logo img {
      max-width: {{ section.settings.logo_width }}px;
    }
  }

  .page-hero__title {
    width: 100%;
    text-align: {{ section.settings.text_align }};
    font-size: clamp(
      {{ section.settings.title_font_size_mobile }}px,
      {{ section.settings.title_font_size_vw }}vw,
      {{ section.settings.title_font_size }}px
    );
    color: var(--section-text-color);
    margin: 0 0 var(--title-margin) 0;
    line-height: {{ section.settings.title_line_height }};
    font-weight: {{ section.settings.title_font_weight }};
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
    text-transform: {{ section.settings.title_text_transform }};
    {%- if section.settings.enable_title_shadow -%}
    text-shadow:
      {{ section.settings.title_shadow_x }}px
      {{ section.settings.title_shadow_y }}px
      {{ section.settings.title_shadow_blur }}px
      rgba(0, 0, 0, {{ section.settings.title_shadow_opacity | divided_by: 100.0 }});
    {%- endif -%}
  }

  .page-hero__subtitle {
    width: 100%;
    text-align: {{ section.settings.text_align }};
    font-size: clamp(
      {{ section.settings.subtitle_font_size_mobile }}px,
      {{ section.settings.subtitle_font_size_vw }}vw,
      {{ section.settings.subtitle_font_size }}px
    );
    color: var(--section-text-color);
    opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
    margin-top: var(--subtitle-margin);
    line-height: {{ section.settings.subtitle_line_height }};
    font-weight: {{ section.settings.subtitle_font_weight }};
    max-width: {{ section.settings.subtitle_max_width }}px;
    {%- if section.settings.text_align == 'center' -%}
    margin-left: auto;
    margin-right: auto;
    {%- endif -%}
  }

  /* Scroll Animation */
  .page-hero-animate {
    opacity: 0;
    transform: translateY({{ section.settings.animation_distance }}px);
    transition:
      opacity {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }},
      transform {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }};
  }

  .page-hero-animate.animated {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger delays for multiple elements */
  .page-hero-animate:nth-child(1) { transition-delay: 0ms; }
  .page-hero-animate:nth-child(2) { transition-delay: {{ section.settings.animation_stagger }}ms; }
  .page-hero-animate:nth-child(3) { transition-delay: calc({{ section.settings.animation_stagger }}ms * 2); }
  .page-hero-animate:nth-child(4) { transition-delay: calc({{ section.settings.animation_stagger }}ms * 3); }
</style>

<div class="page-hero-{{ section.id }}">
  <div class="page-hero__inner">
    {%- if section.settings.show_breadcrumb -%}
      <nav class="page-hero__breadcrumb page-hero-animate" aria-label="Breadcrumb">
        <a href="/">{{ 'general.breadcrumb.home' | default: 'Home' }}</a>
        <span class="breadcrumb-divider"> {{ section.settings.breadcrumb_divider }} </span>
        <span>{{ page.title }}</span>
      </nav>
    {%- endif -%}

    {%- if section.settings.logo != blank -%}
      <div class="page-hero__logo page-hero-animate">
        <img
          src="{{ section.settings.logo | image_url: width: 800 }}"
          alt="{{ section.settings.logo.alt | default: page.title | escape }}"
          width="{{ section.settings.logo_width }}"
          height="auto"
          loading="eager"
        >
      </div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="page-hero__title page-hero-animate">{{ section.settings.title }}</h1>
    {%- else -%}
      <h1 class="page-hero__title page-hero-animate">{{ page.title }}</h1>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <div class="page-hero__subtitle page-hero-animate">{{ section.settings.subtitle }}</div>
    {%- endif -%}
  </div>
</div>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const animateElements = document.querySelectorAll('.page-hero-' + sectionId + ' .page-hero-animate');

  if (!animateElements.length) return;

  const observerOptions = {
    threshold: {{ section.settings.animation_threshold | divided_by: 100.0 }},
    rootMargin: '{{ section.settings.animation_root_margin }}px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        {%- if section.settings.animation_once -%}
        observer.unobserve(entry.target);
        {%- endif -%}
      } else {
        {%- unless section.settings.animation_once -%}
        entry.target.classList.remove('animated');
        {%- endunless -%}
      }
    });
  }, observerOptions);

  animateElements.forEach(el => observer.observe(el));
})();
</script>


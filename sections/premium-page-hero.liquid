<style>
  .page-hero-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .page-hero__logo {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .page-hero__logo img {
    max-width: {{ section.settings.logo_width }}px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .page-hero__title {
    max-width: {{ section.settings.logo_width }}px;
    width: 100%;
    text-align: {{ section.settings.text_align }};
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<div class="page-hero-{{ section.id }}">
  {%- if section.settings.logo != blank -%}
    <div class="page-hero__logo fade-up-anim">
      <img src="{{ section.settings.logo | image_url: width: 800 }}" alt="{{ section.settings.logo.alt | default: page.title | escape }}">
    </div>
  {%- endif -%}

  {%- if section.settings.title != blank -%}
    <h1 class="page-hero__title fade-up-anim" style="animation-delay: 100ms;">{{ section.settings.title }}</h1>
  {%- else -%}
    <h1 class="page-hero__title fade-up-anim" style="animation-delay: 100ms;">{{ page.title }}</h1>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Premium Page Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Hero Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Logo Max Width",
      "default": 350
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page Title Override",
      "info": "Leave blank to use the default page title."
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Title Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Premium Page Hero"
    }
  ]
}
{% endschema %}
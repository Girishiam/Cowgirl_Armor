<style>
  /* ── Wrapper ── */
  .faq-split-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.min_height }}px;
    overflow: hidden;
    background-color: {{ section.settings.bg_color }};
    display: flex;
    align-items: stretch;
  }

  /* ── Full-bleed background image ── */
  .faq-split-{{ section.id }} .fs__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_focal }};
    z-index: 0;
  }

  /* ── Overlay over full section ── */
  .faq-split-{{ section.id }} .fs__left-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    {%- assign ov_r = section.settings.overlay_color | color_extract: 'red' -%}
    {%- assign ov_g = section.settings.overlay_color | color_extract: 'green' -%}
    {%- assign ov_b = section.settings.overlay_color | color_extract: 'blue' -%}
    {%- assign ov_a = section.settings.overlay_opacity | divided_by: 100.0 -%}
    background: rgba({{ ov_r }}, {{ ov_g }}, {{ ov_b }}, {{ ov_a }});
  }

  /* ── Inner grid sits above bg image ── */
  .faq-split-{{ section.id }} .fs__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: grid;
    grid-template-columns: {{ section.settings.left_col_width }}% 1fr;
    align-items: start;
  }

  /* ── Left: title block ── */
  .faq-split-{{ section.id }} .fs__left {
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.title_valign }};
    padding: {{ section.settings.left_padding_v }}px {{ section.settings.left_padding_h }}px;
    min-height: {{ section.settings.min_height }}px;
  }

  .faq-split-{{ section.id }} .fs__title {
    font-family: var(--font-heading-family, serif);
    font-size: clamp({{ section.settings.title_size_min }}px, 3vw, {{ section.settings.title_size_max }}px);
    font-weight: {{ section.settings.title_weight }};
    line-height: {{ section.settings.title_line_height | divided_by: 100.0 }};
    color: {{ section.settings.title_color }};
    margin: 0;
    letter-spacing: {{ section.settings.title_letter_spacing | divided_by: 100.0 }}em;
  }

  .faq-split-{{ section.id }} .fs__subtitle {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp(13px, 1.2vw, {{ section.settings.subtitle_size }}px);
    color: {{ section.settings.title_color }};
    opacity: 0.75;
    margin: 12px 0 0;
    font-weight: 400;
  }

  /* ── Right Panel — FAQ ── */
  .faq-split-{{ section.id }} .fs__right {
    background-color: {{ section.settings.faq_bg }};
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ section.settings.right_padding_v }}px {{ section.settings.right_padding_h }}px;
  }

  /* ── Accordion ── */
  .faq-split-{{ section.id }} .faq-list {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .faq-split-{{ section.id }} .faq-item {
    border-top: {{ section.settings.divider_width }}px solid {{ section.settings.divider_color }};
  }
  .faq-split-{{ section.id }} .faq-item:last-child {
    border-bottom: {{ section.settings.divider_width }}px solid {{ section.settings.divider_color }};
  }

  .faq-split-{{ section.id }} .faq-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: {{ section.settings.item_padding_v }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: {{ section.settings.question_color }};
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp({{ section.settings.question_size_min }}px, 1.4vw, {{ section.settings.question_size_max }}px);
    font-weight: {{ section.settings.question_weight }};
    line-height: 1.4;
    transition: opacity 0.2s ease;
  }
  .faq-split-{{ section.id }} .faq-trigger:hover {
    opacity: 0.7;
  }

  /* Caret icon */
  .faq-split-{{ section.id }} .faq-caret {
    flex-shrink: 0;
    width: {{ section.settings.caret_size }}px;
    height: {{ section.settings.caret_size }}px;
    color: {{ section.settings.caret_color }};
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-split-{{ section.id }} .faq-item.is-open .faq-caret {
    transform: rotate(180deg);
  }

  /* Answer panel — animated with max-height */
  .faq-split-{{ section.id }} .faq-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s ease,
                padding 0.35s ease;
    opacity: 0;
    padding-bottom: 0;
  }
  .faq-split-{{ section.id }} .faq-item.is-open .faq-body {
    max-height: 600px;
    opacity: 1;
    padding-bottom: {{ section.settings.item_padding_v }}px;
  }

  .faq-split-{{ section.id }} .faq-answer {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp({{ section.settings.answer_size_min }}px, 1.2vw, {{ section.settings.answer_size_max }}px);
    font-weight: {{ section.settings.answer_weight }};
    line-height: {{ section.settings.answer_line_height | divided_by: 100.0 }};
    color: {{ section.settings.answer_color }};
  }
  .faq-split-{{ section.id }} .faq-answer p { margin: 0 0 0.75em; }
  .faq-split-{{ section.id }} .faq-answer p:last-child { margin-bottom: 0; }
  .faq-split-{{ section.id }} .faq-answer strong { font-weight: 700; }
  .faq-split-{{ section.id }} .faq-answer a {
    color: {{ section.settings.answer_link_color }};
    text-underline-offset: 3px;
  }
  .faq-split-{{ section.id }} .faq-answer ul,
  .faq-split-{{ section.id }} .faq-answer ol {
    padding-left: 1.4em;
    margin: 0.4em 0 0.75em;
  }
  .faq-split-{{ section.id }} .faq-answer li { margin-bottom: 0.3em; }

  /* ── Mobile: stack vertically ── */
  @media screen and (max-width: {{ section.settings.mobile_breakpoint }}px) {
    .faq-split-{{ section.id }} .fs__inner {
      grid-template-columns: 1fr;
    }
    .faq-split-{{ section.id }} .fs__left {
      min-height: {{ section.settings.mobile_image_height }}px;
    }
    .faq-split-{{ section.id }} .fs__right {
      min-height: auto;
      padding: {{ section.settings.right_padding_v | divided_by: 1.5 | round }}px {{ section.settings.right_padding_h | divided_by: 1.5 | round }}px;
    }
  }
</style>

<section class="faq-split-{{ section.id }}">

  {%- comment -%} Full-bleed background {%- endcomment -%}
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 1600 }}"
      srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1600 }} 1600w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
      class="fs__bg"
      loading="lazy"
    >
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'fs__bg placeholder-svg' }}
  {%- endif -%}

  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="fs__left-overlay"></div>
  {%- endif -%}

  <!-- Content grid -->
  <div class="fs__inner">

    <!-- Left: Title -->
    <div class="fs__left">
      {%- if section.settings.title != blank -%}
        <h2 class="fs__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="fs__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- Right: FAQ Accordion -->
    <div class="fs__right">
    <ul class="faq-list" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <li class="faq-item{% if block.settings.open_by_default %} is-open{% endif %}"
              {{ block.shopify_attributes }}>
            <button
              class="faq-trigger"
              aria-expanded="{{ block.settings.open_by_default }}"
              aria-controls="faq-body-{{ block.id }}">
              <span>{{ block.settings.question }}</span>
              <svg class="faq-caret" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.5"
                   stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <div class="faq-body"
                 id="faq-body-{{ block.id }}"
                 role="region">
              {%- if block.settings.answer != blank -%}
                <div class="faq-answer rte">{{ block.settings.answer }}</div>
              {%- endif -%}
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>

</section>

<script>
(function() {
  var section = document.querySelector('.faq-split-{{ section.id }}');
  if (!section) return;

  var items = section.querySelectorAll('.faq-item');

  items.forEach(function(item) {
    var trigger = item.querySelector('.faq-trigger');
    var body    = item.querySelector('.faq-body');
    if (!trigger || !body) return;

    trigger.addEventListener('click', function() {
      var isOpen = item.classList.contains('is-open');

      {%- if section.settings.close_others -%}
      /* Close all other items first */
      items.forEach(function(other) {
        if (other !== item && other.classList.contains('is-open')) {
          other.classList.remove('is-open');
          var otherTrigger = other.querySelector('.faq-trigger');
          if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        }
      });
      {%- endif -%}

      /* Toggle current */
      item.classList.toggle('is-open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQ Split",
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",

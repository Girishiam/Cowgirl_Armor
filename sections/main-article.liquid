<style>
  .premium-article-{{ section.id }} {
    --section-bg-color: {{ section.settings.bg_color }};
    --section-text-color: {{ section.settings.text_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --link-color: {{ section.settings.link_color }};

    background-color: var(--section-bg-color);
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    color: var(--section-text-color);
  }

  .premium-article__header {
    max-width: {{ section.settings.header_max_width }}px;
    margin: 0 auto {{ section.settings.header_margin_bottom }}px;
    text-align: {{ section.settings.header_alignment }};
    padding: 0 {{ section.settings.padding_horizontal_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .premium-article__header {
      padding: 0 {{ section.settings.padding_horizontal_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-article__header {
      padding: 0 {{ section.settings.padding_horizontal }}px;
    }
  }

  .premium-article__title {
    font-family: var(--font-heading);
    font-size: clamp(
      {{ section.settings.title_font_size_mobile }}px,
      {{ section.settings.title_font_size_vw }}vw,
      {{ section.settings.title_font_size }}px
    );
    line-height: {{ section.settings.title_line_height }};
    margin-bottom: {{ section.settings.title_margin_bottom }}px;
    color: var(--section-text-color);
    font-weight: {{ section.settings.title_font_weight }};
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
  }

  .premium-article__meta {
    font-family: var(--font-body);
    font-size: {{ section.settings.meta_font_size }}px;
    opacity: {{ section.settings.meta_opacity | divided_by: 100.0 }};
    text-transform: {{ section.settings.meta_text_transform }};
    letter-spacing: {{ section.settings.meta_letter_spacing }}px;
    font-weight: {{ section.settings.meta_font_weight }};
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.header_alignment }};
    gap: {{ section.settings.meta_gap }}px;
    flex-wrap: wrap;
  }

  .premium-article__meta-separator {
    opacity: 0.4;
  }

  {%- if section.settings.show_read_time -%}
  .premium-article__read-time {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  {%- endif -%}

  .premium-article__image-container {
    max-width: {{ section.settings.image_max_width }}px;
    margin: 0 auto {{ section.settings.image_margin_bottom }}px;
    padding: 0 {{ section.settings.padding_horizontal_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .premium-article__image-container {
      padding: 0 {{ section.settings.padding_horizontal_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-article__image-container {
      padding: 0 {{ section.settings.padding_horizontal }}px;
    }
  }

  .premium-article__image {
    width: 100%;
    height: auto;
    object-fit: {{ section.settings.image_object_fit }};
    border-radius: {{ section.settings.image_border_radius }}px;
    display: block;
    {%- if section.settings.enable_image_shadow -%}
    box-shadow:
      {{ section.settings.image_shadow_x }}px
      {{ section.settings.image_shadow_y }}px
      {{ section.settings.image_shadow_blur }}px
      rgba(0, 0, 0, {{ section.settings.image_shadow_opacity | divided_by: 100.0 }});
    {%- endif -%}
  }

  .premium-article__content {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.padding_horizontal_mobile }}px;
    font-family: var(--font-body);
    font-size: clamp(
      {{ section.settings.content_font_size_mobile }}px,
      {{ section.settings.content_font_size_vw }}vw,
      {{ section.settings.content_font_size }}px
    );
    line-height: {{ section.settings.content_line_height }};
  }

  @media screen and (min-width: 768px) {
    .premium-article__content {
      padding: 0 {{ section.settings.padding_horizontal_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-article__content {
      padding: 0 {{ section.settings.padding_horizontal }}px;
    }
  }

  .premium-article__content p {
    margin-bottom: {{ section.settings.paragraph_spacing }}px;
  }

  .premium-article__content p:last-child {
    margin-bottom: 0;
  }

  .premium-article__content h2,
  .premium-article__content h3,
  .premium-article__content h4 {
    font-family: var(--font-heading);
    margin-top: {{ section.settings.subheading_margin_top }}px;
    margin-bottom: {{ section.settings.subheading_margin_bottom }}px;
    line-height: {{ section.settings.subheading_line_height }};
    font-weight: {{ section.settings.subheading_font_weight }};
  }

  .premium-article__content h2 {
    font-size: {{ section.settings.h2_font_size }}px;
  }

  .premium-article__content h3 {
    font-size: {{ section.settings.h3_font_size }}px;
  }

  .premium-article__content h4 {
    font-size: {{ section.settings.h4_font_size }}px;
  }

  .premium-article__content img {
    max-width: 100%;
    height: auto;
    margin: {{ section.settings.content_image_margin_vertical }}px 0;
    border-radius: {{ section.settings.content_image_border_radius }}px;
  }

  .premium-article__content a {
    color: var(--link-color);
    text-decoration: {{ section.settings.link_decoration }};
    text-underline-offset: {{ section.settings.link_underline_offset }}px;
    transition: opacity {{ section.settings.link_hover_duration }}ms ease;
  }

  .premium-article__content a:hover {
    opacity: {{ section.settings.link_hover_opacity | divided_by: 100.0 }};
  }

  .premium-article__content blockquote {
    border-left: {{ section.settings.blockquote_border_width }}px solid {{ section.settings.blockquote_border_color }};
    padding-left: {{ section.settings.blockquote_padding_left }}px;
    margin: {{ section.settings.blockquote_margin_vertical }}px 0;
    font-style: {{ section.settings.blockquote_font_style }};
    font-size: {{ section.settings.blockquote_font_size }}px;
    opacity: {{ section.settings.blockquote_opacity | divided_by: 100.0 }};
  }

  .premium-article__content ul,
  .premium-article__content ol {
    margin: {{ section.settings.list_margin_vertical }}px 0;
    padding-left: {{ section.settings.list_padding_left }}px;
  }

  .premium-article__content li {
    margin-bottom: {{ section.settings.list_item_spacing }}px;
  }

  {%- if section.settings.show_tags -%}
  .premium-article__tags {
    max-width: {{ section.settings.content_max_width }}px;
    margin: {{ section.settings.tags_margin_top }}px auto 0;
    padding: 0 {{ section.settings.padding_horizontal }}px;
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.tags_gap }}px;
    justify-content: {{ section.settings.header_alignment }};
  }

  .premium-article__tag {
    display: inline-block;
    background-color: {{ section.settings.tag_bg_color }};
    color: {{ section.settings.tag_text_color }};
    padding: {{ section.settings.tag_padding_vertical }}px {{ section.settings.tag_padding_horizontal }}px;
    font-size: {{ section.settings.tag_font_size }}px;
    font-weight: {{ section.settings.tag_font_weight }};
    text-decoration: none;
    border-radius: {{ section.settings.tag_border_radius }}px;
    text-transform: {{ section.settings.tag_text_transform }};
    letter-spacing: {{ section.settings.tag_letter_spacing }}px;
    transition:
      background-color {{ section.settings.tag_hover_duration }}ms ease,
      transform {{ section.settings.tag_hover_duration }}ms ease;
  }

  .premium-article__tag:hover {
    background-color: {{ section.settings.tag_hover_bg_color }};
    transform: translateY({{ section.settings.tag_hover_lift }}px);
  }
  {%- endif -%}

  .premium-article__pagination {
    max-width: {{ section.settings.pagination_max_width }}px;
    margin: {{ section.settings.pagination_margin_top }}px auto 0;
    padding: {{ section.settings.pagination_padding_top }}px {{ section.settings.padding_horizontal }}px 0;
    border-top: {{ section.settings.pagination_border_width }}px solid {{ section.settings.pagination_border_color }};
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: {{ section.settings.pagination_gap }}px;
  }

  .article-nav-link {
    display: flex;
    align-items: center;
    gap: {{ section.settings.nav_link_icon_gap }}px;
    text-decoration: none;
    color: var(--section-text-color);
    font-family: var(--font-heading);
    font-size: clamp({{ section.settings.nav_link_font_size_mobile }}px, 3vw, {{ section.settings.nav_link_font_size }}px);
    font-weight: {{ section.settings.nav_link_font_weight }};
    transition:
      opacity {{ section.settings.nav_link_hover_duration }}ms ease,
      transform {{ section.settings.nav_link_hover_duration }}ms ease;
    max-width: 45%;
  }

  .article-nav-link:hover {
    opacity: {{ section.settings.nav_link_hover_opacity | divided_by: 100.0 }};
    transform: translateX({{ section.settings.nav_link_hover_distance }}px);
  }

  .article-nav-link--prev:hover {
    transform: translateX(calc({{ section.settings.nav_link_hover_distance }}px * -1));
  }

  .article-nav-link svg {
    width: {{ section.settings.nav_link_icon_size }}px;
    height: {{ section.settings.nav_link_icon_size }}px;
    flex-shrink: 0;
    stroke-width: {{ section.settings.nav_link_icon_stroke }}px;
  }

  .article-nav-link--next {
    margin-left: auto;
    text-align: right;
  }

  .article-nav-link__label {
    font-size: {{ section.settings.nav_link_label_font_size }}px;
    opacity: {{ section.settings.nav_link_label_opacity | divided_by: 100.0 }};
    text-transform: {{ section.settings.nav_link_label_text_transform }};
    letter-spacing: {{ section.settings.nav_link_label_letter_spacing }}px;
    margin-bottom: {{ section.settings.nav_link_label_margin_bottom }}px;
    display: block;
  }

  /* Scroll Animation */
  .premium-article-animate {
    opacity: 0;
    transform: translateY({{ section.settings.animation_distance }}px);
    transition:
      opacity {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }},
      transform {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }};
  }

  .premium-article-animate.animated {
    opacity: 1;
    transform: translateY(0);
  }

  .premium-article-animate:nth-child(1) { transition-delay: 0ms; }
  .premium-article-animate:nth-child(2) { transition-delay: {{ section.settings.animation_stagger }}ms; }
  .premium-article-animate:nth-child(3) { transition-delay: calc({{ section.settings.animation_stagger }}ms * 2); }
  .premium-article-animate:nth-child(4) { transition-delay: calc({{ section.settings.animation_stagger }}ms * 3); }
</style>

<article class="premium-article-{{ section.id }}" itemscope itemtype="http://schema.org/BlogPosting">
  <header class="premium-article__header premium-article-animate">
    <h1 class="premium-article__title" itemprop="headline">{{ article.title }}</h1>

    {%- if section.settings.show_date or section.settings.show_author or section.settings.show_read_time -%}
      <div class="premium-article__meta">
        {%- if section.settings.show_date -%}
          <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
            {{ article.published_at | time_tag: format: 'date' }}
          </time>
        {%- endif -%}

        {%- if section.settings.show_date and (section.settings.show_author or section.settings.show_read_time) -%}
          <span class="premium-article__meta-separator">•</span>
        {%- endif -%}

        {%- if section.settings.show_read_time -%}
          {%- assign words = article.content | strip_html | split: ' ' | size -%}
          {%- assign read_time = words | divided_by: 200 -%}
          {%- if read_time == 0 -%}{%- assign read_time = 1 -%}{%- endif -%}
          <span class="premium-article__read-time">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            {{ read_time }} {{ section.settings.read_time_text | default: 'min read' }}
          </span>
        {%- endif -%}

        {%- if section.settings.show_author and (section.settings.show_date or section.settings.show_read_time) -%}
          <span class="premium-article__meta-separator">•</span>
        {%- endif -%}

        {%- if section.settings.show_author -%}
          <span itemprop="author" itemscope itemtype="http://schema.org/Person">
            <span itemprop="name">{{ article.author }}</span>
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </header>

  {%- if article.image and section.settings.show_featured_image -%}
    <div class="premium-article__image-container premium-article-animate">
      <img
        src="{{ article.image | image_url: width: 1600 }}"
        srcset="
          {{ article.image | image_url: width: 800 }} 800w,
          {{ article.image | image_url: width: 1200 }} 1200w,
          {{ article.image | image_url: width: 1600 }} 1600w,
          {{ article.image | image_url: width: 2000 }} 2000w
        "
        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1200px"
        alt="{{ article.image.alt | escape }}"
        class="premium-article__image"
        itemprop="image"
        loading="eager"
        width="{{ article.image.width }}"
        height="{{ article.image.height }}"
      >
    </div>
  {%- endif -%}

  <div class="premium-article__content premium-article-animate" itemprop="articleBody">
    {{ article.content }}
  </div>

  {%- if section.settings.show_tags and article.tags.size > 0 -%}
    <div class="premium-article__tags premium-article-animate">
      {%- for tag in article.tags -%}
        <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="premium-article__tag">
          {{ tag }}
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.show_pagination -%}
    {%- if blog.previous_article or blog.next_article -%}
      <div class="premium-article__pagination">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article.url }}" class="article-nav-link article-nav-link--prev">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <span class="article-nav-link__label">{{ section.settings.prev_label | default: 'Previous' }}</span>
              <span>{{ blog.previous_article.title }}</span>
            </div>
          </a>
        {%- else -%}
          <div></div>
        {%- endif -%}

        {%- if blog.next_article -%}
          <a href="{{ blog.next_article.url }}" class="article-nav-link article-nav-link--next">
            <div>
              <span class="article-nav-link__label">{{ section.settings.next_label | default: 'Next' }}</span>
              <span>{{ blog.next_article.title }}</span>
            </div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</article>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const animateElements = document.querySelectorAll('.premium-article-' + sectionId + ' .premium-article-animate');

  if (!animateElements.length) return;

  const observerOptions = {
    threshold: {{ section.settings.animation_threshold | divided_by: 100.0 }},
    rootMargin: '{{ section.settings.animation_root_margin }}px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        {%- if section.settings.animation_once -%}
        observer.unobserve(entry.target);
        {%- endif -%}
      } else {
        {%- unless section.settings.animation_once -%}
        entry.target.classList.remove('animated');
        {%- endunless -%}
      }
    });
  }, observerOptions);

  animateElements.forEach(el => observer.observe(el));
})();
</script>

{% schema %}
{
  "name": "Article Post",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",

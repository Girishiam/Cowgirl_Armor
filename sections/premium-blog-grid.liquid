<style>
  .premium-blog-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-bg-color: {{ section.settings.bg_color }};
    --section-text-color: {{ section.settings.text_color }};
    --card-bg-color: {{ section.settings.card_bg_color }};
    --card-border-radius: {{ section.settings.card_border_radius }}px;
    --card-gap: {{ section.settings.card_gap }}px;
    --card-hover-lift: {{ section.settings.card_hover_lift }}px;

    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background-color: var(--section-bg-color);
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .premium-blog-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal_tablet }}px;
      padding-right: {{ section.settings.padding_horizontal_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-blog-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal }}px;
      padding-right: {{ section.settings.padding_horizontal }}px;
    }
  }

  .premium-blog__header {
    text-align: {{ section.settings.header_alignment }};
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  .premium-blog__title {
    font-size: clamp(
      {{ section.settings.title_font_size_mobile }}px,
      {{ section.settings.title_font_size_vw }}vw,
      {{ section.settings.title_font_size }}px
    );
    color: var(--section-text-color);
    font-family: var(--font-heading);
    text-transform: {{ section.settings.title_text_transform }};
    font-weight: {{ section.settings.title_font_weight }};
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
    line-height: {{ section.settings.title_line_height }};
    margin: 0 0 {{ section.settings.title_margin_bottom }}px 0;
  }

  .premium-blog__description {
    font-size: clamp({{ section.settings.description_font_size_mobile }}px, 2vw, {{ section.settings.description_font_size }}px);
    color: var(--section-text-color);
    opacity: {{ section.settings.description_opacity | divided_by: 100.0 }};
    line-height: {{ section.settings.description_line_height }};
    max-width: {{ section.settings.description_max_width }}px;
    margin: 0 auto;
  }

  .premium-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.card_gap_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .premium-blog__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
      gap: {{ section.settings.card_gap_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-blog__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: var(--card-gap);
    }
  }

  .premium-article-card {
    text-decoration: none;
    color: var(--section-text-color);
    display: flex;
    flex-direction: column;
    background-color: var(--card-bg-color);
    border-radius: var(--card-border-radius);
    overflow: hidden;
    transition:
      transform {{ section.settings.hover_transition_duration }}ms {{ section.settings.hover_easing }},
      box-shadow {{ section.settings.hover_transition_duration }}ms {{ section.settings.hover_easing }};
    {%- if section.settings.enable_card_shadow -%}
    box-shadow:
      {{ section.settings.card_shadow_x }}px
      {{ section.settings.card_shadow_y }}px
      {{ section.settings.card_shadow_blur }}px
      rgba(0, 0, 0, {{ section.settings.card_shadow_opacity | divided_by: 100.0 }});
    {%- endif -%}
  }

  .premium-article-card:hover {
    transform: translateY(calc(var(--card-hover-lift) * -1));
    {%- if section.settings.enable_hover_shadow -%}
    box-shadow:
      {{ section.settings.hover_shadow_x }}px
      {{ section.settings.hover_shadow_y }}px
      {{ section.settings.hover_shadow_blur }}px
      rgba(0, 0, 0, {{ section.settings.hover_shadow_opacity | divided_by: 100.0 }});
    {%- endif -%}
  }

  .premium-article-card__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
    background-color: {{ section.settings.image_bg_color }};
  }

  .premium-article-card__image {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    transition: transform {{ section.settings.image_hover_duration }}ms {{ section.settings.image_hover_easing }};
  }

  .premium-article-card:hover .premium-article-card__image {
    transform: scale({{ section.settings.image_hover_scale | divided_by: 100.0 }});
  }

  {%- if section.settings.show_category -%}
  .premium-article-card__category {
    position: absolute;
    top: {{ section.settings.category_position_top }}px;
    left: {{ section.settings.category_position_left }}px;
    background-color: {{ section.settings.category_bg_color }};
    color: {{ section.settings.category_text_color }};
    padding: {{ section.settings.category_padding_vertical }}px {{ section.settings.category_padding_horizontal }}px;
    font-size: {{ section.settings.category_font_size }}px;
    font-weight: {{ section.settings.category_font_weight }};
    text-transform: {{ section.settings.category_text_transform }};
    letter-spacing: {{ section.settings.category_letter_spacing }}px;
    border-radius: {{ section.settings.category_border_radius }}px;
    z-index: 2;
  }
  {%- endif -%}

  .premium-article-card__content {
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .premium-article-card__meta {
    font-size: {{ section.settings.meta_font_size }}px;
    opacity: {{ section.settings.meta_opacity | divided_by: 100.0 }};
    margin-bottom: {{ section.settings.meta_margin_bottom }}px;
    font-family: var(--font-body);
    text-transform: {{ section.settings.meta_text_transform }};
    letter-spacing: {{ section.settings.meta_letter_spacing }}px;
    font-weight: {{ section.settings.meta_font_weight }};
    display: flex;
    align-items: center;
    gap: {{ section.settings.meta_gap }}px;
  }

  .premium-article-card__meta-separator {
    opacity: 0.4;
  }

  .premium-article-card__title {
    font-size: clamp({{ section.settings.card_title_font_size_mobile }}px, 3vw, {{ section.settings.card_title_font_size }}px);
    line-height: {{ section.settings.card_title_line_height }};
    margin-bottom: {{ section.settings.card_title_margin_bottom }}px;
    font-family: var(--font-heading);
    font-weight: {{ section.settings.card_title_font_weight }};
    transition: opacity {{ section.settings.hover_transition_duration }}ms ease;
  }

  .premium-article-card:hover .premium-article-card__title {
    opacity: {{ section.settings.title_hover_opacity | divided_by: 100.0 }};
  }

  {%- if section.settings.show_excerpt -%}
  .premium-article-card__excerpt {
    font-size: {{ section.settings.excerpt_font_size }}px;
    line-height: {{ section.settings.excerpt_line_height }};
    opacity: {{ section.settings.excerpt_opacity | divided_by: 100.0 }};
    margin-bottom: {{ section.settings.excerpt_margin_bottom }}px;
    display: -webkit-box;
    -webkit-line-clamp: {{ section.settings.excerpt_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  {%- endif -%}

  .premium-article-card__read-more {
    font-size: {{ section.settings.read_more_font_size }}px;
    font-weight: {{ section.settings.read_more_font_weight }};
    text-decoration: {{ section.settings.read_more_decoration }};
    text-underline-offset: {{ section.settings.read_more_underline_offset }}px;
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.read_more_icon_gap }}px;
  }

  {%- if section.settings.show_read_more_arrow -%}
  .premium-article-card__read-more::after {
    content: '→';
    transition: transform {{ section.settings.hover_transition_duration }}ms ease;
  }

  .premium-article-card:hover .premium-article-card__read-more::after {
    transform: translateX({{ section.settings.arrow_hover_distance }}px);
  }
  {%- endif -%}

  /* Pagination */
  .premium-blog__pagination {
    margin-top: {{ section.settings.pagination_margin_top }}px;
    text-align: center;
  }

  /* Scroll Animation */
  .premium-blog-animate {
    opacity: 0;
    transform: translateY({{ section.settings.animation_distance }}px);
    transition:
      opacity {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }},
      transform {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }};
  }

  .premium-blog-animate.animated {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="premium-blog-{{ section.id }}">
  <div class="premium-blog__header premium-blog-animate">
    {%- if section.settings.show_title -%}
      <h1 class="premium-blog__title">
        {%- if section.settings.custom_title != blank -%}
          {{ section.settings.custom_title }}
        {%- else -%}
          {{ blog.title }}
        {%- endif -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="premium-blog__description">{{ section.settings.description }}</div>
    {%- endif -%}
  </div>

  {% paginate blog.articles by section.settings.articles_per_page %}
    <div class="premium-blog__grid">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="premium-article-card premium-blog-animate" style="transition-delay: {{ forloop.index0 | times: section.settings.animation_stagger }}ms;">
          <div class="premium-article-card__image-wrapper">
            {%- if article.image -%}
              <img
                src="{{ article.image | image_url: width: 800 }}"
                srcset="
                  {{ article.image | image_url: width: 400 }} 400w,
                  {{ article.image | image_url: width: 600 }} 600w,
                  {{ article.image | image_url: width: 800 }} 800w,
                  {{ article.image | image_url: width: 1000 }} 1000w
                "
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="{{ article.image.alt | escape }}"
                class="premium-article-card__image"
                loading="lazy"
                width="{{ article.image.width }}"
                height="{{ article.image.height }}"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'premium-article-card__image placeholder-svg' }}
            {%- endif -%}

            {%- if section.settings.show_category and article.tags.size > 0 -%}
              <span class="premium-article-card__category">{{ article.tags.first }}</span>
            {%- endif -%}
          </div>

          <div class="premium-article-card__content">
            <div class="premium-article-card__meta">
              {%- if section.settings.show_date -%}
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | time_tag: format: 'date' }}
                </time>
              {%- endif -%}

              {%- if section.settings.show_date and section.settings.show_read_time -%}
                <span class="premium-article-card__meta-separator">•</span>
              {%- endif -%}

              {%- if section.settings.show_read_time -%}
                {%- assign words = article.content | strip_html | split: ' ' | size -%}
                {%- assign read_time = words | divided_by: 200 -%}
                {%- if read_time == 0 -%}{%- assign read_time = 1 -%}{%- endif -%}
                <span>{{ read_time }} {{ section.settings.read_time_text | default: 'min read' }}</span>
              {%- endif -%}

              {%- if section.settings.show_author and (section.settings.show_date or section.settings.show_read_time) -%}
                <span class="premium-article-card__meta-separator">•</span>
              {%- endif -%}

              {%- if section.settings.show_author -%}
                <span>{{ article.author }}</span>
              {%- endif -%}
            </div>

            <h2 class="premium-article-card__title">{{ article.title }}</h2>

            {%- if section.settings.show_excerpt -%}
              <div class="premium-article-card__excerpt">
                {%- if article.excerpt != blank -%}
                  {{ article.excerpt | strip_html }}
                {%- else -%}
                  {{ article.content | strip_html | truncatewords: 25 }}
                {%- endif -%}
              </div>
            {%- endif -%}

            <span class="premium-article-card__read-more">
              {{ section.settings.read_more_text | default: 'Read More' | escape }}
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="premium-blog__pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {% endpaginate %}
</div>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const animateElements = document.querySelectorAll('.premium-blog-' + sectionId + ' .premium-blog-animate');

  if (!animateElements.length) return;

  const observerOptions = {
    threshold: {{ section.settings.animation_threshold | divided_by: 100.0 }},
    rootMargin: '{{ section.settings.animation_root_margin }}px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        {%- if section.settings.animation_once -%}
        observer.unobserve(entry.target);
        {%- endif -%}
      } else {
        {%- unless section.settings.animation_once -%}
        entry.target.classList.remove('animated');
        {%- endunless -%}
      }
    });
  }, observerOptions);

  animateElements.forEach(el => observer.observe(el));
})();
</script>


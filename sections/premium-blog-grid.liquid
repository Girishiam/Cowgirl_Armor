<style>
  .premium-blog-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .premium-blog__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .premium-blog__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: {{ section.settings.text_color }};
    font-family: var(--font-heading);
    text-transform: uppercase;
  }

  .premium-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 768px) {
    .premium-blog__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-blog__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  .premium-article-card {
    text-decoration: none;
    color: {{ section.settings.text_color }};
    display: flex;
    flex-direction: column;
  }

  .premium-article-card__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .premium-article-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .premium-article-card:hover .premium-article-card__image {
    transform: scale(1.05);
  }

  .premium-article-card__meta {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 0.75rem;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .premium-article-card__title {
    font-size: 1.5rem;
    line-height: 1.3;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
    transition: opacity 0.3s ease;
  }

  .premium-article-card:hover .premium-article-card__title {
    opacity: 0.7;
  }

  .premium-article-card__read-more {
    font-size: 0.9rem;
    font-weight: bold;
    text-decoration: underline;
    text-underline-offset: 4px;
    margin-top: auto;
  }

  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUpAnim {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="premium-blog-{{ section.id }}">
  <div class="premium-blog__header">
    <h1 class="premium-blog__title">{{ blog.title }}</h1>
  </div>

  {% paginate blog.articles by section.settings.articles_per_page %}
    <div class="premium-blog__grid">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="premium-article-card fade-up-anim" style="animation-delay: {{ forloop.index0 | times: 100 }}ms;">
          <div class="premium-article-card__image-wrapper">
            {%- if article.image -%}
              <img
                src="{{ article.image | image_url: width: 800 }}"
                alt="{{ article.image.alt | escape }}"
                class="premium-article-card__image"
                loading="lazy"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'premium-article-card__image placeholder-svg' }}
            {%- endif -%}
          </div>

          <div class="premium-article-card__meta">
            {%- if section.settings.show_date -%}
              <span>{{ article.published_at | time_tag: format: 'date' }}</span>
            {%- endif -%}
            {%- if section.settings.show_author and section.settings.show_date -%}
              <span style="margin: 0 0.5rem;">|</span>
            {%- endif -%}
            {%- if section.settings.show_author -%}
              <span>{{ article.author }}</span>
            {%- endif -%}
          </div>

          <h2 class="premium-article-card__title">{{ article.title }}</h2>

          <span class="premium-article-card__read-more">{{ section.settings.read_more_text | default: 'Read More' | escape }}</span>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div style="margin-top: 4rem; text-align: center;">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Premium Blog Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (Desktop)",
      "default": 2
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "3 / 2", "label": "Landscape (3:2)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" }
      ],
      "default": "3 / 2"
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read More Button Text",
      "default": "Read More"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show Author",
      "default": false
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 2,
      "max": 24,
      "step": 2,
      "label": "Articles per page",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ]
}
{% endschema %}

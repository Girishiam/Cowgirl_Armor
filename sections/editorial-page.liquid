<style>
  .ep-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* ── Hero ── */
  .ep-{{ section.id }} .ep-hero {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height }}px;
    overflow: hidden;
    margin-bottom: 0;
  }

  .ep-{{ section.id }} .ep-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.hero_focal }};
    display: block;
  }

  .ep-{{ section.id }} .ep-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 30%, rgba(0,0,0,{{ section.settings.hero_overlay_opacity | divided_by: 100.0 }}) 100%);
    z-index: 1;
  }

  .ep-{{ section.id }} .ep-hero-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 3rem clamp(1.5rem, 5vw, 4rem);
    text-align: {{ section.settings.hero_title_align }};
  }

  .ep-{{ section.id }} .ep-hero-title h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6vw, {{ section.settings.title_size }}px);
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.hero_title_color }};
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  /* No image fallback */
  .ep-{{ section.id }} .ep-hero--no-image {
    height: auto;
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px clamp(1.5rem, 5vw, 4rem) 3rem;
    text-align: {{ section.settings.hero_title_align }};
  }

  .ep-{{ section.id }} .ep-hero--no-image h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6vw, {{ section.settings.title_size }}px);
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.text_color }};
    line-height: 1.1;
    margin: 0;
  }

  /* ── Content Wrap ── */
  .ep-{{ section.id }} .ep-body {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px clamp(1.5rem, 5vw, 3rem) 0;
  }

  {%- if section.settings.image != blank -%}
  .ep-{{ section.id }} .ep-body {
    padding-top: 4rem;
  }
  {%- endif -%}

  /* ── Rich Text ── */
  .ep-{{ section.id }} .ep-rte {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.8vw, {{ section.settings.body_size }}px);
    line-height: {{ section.settings.body_line_height }};
    color: {{ section.settings.text_color }};
  }

  .ep-{{ section.id }} .ep-rte p {
    margin-bottom: 1.75rem;
    opacity: 0.88;
  }

  .ep-{{ section.id }} .ep-rte h2,
  .ep-{{ section.id }} .ep-rte h3,
  .ep-{{ section.id }} .ep-rte h4 {
    font-family: var(--font-heading);
    margin: 3rem 0 1.25rem;
    color: {{ section.settings.text_color }};
  }

  .ep-{{ section.id }} .ep-rte a {
    color: {{ section.settings.text_color }};
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .ep-{{ section.id }} .ep-rte img {
    max-width: 100%;
    height: auto;
    margin: 2.5rem 0;
    border-radius: {{ section.settings.image_radius }}px;
  }

  /* ── Pull Quote ── */
  .ep-{{ section.id }} .ep-pullquote {
    margin: 3rem 0;
    padding: 2.5rem clamp(1.5rem, 5vw, 3.5rem);
    border-left: {{ section.settings.quote_border_width }}px solid {{ section.settings.quote_border_color }};
    background-color: {{ section.settings.quote_bg }};
    border-radius: 0 {{ section.settings.image_radius }}px {{ section.settings.image_radius }}px 0;
  }

  .ep-{{ section.id }} .ep-pullquote blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 3vw, {{ section.settings.quote_size }}px);
    font-weight: {{ section.settings.quote_weight }};
    line-height: 1.4;
    color: {{ section.settings.quote_color }};
    margin: 0 0 1rem;
    font-style: normal;
    letter-spacing: -0.01em;
  }

  .ep-{{ section.id }} .ep-pullquote cite {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    font-style: normal;
  }

  /* ── Author Signature ── */
  .ep-{{ section.id }} .ep-author {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin: 3.5rem 0;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .ep-{{ section.id }} .ep-author-avatar {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(0,0,0,0.06);
  }

  .ep-{{ section.id }} .ep-author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ep-{{ section.id }} .ep-author-info {}

  .ep-{{ section.id }} .ep-author-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 0.25rem;
  }

  .ep-{{ section.id }} .ep-author-name {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin-bottom: 0.35rem;
  }

  .ep-{{ section.id }} .ep-author-bio {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.65;
  }

  /* ── Pagination ── */
  .ep-{{ section.id }} .ep-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2.5rem 0 0;
    margin-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .ep-{{ section.id }} .ep-pagination a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-heading);
    font-size: clamp(0.85rem, 2vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    transition: opacity 0.2s ease;
    max-width: 45%;
  }

  .ep-{{ section.id }} .ep-pagination a:hover {
    opacity: 0.5;
  }

  .ep-{{ section.id }} .ep-pagination a svg {
    flex-shrink: 0;
  }

  .ep-{{ section.id }} .ep-pagination .ep-prev { text-align: left; }
  .ep-{{ section.id }} .ep-pagination .ep-next { text-align: right; margin-left: auto; }

  .ep-{{ section.id }} .ep-pagination .ep-nav-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    opacity: 0.5;
    display: block;
    margin-bottom: 0.25rem;
  }

  .ep-{{ section.id }} .ep-pagination .ep-nav-title {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media screen and (max-width: 600px) {
    .ep-{{ section.id }} .ep-author { flex-direction: column; align-items: flex-start; }
    .ep-{{ section.id }} .ep-pagination a { max-width: 100%; }
  }
</style>

{%- assign show_hero = false -%}
{%- if section.settings.image != blank -%}
  {%- assign show_hero = true -%}
{%- endif -%}

<div class="ep-{{ section.id }}">

  {%- if show_hero -%}
    <div class="ep-hero">
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w,
                {{ section.settings.image | image_url: width: 1600 }} 1600w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
        loading="eager"
      >
      {%- if section.settings.hero_overlay_opacity > 0 -%}
        <div class="ep-hero-overlay"></div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <div class="ep-hero-title">
          <h1>{{ section.settings.title }}</h1>
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    {%- if section.settings.title != blank -%}
      <div class="ep-hero ep-hero--no-image">
        <h1>{{ section.settings.title }}</h1>
      </div>
    {%- endif -%}
  {%- endif -%}

  <div class="ep-body">

    {%- for block in section.blocks -%}

      {%- case block.type -%}

        {%- when 'rich_text' -%}
          {%- if block.settings.content != blank -%}
            <div class="ep-rte rte" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>
          {%- endif -%}

        {%- when 'pullquote' -%}
          {%- if block.settings.quote != blank -%}
            <div class="ep-pullquote" {{ block.shopify_attributes }}>
              <blockquote>{{ block.settings.quote }}</blockquote>
              {%- if block.settings.cite != blank -%}
                <cite>— {{ block.settings.cite }}</cite>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- when 'author' -%}
          <div class="ep-author" {{ block.shopify_attributes }}>
            {%- if block.settings.avatar != blank -%}
              <div class="ep-author-avatar">
                <img
                  src="{{ block.settings.avatar | image_url: width: 120 }}"
                  alt="{{ block.settings.name | escape }}"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
            <div class="ep-author-info">
              {%- if block.settings.label != blank -%}
                <p class="ep-author-label">{{ block.settings.label }}</p>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <p class="ep-author-name">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="ep-author-bio">{{ block.settings.bio }}</p>
              {%- endif -%}
            </div>
          </div>

        {%- when 'pagination' -%}
          {%- if block.settings.prev_label != blank or block.settings.next_label != blank -%}
            <div class="ep-pagination" {{ block.shopify_attributes }}>
              {%- if block.settings.prev_link != blank -%}
                <a href="{{ block.settings.prev_link }}" class="ep-prev">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>
                    <span class="ep-nav-label">Previous</span>
                    <span class="ep-nav-title">{{ block.settings.prev_label }}</span>
                  </span>
                </a>
              {%- endif -%}
              {%- if block.settings.next_link != blank -%}
                <a href="{{ block.settings.next_link }}" class="ep-next">
                  <span>
                    <span class="ep-nav-label">Next</span>
                    <span class="ep-nav-title">{{ block.settings.next_label }}</span>
                  </span>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

      {%- endcase -%}

    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Editorial Page",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "God meets you where you are."
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Hero Image Height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 560
    },
    {
      "type": "select",
      "id": "hero_focal",
      "label": "Image Focus",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center", "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "hero_overlay_opacity",
      "label": "Hero Overlay Darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "select",
      "id": "hero_title_align",
      "label": "Title Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "hero_title_color",
      "label": "Title Color (on image)",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size (max)",
      "min": 32,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "title_weight",
      "label": "Title Weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body Font Size (max)",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_line_height",
      "label": "Body Line Height",
      "min": 14,
      "max": 22,
      "step": 1,
      "default": 18,
      "info": "Divide by 10 — e.g. 18 = 1.8"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content Max Width",
      "min": 480,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 720
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image / Card Radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (no image)",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Pull Quote Style"
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Quote Font Size (max)",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "quote_weight",
      "label": "Quote Font Weight",
      "min": 300,
      "max": 800,
      "step": 100,
      "default": 500
    },
    {
      "type": "range",
      "id": "quote_border_width",
      "label": "Quote Border Width",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "color",
      "id": "quote_border_color",
      "label": "Quote Border Color",
      "default": "#8BA4AC"
    },
    {
      "type": "color",
      "id": "quote_bg",
      "label": "Quote Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Quote Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Author Style"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "label": "Avatar Size",
      "min": 40,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "rich_text",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Write your story here. Add as many rich text blocks as you need.</p>"
        }
      ]
    },
    {
      "type": "pullquote",
      "name": "Pull Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote Text",
          "default": "God meets you where you are."
        },
        {
          "type": "text",
          "id": "cite",
          "label": "Attribution",
          "default": "Romans 8:38-39"
        }
      ]
    },
    {
      "type": "author",
      "name": "Author Signature",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author Photo"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Written by"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Author Name",
          "default": "A Cowgirl, xoxo"
        },
        {
          "type": "text",
          "id": "bio",
          "label": "Short Bio / Tagline",
          "default": "Equipped with the Armor of God."
        }
      ]
    },
    {
      "type": "pagination",
      "name": "Prev / Next Links",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "prev_label",
          "label": "Previous Page Title"
        },
        {
          "type": "url",
          "id": "prev_link",
          "label": "Previous Page Link"
        },
        {
          "type": "text",
          "id": "next_label",
          "label": "Next Page Title"
        },
        {
          "type": "url",
          "id": "next_link",
          "label": "Next Page Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Page",
      "blocks": [
        { "type": "rich_text" },
        { "type": "pullquote" },
        { "type": "author" },
        { "type": "pagination" }
      ]
    }
  ]
}
{% endschema %}

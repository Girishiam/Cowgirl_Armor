{%- comment -%} Build gradient directly in Liquid — no CSS variable dependency {%- endcomment -%}
{%- assign grad_dir   = settings.gradient_direction | default: '135deg' -%}
{%- assign grad_col_1 = settings.gradient_color_1   | default: '#3A6FE8' -%}
{%- assign grad_col_2 = settings.gradient_color_2   | default: '#8B52D4' -%}
{%- assign grad_col_3 = settings.gradient_color_3   | default: '#CC72E8' -%}
{%- assign brand_gradient = 'linear-gradient(' | append: grad_dir | append: ', ' | append: grad_col_1 | append: ' 0%, ' | append: grad_col_2 | append: ' 55%, ' | append: grad_col_3 | append: ' 100%)' -%}

<style>
  /* ── Outer wrapper — full width background ── */
  .iwt-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: {{ brand_gradient }};
    {%- else -%}
      background-color: {{ section.settings.background_color }};
    {%- endif -%}
  }

  /* ── Inner — padding + color ── */
  .iwt-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  /* ── Grid ── */
  .iwt-section-{{ section.id }} .iwt-grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    max-width: {{ settings.page_width | default: 1400 }}px;
    margin: 0 auto;
  }
  @media screen and (min-width: 768px) {
    .iwt-section-{{ section.id }} .iwt-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Image column ── */
  .iwt-section-{{ section.id }} .iwt-media {
    position: relative;
    overflow: hidden;
    min-height: 420px;
  }
  @media screen and (min-width: 768px) {
    .iwt-section-{{ section.id }} .iwt-media { min-height: 560px; }
  }
  @media screen and (max-width: 767px) {
    .iwt-section-{{ section.id }} .iwt-media { min-height: 300px; }
  }

  .iwt-section-{{ section.id }} .iwt-media img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .iwt-section-{{ section.id }} .iwt-media:hover img { transform: scale(1.04); }

  .iwt-section-{{ section.id }} .iwt-media .placeholder-svg {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: #F5F5F7;
  }
  .iwt-section-{{ section.id }} .iwt-media .placeholder-svg svg {
    width: 60%; height: auto; opacity: 0.2;
  }

  /* ── Content column ── */
  .iwt-section-{{ section.id }} .iwt-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(2rem, 5vw, 5rem);
    text-align: {{ section.settings.content_alignment | replace: 'text-', '' }};

    {%- if section.settings.content_alignment == 'text-center' -%}
      align-items: center;
    {%- elsif section.settings.content_alignment == 'text-right' -%}
      align-items: flex-end;
    {%- else -%}
      align-items: flex-start;
    {%- endif -%}
  }
  @media screen and (max-width: 767px) {
    .iwt-section-{{ section.id }} .iwt-content { padding: 2rem 1.5rem; }
    .iwt-section-{{ section.id }} .iwt-text { max-width: 100%; }
  }

  /* ── Eyebrow ── */
  .iwt-section-{{ section.id }} .iwt-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    {%- if section.settings.use_gradient -%}
      color: rgba(255,255,255,0.75);
    {%- else -%}
      color: {{ grad_col_2 }};
    {%- endif -%}
  }

  /* Gradient underline on eyebrow when on white bg */
  {%- unless section.settings.use_gradient -%}
  .iwt-section-{{ section.id }} .iwt-eyebrow::after {
    content: '';
    display: block;
    height: 2px;
    width: 2.5rem;
    margin-top: 6px;
    border-radius: 99px;
    background: {{ brand_gradient }};
    {%- if section.settings.content_alignment == 'text-center' -%}
      margin-left: auto; margin-right: auto;
    {%- elsif section.settings.content_alignment == 'text-right' -%}
      margin-left: auto;
    {%- endif -%}
  }
  {%- endunless -%}

  /* ── Heading ── */
  .iwt-section-{{ section.id }} .iwt-heading {
    font-family: var(--font-heading-family, sans-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  /* ── Body text ── */
  .iwt-section-{{ section.id }} .iwt-text {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    line-height: 1.8;
    opacity: 0.75;
    margin: 0 0 2.25rem;
    max-width: 480px;
  }

  /* ── Button ── */
  .iwt-section-{{ section.id }} .iwt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-family: var(--font-heading-family, sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.85rem 2rem;
    border-radius: var(--buttons-radius, 4px);
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease;

    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.15);
      color: #FFFFFF;
      border: 1.5px solid rgba(255,255,255,0.5);
    {%- elsif section.settings.btn_use_gradient -%}
      background: {{ brand_gradient }};
      color: #FFFFFF;
      border: none;
      box-shadow: 0 4px 20px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.22);
    {%- else -%}
      background: transparent;
      color: {{ section.settings.text_color }};
      border: 1.5px solid {{ section.settings.text_color }};
    {%- endif -%}
  }

  /* Gradient button hover overlay */
  {%- if section.settings.btn_use_gradient and section.settings.use_gradient == false -%}
  .iwt-section-{{ section.id }} .iwt-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ brand_gradient }};
    filter: brightness(0.88);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .iwt-section-{{ section.id }} .iwt-btn span,
  .iwt-section-{{ section.id }} .iwt-btn svg { position: relative; z-index: 1; }
  {%- endif -%}

  .iwt-section-{{ section.id }} .iwt-btn:hover {
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.28);
      border-color: #FFFFFF;
      transform: translateX(3px);
    {%- elsif section.settings.btn_use_gradient -%}
      transform: translateX(3px);
      box-shadow: 0 8px 36px rgba({{ grad_col_2 | color_extract: 'red' }}, {{ grad_col_2 | color_extract: 'green' }}, {{ grad_col_2 | color_extract: 'blue' }}, 0.38);
    {%- else -%}
      background-color: {{ section.settings.text_color }};
      color: {{ section.settings.background_color }};
    {%- endif -%}
  }

  {%- if section.settings.btn_use_gradient and section.settings.use_gradient == false -%}
  .iwt-section-{{ section.id }} .iwt-btn:hover::after { opacity: 1; }
  {%- endif -%}

  .iwt-section-{{ section.id }} .iwt-btn svg { transition: transform 0.25s ease; }
  .iwt-section-{{ section.id }} .iwt-btn:hover svg { transform: translateX(4px); }
</style>

<div class="iwt-outer-{{ section.id }}">
  <div class="iwt-section-{{ section.id }}">
    <div class="iwt-grid">

      {%- if section.settings.layout == 'image_first' -%}
        <div class="iwt-media">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="
                {{ section.settings.image | image_url: width: 600 }}  600w,
                {{ section.settings.image | image_url: width: 900 }}  900w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 767px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="placeholder-svg">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="iwt-content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="iwt-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="iwt-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="iwt-text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
            class="iwt-btn"
          >
            {%- if section.settings.btn_use_gradient and section.settings.use_gradient == false -%}
              <span>{{ section.settings.button_label }}</span>
            {%- else -%}
              {{ section.settings.button_label }}
            {%- endif -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.layout == 'text_first' -%}
        <div class="iwt-media">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="
                {{ section.settings.image | image_url: width: 600 }}  600w,
                {{ section.settings.image | image_url: width: 900 }}  900w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 767px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="placeholder-svg">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_first", "label": "Image left, text right" },
        { "value": "text_first",  "label": "Text left, image right" }
      ],
      "default": "image_first"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "text-left",   "label": "Left"   },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right",  "label": "Right"  }
      ],
      "default": "text-left"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "info": "Small label above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": false,
      "info": "Off = clean white (recommended). On = gradient bg with white text."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color (if not gradient)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "checkbox",
      "id": "btn_use_gradient",
      "label": "Use brand gradient on button",
      "default": true,
      "info": "Ignored when section background is gradient."
    }
  ],
  "presets": [{ "name": "Image with Text" }]
}
{% endschema %}

{%- if section.settings.show_announcement -%}
  <style>
    .announcement-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      z-index: 101;
      -webkit-transform: translate3d(0, 0, 0);
      transform: translate3d(0, 0, 0);
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
    }
  </style>
  <div class="announcement-bar" role="region" aria-label="Announcement" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
    <div class="announcement-bar__content">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__link" style="color: {{ section.settings.text_color }};">
      {%- endif -%}
          <p class="announcement-bar__message">{{ section.settings.text }}</p>
      {%- if section.settings.link != blank -%}
        </a>
      {%- endif -%}
    </div>
    
    {%- if section.settings.show_close -%}
      <button type="button" class="announcement-bar__close" aria-label="Close announcement" style="color: {{ section.settings.text_color }};">
        <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 14 14" width="12" height="12">
          <path d="M13 13L1 1M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const banner = document.querySelector('.announcement-bar');
          const closeBtn = document.querySelector('.announcement-bar__close');
          if (banner && closeBtn) {
            closeBtn.addEventListener('click', function() {
              banner.style.display = 'none';
            });
          }
        });
      </script>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "✨ Due to overwhelming love and support..."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (Optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#7d7d7d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show Close Button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Header"
    }
  ]
}
{% endschema %}

{%- if section.settings.show_announcement -%}
  <style>
    .announcement-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      z-index: 101;
      -webkit-transform: translate3d(0, 0, 0);
      transform: translate3d(0, 0, 0);
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
    }
  </style>

  <div class="announcement-bar"
    role="region"
    aria-label="Announcement"
    {% if section.settings.use_gradient %}
      data-gradient="true"
    {% else %}
      style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
    {% endif %}>

    <div class="announcement-bar__content">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__link">
      {%- endif -%}
        <p class="announcement-bar__message">{{ section.settings.text }}</p>
      {%- if section.settings.link != blank -%}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_close -%}
      <button type="button" class="announcement-bar__close" aria-label="Close announcement">
        <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 14 14" width="12" height="12">
          <path d="M13 13L1 1M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "✨ Due to overwhelming love and support..."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (Optional)"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (if not gradient)",
      "default": "#3A6FE8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show Close Button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Header"
    }
  ]
}
{% endschema %}

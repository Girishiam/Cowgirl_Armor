<style>
  cart-notification {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 900;
    display: block;
    transform: translateY(20px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  cart-notification.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .cart-notif__panel {
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    width: min(340px, 90vw);
    box-shadow: 0 8px 32px rgba(139,82,212,0.35);
  }
  .cart-notif__img {
    width: 52px;
    height: 52px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    background: rgba(255,255,255,0.1);
  }
  .cart-notif__info { flex: 1; min-width: 0; }
  .cart-notif__added {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 3px;
  }
  .cart-notif__title {
    font-size: 0.88rem;
    font-weight: 600;
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cart-notif__price {
    font-size: 0.82rem;
    opacity: 0.7;
    margin: 0;
  }
  .cart-notif__view {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: inherit;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 7px 12px;
    border-radius: 6px;
    white-space: nowrap;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .cart-notif__view:hover { background: rgba(255,255,255,0.25); }

  @media (max-width: 480px) {
    cart-notification { bottom: 16px; right: 16px; left: 16px; }
  }
</style>

<cart-notification>
  <div class="cart-notif__panel"
    {% if section.settings.use_gradient %}
      data-gradient="true"
    {% else %}
      style="background: {{ section.settings.bg | default: '#8B52D4' }}; color: {{ section.settings.text | default: '#ffffff' }};"
    {% endif %}>
    <img src="" alt="" class="cart-notif__img" width="52" height="52">
    <div class="cart-notif__info">
      <p class="cart-notif__added">{{ section.settings.added_text | default: 'Added to cart' }}</p>
      <p class="cart-notif__title"></p>
      <p class="cart-notif__price"></p>
    </div>
    <a href="/cart" class="cart-notif__view">{{ section.settings.view_text | default: 'View cart' }}</a>
  </div>
</cart-notification>

{% schema %}
{
  "name": "Cart Notification",
  "limit": 1,
  "settings": [
    { "type": "text",     "id": "added_text",    "label": "Added Text",                      "default": "Added to cart" },
    { "type": "text",     "id": "view_text",     "label": "View Cart Text",                  "default": "View cart" },
    { "type": "checkbox", "id": "use_gradient",  "label": "Use brand gradient background",   "default": true },
    { "type": "color",    "id": "bg",            "label": "Background (if not gradient)",    "default": "#8B52D4" },
    { "type": "color",    "id": "text",          "label": "Text Color",                      "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "Cart Notification" }]
}
{% endschema %}

  ],
  "presets": [
    {
      "name": "FAQ 2-Column",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "When can I expect my order?" } },
        { "type": "faq_item", "settings": { "question": "I placed multiple items in one order. Will they ship together?" } },

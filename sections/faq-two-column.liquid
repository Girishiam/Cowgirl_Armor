    { "type": "text",   "id": "title",        "label": "Title",              "default": "Frequently Asked Questions Cowgirl Armor" },
    { "type": "select", "id": "title_align",  "label": "Title Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ], "default": "center"

    { "type": "range",    "id": "col_gap",         "label": "Column Gap",         "min": 20, "max": 120, "step": 4,  "unit": "px", "default": 60 },
    { "type": "range",    "id": "item_padding_v",  "label": "Item Vertical Padding","min": 12,"max": 40,  "step": 2,  "unit": "px", "default": 22 },
    { "type": "range",    "id": "divider_width",   "label": "Divider Thickness",  "min": 1,  "max": 3,   "step": 1,  "unit": "px", "default": 1 },

    {
      "type": "header",
      "content": "Question Style"
    },
    { "type": "range", "id": "question_min",    "label": "Question Size — Min", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 15 },
    { "type": "range", "id": "question_max",    "label": "Question Size — Max", "min": 14, "max": 28, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "question_weight", "label": "Question Weight",     "min": 300,"max": 700,"step": 100, "default": 400 },
    { "type": "range", "id": "question_lh",     "label": "Question Line Height","min": 110,"max": 180,"step": 5,  "unit": "%", "default": 135 },

    {
      "type": "header",
      "content": "Icon (+)"
    },
    { "type": "range", "id": "icon_size",      "label": "Icon Size",      "min": 12, "max": 28, "step": 2, "unit": "px", "default": 18 },
    { "type": "range", "id": "icon_thickness", "label": "Icon Thickness", "min": 1,  "max": 4,  "step": 1, "unit": "px", "default": 1 },

    {
      "type": "header",
      "content": "Answer Style"
    },
    { "type": "range", "id": "answer_min",    "label": "Answer Size — Min", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "answer_max",    "label": "Answer Size — Max", "min": 13, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "answer_weight", "label": "Answer Weight",     "min": 300,"max": 500,"step": 100, "default": 400 },
    { "type": "range", "id": "answer_lh",     "label": "Answer Line Height","min": 140,"max": 210,"step": 5, "unit": "%", "default": 170 },


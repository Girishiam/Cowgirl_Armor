<style>
  .faq2-{{ section.id }} {
    position: relative;
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_desktop }}px 0 {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  /* ── Watermark ── */
  .faq2-{{ section.id }} .faq2__watermark {
    position: absolute;
    bottom: {{ section.settings.watermark_bottom }}px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: var(--font-heading-family, serif);
    font-size: clamp(80px, {{ section.settings.watermark_size }}vw, 260px);
    font-weight: {{ section.settings.watermark_weight }};
    letter-spacing: {{ section.settings.watermark_ls | divided_by: 100.0 }}em;
    color: {{ section.settings.watermark_color }};
    opacity: {{ section.settings.watermark_opacity | divided_by: 100.0 }};
    pointer-events: none;
    user-select: none;
    text-transform: uppercase;
    line-height: 1;
    z-index: 0;
  }

  /* ── Background image ── */
  .faq2-{{ section.id }} .faq2__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.bg_img_fit }};
    object-position: {{ section.settings.bg_img_position }};
    opacity: {{ section.settings.bg_img_opacity | divided_by: 100.0 }};
    pointer-events: none;
    z-index: 0;
  }

  /* ── Container ── */
  .faq2-{{ section.id }} .faq2__container {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.padding_h_desktop }}px;
  }

  /* ── Header ── */
  .faq2-{{ section.id }} .faq2__header {
    text-align: {{ section.settings.title_align }};
    margin-bottom: {{ section.settings.header_gap }}px;
  }
  .faq2-{{ section.id }} .faq2__eyebrow {
    font-family: var(--font-body-family, sans-serif);
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 12px;
  }
  .faq2-{{ section.id }} .faq2__title {
    font-family: var(--font-heading-family, serif);
    font-size: clamp({{ section.settings.title_min }}px, 3.5vw, {{ section.settings.title_max }}px);
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.15;
    letter-spacing: {{ section.settings.title_ls | divided_by: 100.0 }}em;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* ── 2-col grid ── */
  .faq2-{{ section.id }} .faq2__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 {{ section.settings.col_gap }}px;
  }

  /* ── Column ── */
  .faq2-{{ section.id }} .faq2__col {
    display: flex;
    flex-direction: column;
  }

  /* ── FAQ Item ── */
  .faq2-{{ section.id }} .faq2__item {
    border-top: {{ section.settings.divider_width }}px solid {{ section.settings.divider_color }};
  }
  .faq2-{{ section.id }} .faq2__item:last-child {
    border-bottom: {{ section.settings.divider_width }}px solid {{ section.settings.divider_color }};
  }

  .faq2-{{ section.id }} .faq2__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: {{ section.settings.item_padding_v }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: {{ section.settings.text_color }};
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp({{ section.settings.question_min }}px, 1.4vw, {{ section.settings.question_max }}px);
    font-weight: {{ section.settings.question_weight }};
    line-height: {{ section.settings.question_lh | divided_by: 100.0 }};
    transition: opacity 0.2s;
  }
  .faq2-{{ section.id }} .faq2__trigger:hover { opacity: 0.65; }

  /* +/× icon */
  .faq2-{{ section.id }} .faq2__icon {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    position: relative;
    color: {{ section.settings.icon_color }};
  }
  .faq2-{{ section.id }} .faq2__icon::before,
  .faq2-{{ section.id }} .faq2__icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s;
  }
  /* Horizontal bar */
  .faq2-{{ section.id }} .faq2__icon::before {
    width: 100%;
    height: {{ section.settings.icon_thickness }}px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }
  /* Vertical bar */
  .faq2-{{ section.id }} .faq2__icon::after {
    width: {{ section.settings.icon_thickness }}px;
    height: 100%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }
  /* When open — vertical bar rotates to make × */
  .faq2-{{ section.id }} .faq2__item.is-open .faq2__icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }
  .faq2-{{ section.id }} .faq2__item.is-open .faq2__icon::before {
    transform: translateY(-50%) rotate(45deg);
  }

  /* Answer */
  .faq2-{{ section.id }} .faq2__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.3s ease,
                padding-bottom 0.3s ease;
    opacity: 0;
    padding-bottom: 0;
  }
  .faq2-{{ section.id }} .faq2__item.is-open .faq2__body {
    max-height: 600px;
    opacity: 1;
    padding-bottom: {{ section.settings.item_padding_v }}px;
  }
  .faq2-{{ section.id }} .faq2__answer {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp({{ section.settings.answer_min }}px, 1.2vw, {{ section.settings.answer_max }}px);
    line-height: {{ section.settings.answer_lh | divided_by: 100.0 }};
    color: {{ section.settings.answer_color }};
    font-weight: {{ section.settings.answer_weight }};
  }
  .faq2-{{ section.id }} .faq2__answer p { margin: 0 0 0.75em; }
  .faq2-{{ section.id }} .faq2__answer p:last-child { margin: 0; }
  .faq2-{{ section.id }} .faq2__answer strong { font-weight: 700; color: {{ section.settings.text_color }}; }
  .faq2-{{ section.id }} .faq2__answer a { color: {{ section.settings.accent_color }}; text-decoration: underline; text-underline-offset: 3px; }
  .faq2-{{ section.id }} .faq2__answer ul,
  .faq2-{{ section.id }} .faq2__answer ol { padding-left: 1.3em; margin: 0 0 0.75em; }
  .faq2-{{ section.id }} .faq2__answer li { margin-bottom: 0.4em; }

  /* ── Responsive ── */
  @media screen and (max-width: 767px) {
    .faq2-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .faq2-{{ section.id }} .faq2__container {
      padding: 0 {{ section.settings.padding_h_mobile }}px;
    }
    .faq2-{{ section.id }} .faq2__grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .faq2-{{ section.id }} .faq2__watermark {
      font-size: clamp(40px, 20vw, 100px);
    }
    .faq2-{{ section.id }} .faq2__bg-img { display: none; }
  }
</style>

<section class="faq2-{{ section.id }}">

  {%- comment -%} ── Background image ── {%- endcomment -%}
  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 1600 }}"
      srcset="{{ section.settings.bg_image | image_url: width: 800 }} 800w,
              {{ section.settings.bg_image | image_url: width: 1200 }} 1200w,
              {{ section.settings.bg_image | image_url: width: 1600 }} 1600w"
      sizes="100vw"
      alt=""
      class="faq2__bg-img"
      aria-hidden="true"
      loading="lazy"
    >
  {%- endif -%}

  {%- comment -%} ── Watermark ── {%- endcomment -%}
  {%- if section.settings.watermark_text != blank -%}
    <div class="faq2__watermark" aria-hidden="true">{{ section.settings.watermark_text }}</div>
  {%- endif -%}

  <div class="faq2__container">

    {%- comment -%} ── Header ── {%- endcomment -%}
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <div class="faq2__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="faq2__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="faq2__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Split blocks into 2 columns ── {%- endcomment -%}
    {%- assign faq_blocks = section.blocks -%}
    {%- assign total = faq_blocks.size -%}
    {%- assign col1_count = total | divided_by: 2 | ceil -%}

    <div class="faq2__grid">

      {%- comment -%} Left column {%- endcomment -%}
      <div class="faq2__col">
        {%- for block in faq_blocks -%}
          {%- if forloop.index <= col1_count -%}
            <div class="faq2__item" {{ block.shopify_attributes }}>
              <button class="faq2__trigger" aria-expanded="false" aria-controls="faq2-body-{{ block.id }}">
                <span>{{ block.settings.question }}</span>
                <span class="faq2__icon" aria-hidden="true"></span>
              </button>
              <div class="faq2__body" id="faq2-body-{{ block.id }}" role="region">
                {%- if block.settings.answer != blank -%}
                  <div class="faq2__answer">{{ block.settings.answer }}</div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Right column {%- endcomment -%}
      <div class="faq2__col">
        {%- for block in faq_blocks -%}
          {%- if forloop.index > col1_count -%}
            <div class="faq2__item" {{ block.shopify_attributes }}>
              <button class="faq2__trigger" aria-expanded="false" aria-controls="faq2-body-{{ block.id }}">
                <span>{{ block.settings.question }}</span>
                <span class="faq2__icon" aria-hidden="true"></span>
              </button>
              <div class="faq2__body" id="faq2-body-{{ block.id }}" role="region">
                {%- if block.settings.answer != blank -%}
                  <div class="faq2__answer">{{ block.settings.answer }}</div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  var section = document.querySelector('.faq2-{{ section.id }}');
  if (!section) return;

  var items = section.querySelectorAll('.faq2__item');

  items.forEach(function(item) {
    var trigger = item.querySelector('.faq2__trigger');
    var body    = item.querySelector('.faq2__body');
    if (!trigger || !body) return;

    trigger.addEventListener('click', function() {
      var isOpen = item.classList.contains('is-open');

      {%- if section.settings.close_others -%}
      items.forEach(function(other) {
        if (other !== item && other.classList.contains('is-open')) {
          other.classList.remove('is-open');
          var t = other.querySelector('.faq2__trigger');
          if (t) t.setAttribute('aria-expanded', 'false');
        }
      });
      {%- endif -%}

      item.classList.toggle('is-open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQ 2-Column",
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "When can I expect my order?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "bg_color",      "label": "Background",       "default": "#E2E2E2" },
    { "type": "color", "id": "text_color",    "label": "Text Color",       "default": "#1A1A1A" },
    { "type": "color", "id": "accent_color",  "label": "Accent Color",     "default": "#8BA4AC" },
    { "type": "color", "id": "answer_color",  "label": "Answer Text Color","default": "#444444" },
    { "type": "color", "id": "divider_color", "label": "Divider Color",    "default": "#cccccc" },

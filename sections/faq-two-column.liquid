    { "type": "range", "id": "title_max",    "label": "Title Size — Max", "min": 24, "max": 64, "step": 2, "unit": "px", "default": 38 },
    { "type": "range", "id": "title_weight", "label": "Title Weight",     "min": 300,"max": 900,"step": 100, "default": 600 },

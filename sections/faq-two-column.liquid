    { "type": "range", "id": "watermark_ls",      "label": "Watermark Letter Spacing","min": -5,"max": 20,"step": 1, "default": 2, "info": "Divide by 100" },
    { "type": "range", "id": "watermark_bottom",  "label": "Watermark Bottom Position","min": -100,"max": 100,"step": 4, "unit": "px", "default": -20 },

    {
      "type": "header",
      "content": "Background Image"

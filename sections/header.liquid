<style>
  .site-header {
    position: fixed;
    top: var(--announcement-height, 0px);
    left: 0;
    right: 0;
    width: 100%;
    z-index: 100;
    -webkit-transform: translate3d(0, 0, 0);
    transform: translate3d(0, 0, 0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  body {
    padding-top: var(--nav-total-height, 80px);
  }
</style>

<header
  class="site-header{% if section.settings.enable_sticky %} header-sticky{% endif %}"
  id="shopify-section-header"
  data-sticky="{{ section.settings.enable_sticky }}"
  data-scroll-threshold="{{ section.settings.sticky_threshold }}"
  style="--header-bg: {{ section.settings.header_bg }};
         --header-text: {{ section.settings.header_text_color }};
         --header-shadow: {{ section.settings.header_shadow }};
         background-color: var(--header-bg);
         color: var(--header-text);
         padding-top: {{ section.settings.padding_top }}px;
         padding-bottom: {{ section.settings.padding_bottom }}px;
         border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_bottom_color }};">

  <div class="header__left">
    <button class="mobile-menu-btn"
            aria-expanded="false"
            aria-controls="mobile-drawer"
            aria-label="Open navigation"
            style="color: var(--header-text);">
      <svg
        aria-hidden="true"
        focusable="false"
        role="presentation"
        class="icon icon-hamburger"
        viewBox="0 0 16 16"
        width="{{ section.settings.hamburger_size }}"
        height="{{ section.settings.hamburger_size }}"
      >
        <path class="hamburger-line-1" d="M1 3.5h14" stroke="currentColor" stroke-width="{{ section.settings.hamburger_thickness }}" stroke-linecap="round"/>
        <path class="hamburger-line-2" d="M1 8h14" stroke="currentColor" stroke-width="{{ section.settings.hamburger_thickness }}" stroke-linecap="round"/>
        <path class="hamburger-line-3" d="M1 12.5h14" stroke="currentColor" stroke-width="{{ section.settings.hamburger_thickness }}" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="logo-link">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: settings.logo_width }}"
            srcset="{{ settings.logo | image_url: width: settings.logo_width }} 1x,
                    {{ settings.logo | image_url: width: settings.logo_width | times: 2 }} 2x"
            alt="{{ shop.name }}"
            class="logo-image"
            style="max-width: {{ settings.logo_width }}px; height: auto;"
            width="{{ settings.logo_width }}"
            height="auto"
            loading="eager"
          >
        {%- else -%}
          <span class="logo-text"
                style="font-size: clamp({{ section.settings.logo_text_min }}px, 3vw, {{ section.settings.logo_text_max }}px);
                       font-weight: {{ section.settings.logo_font_weight }};
                       letter-spacing: {{ section.settings.logo_letter_spacing }}px;">
            {{ shop.name }}
          </span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <nav class="site-nav desktop-only" aria-label="Main navigation">
    {%- if section.settings.menu != blank -%}
      <ul class="site-nav__list" style="gap: clamp({{ section.settings.nav_gap_min }}rem, 2vw, {{ section.settings.nav_gap_max }}rem);">
        {%- for link in linklists[section.settings.menu].links -%}
          {%- if link.links != blank -%}
            <li class="site-nav__item site-nav__item--has-dropdown">
              <a href="{{ link.url }}"
                 class="site-nav__link {% if link.active or request.path == link.url %}site-nav__link--active{% endif %}"
                 style="font-size: {{ section.settings.nav_font_size }}px;
                        font-weight: {{ section.settings.nav_font_weight }};">
                {{ link.title }}
                <svg class="icon-caret"
                     width="{{ section.settings.caret_size }}"
                     height="{{ section.settings.caret_size | divided_by: 2 }}"
                     viewBox="0 0 10 6"
                     fill="none"
                     aria-hidden="true">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <ul class="site-nav__dropdown"
                  style="background-color: {{ section.settings.dropdown_bg }};
                         border-radius: {{ section.settings.dropdown_radius }}px;
                         box-shadow: {{ section.settings.dropdown_shadow }};">
                {%- for childlink in link.links -%}
                  <li>
                    <a
                      href="{{ childlink.url }}"
                      class="site-nav__dropdown-link {% if childlink.active %}site-nav__dropdown-link--active{% endif %}"
                      style="font-size: {{ section.settings.dropdown_font_size }}px;"
                    >
                      {{ childlink.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </li>
          {%- else -%}
            <li class="site-nav__item">
              <a
                href="{{ link.url }}"
                class="site-nav__link {% if link.active or request.path == link.url %}site-nav__link--active{% endif %}"
                {% if link.active or request.path == link.url %}
                  aria-current="page"
                {% endif %}
                style="font-size: {{ section.settings.nav_font_size }}px;
                       font-weight: {{ section.settings.nav_font_weight }};"
              >
                {{ link.title }}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </nav>

  <div class="header__right">
    {%- if section.settings.show_search -%}
      <button class="header__icon header__search-toggle desktop-only"
              aria-label="Search"
              data-search-toggle
              style="color: var(--header-text);">
        <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </button>
    {%- endif -%}

    <div class="header__socials desktop-only" style="gap: {{ section.settings.social_gap }}px;">
      {%- if section.settings.social_facebook_link != blank -%}
        <a
          href="{{ section.settings.social_facebook_link }}"
          class="header__icon"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          style="color: var(--header-text);">
          <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
            <path d="M12 2.04c-5.5 0-10 4.48-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.67c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10.05 10.05 0 008.44-9.9c0-5.54-4.5-10.02-10-10.02z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_instagram_link != blank -%}
        <a
          href="{{ section.settings.social_instagram_link }}"
          class="header__icon"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          style="color: var(--header-text);">
          <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
            <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07zm0-2.16C8.74 0 8.33.01 7.05.07 5.77.13 4.89.33 4.14.62c-.78.3-1.44.73-2 1.29-.56.56-.99 1.22-1.29 2-.29.75-.49 1.63-.55 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.16.55 2.91.3.78.73 1.44 1.29 2 .56.56 1.22.99 2 1.29.75.29 1.63.49 2.91.55 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.28-.06 2.16-.26 2.91-.55.78-.3 1.44-.73 2-1.29.56-.56.99-1.22 1.29-2 .29-.75.49-1.63.55-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.16-.55-2.91-.3-.78-.73-1.44-1.29-2-.56-.56-1.22-.99-2-1.29-.75-.29-1.63-.49-2.91-.55C15.67.01 15.26 0 12 0zm0 5.84c-3.4 0-6.16 2.76-6.16 6.16s2.76 6.16 6.16 6.16 6.16-2.76 6.16-6.16-2.76-6.16-6.16-6.16zm0 10.16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm3.97-10.45c-.53 0-.96.43-.96.96s.43.96.96.96.96-.43.96-.96-.43-.96-.96-.96z"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <a href="{{ routes.cart_url }}"
       class="header__icon header__cart"
       aria-label="Cart ({{ cart.item_count }} items)"
       style="color: var(--header-text);">
      <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
        <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
      </svg>
      <span class="cart-count"
            style="background-color: {{ section.settings.cart_badge_bg }};
                   color: {{ section.settings.cart_badge_text }};
                   font-size: {{ section.settings.cart_badge_size }}px;"
            {% if cart.item_count == 0 %}hidden{% endif %}>
        {{ cart.item_count }}
      </span>
    </a>

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link }}"
        class="btn header__btn desktop-only"
        style="background-color: {{ section.settings.button_bg_color }};
               color: {{ section.settings.button_text_color }};
               border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
               border-radius: {{ section.settings.button_border_radius }}px;
               padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
               font-size: {{ section.settings.button_font_size }}px;
               font-weight: {{ section.settings.button_font_weight }};"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</header>

{%- if section.settings.show_search -%}
<div class="search-overlay" id="search-overlay" hidden>
  <div class="search-overlay__content">
    <button class="search-overlay__close" aria-label="Close search">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input
        type="search"
        name="q"
        placeholder="{{ section.settings.search_placeholder }}"
        class="search-input"
        autocomplete="off"
        aria-label="Search"
      >
      <button type="submit" class="search-submit" aria-label="Submit search">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </button>
    </form>
  </div>
</div>
{%- endif -%}

<div class="mobile-drawer{% if section.settings.drawer_animation == 'slide' %} drawer-slide{% elsif section.settings.drawer_animation == 'fade' %} drawer-fade{% endif %}"
     id="mobile-drawer"
     style="background-color: {{ section.settings.drawer_bg }};
            color: {{ section.settings.drawer_text_color }};">
  <div class="mobile-drawer__header">
    {%- if section.settings.drawer_logo != blank -%}
      <img src="{{ section.settings.drawer_logo | image_url: width: section.settings.drawer_logo_width }}"
           alt="{{ shop.name }}"
           style="max-width: {{ section.settings.drawer_logo_width }}px;">
    {%- endif -%}
  </div>

  <nav class="mobile-drawer__nav">
    {%- if section.settings.menu != blank -%}
      <ul style="list-style: none; padding: 0; width: 100%;">
        {%- for link in linklists[section.settings.menu].links -%}
          <li style="margin-bottom: {{ section.settings.drawer_link_spacing }}px; text-align: center;">
            <a
              href="{{ link.url }}"
              style="font-size: clamp({{ section.settings.drawer_font_min }}px, 6vw, {{ section.settings.drawer_font_max }}px);
                     text-decoration: none;
                     color: inherit;
                     display: block;
                     font-family: var(--font-heading);
                     font-weight: {{ section.settings.drawer_font_weight }};
                     padding: {{ section.settings.drawer_link_padding }}px;
                     transition: opacity {{ section.settings.drawer_hover_speed }}s ease;"
              onmouseover="this.style.opacity='{{ section.settings.drawer_hover_opacity | divided_by: 100.0 }}'"
              onmouseout="this.style.opacity='1'"
            >
              {{ link.title }}
            </a>

            {%- if link.links != blank -%}
              <ul style="list-style: none; padding-top: 0.5rem; margin-bottom: 1rem;">
                {%- for childlink in link.links -%}
                  <li style="margin-bottom: 0.5rem;">
                    <a
                      href="{{ childlink.url }}"
                      style="font-size: {{ section.settings.drawer_subfont_size }}px;
                             text-decoration: none;
                             color: inherit;
                             opacity: 0.8;
                             font-family: var(--font-body);"
                    >
                      {{ childlink.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </nav>

  {%- if section.settings.button_label != blank -%}
    <div style="margin-top: 2rem; text-align: center;">
      <a
        href="{{ section.settings.button_link }}"
        class="btn"
        style="background-color: {{ section.settings.button_bg_color }};
               color: {{ section.settings.button_text_color }};
               border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
               border-radius: {{ section.settings.button_border_radius }}px;
               padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
               font-size: {{ section.settings.button_font_size }}px;"
      >
        {{ section.settings.button_label }}
      </a>
    </div>
  {%- endif -%}

  {%- if section.settings.show_drawer_socials -%}
    <div class="drawer-socials" style="margin-top: 2rem; display: flex; justify-content: center; gap: {{ section.settings.social_gap }}px;">
      {%- if section.settings.social_facebook_link != blank -%}
        <a href="{{ section.settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="{{ section.settings.drawer_social_size }}" height="{{ section.settings.drawer_social_size }}" fill="currentColor">
            <path d="M12 2.04c-5.5 0-10 4.48-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.67c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10.05 10.05 0 008.44-9.9c0-5.54-4.5-10.02-10-10.02z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_instagram_link != blank -%}
        <a href="{{ section.settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="{{ section.settings.drawer_social_size }}" height="{{ section.settings.drawer_social_size }}" fill="currentColor">
            <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07zm0-2.16C8.74 0 8.33.01 7.05.07 5.77.13 4.89.33 4.14.62c-.78.3-1.44.73-2 1.29-.56.56-.99 1.22-1.29 2-.29.75-.49 1.63-.55 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.16.55 2.91.3.78.73 1.44 1.29 2 .56.56 1.22.99 2 1.29.75.29 1.63.49 2.91.55 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.28-.06 2.16-.26 2.91-.55.78-.3 1.44-.73 2-1.29.56-.56.99-1.22 1.29-2 .29-.75.49-1.63.55-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.16-.55-2.91-.3-.78-.73-1.44-1.29-2-.56-.56-1.22-.99-2-1.29-.75-.29-1.63-.49-2.91-.55C15.67.01 15.26 0 12 0zm0 5.84c-3.4 0-6.16 2.76-6.16 6.16s2.76 6.16 6.16 6.16 6.16-2.76 6.16-6.16-2.76-6.16-6.16-6.16zm0 10.16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm3.97-10.45c-.53 0-.96.43-.96.96s.43.96.96.96.96-.43.96-.96-.43-.96-.96-.96z"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<style>
  /* Cart badge */
  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    line-height: 1;
    padding: 2px 4px;
  }

  .header__cart {
    position: relative;
  }

  /* Search overlay */
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, {{ section.settings.search_overlay_opacity | divided_by: 100.0 }});
    backdrop-filter: blur({{ section.settings.search_overlay_blur }}px);
    z-index: 1000;
    display: flex;
    align-items: {{ section.settings.search_position }};
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity {{ section.settings.search_transition }}s ease, visibility {{ section.settings.search_transition }}s ease;
  }

  .search-overlay[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .search-overlay__content {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.search_max_width }}px;
  }

  .search-overlay__close {
    position: absolute;
    top: -50px;
    right: 0;
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 10px;
    transition: opacity 0.3s ease;
  }

  .search-overlay__close:hover {
    opacity: 0.7;
  }

  .search-form {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-input {
    width: 100%;
    padding: {{ section.settings.search_input_padding }}px;
    font-size: {{ section.settings.search_input_size }}px;
    border: {{ section.settings.search_input_border }}px solid {{ section.settings.search_input_border_color }};
    border-radius: {{ section.settings.search_input_radius }}px;
    background: {{ section.settings.search_input_bg }};
    color: {{ section.settings.search_input_text }};
  }

  .search-submit {
    position: absolute;
    right: 10px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    color: {{ section.settings.search_input_text }};
  }

</style>

<script>
  // Position header below announcement bar and set body padding
  (function() {
    const header = document.querySelector('.site-header');
    const announcement = document.querySelector('.announcement-bar');

    function setHeights() {
      const announcementH = announcement ? announcement.offsetHeight : 0;
      const headerH = header ? header.offsetHeight : 0;
      document.documentElement.style.setProperty('--announcement-height', announcementH + 'px');
      document.documentElement.style.setProperty('--nav-total-height', (announcementH + headerH) + 'px');
    }

    setHeights();
    window.addEventListener('resize', setHeights, { passive: true });
  })();

  // Mobile drawer
  (function() {
    const btn = document.querySelector('.mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    if (!btn || !drawer) return;

    btn.addEventListener('click', function() {
      const isExpanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !isExpanded);
      drawer.classList.toggle('mobile-drawer--active');
      document.body.style.overflow = isExpanded ? '' : 'hidden';
    });

    // Close on escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && drawer.classList.contains('mobile-drawer--active')) {
        btn.click();
      }
    });
  })();

  // Search overlay
  {%- if section.settings.show_search -%}
  (function() {
    const toggleBtn = document.querySelector('[data-search-toggle]');
    const overlay = document.getElementById('search-overlay');
    const closeBtn = document.querySelector('.search-overlay__close');
    const input = document.querySelector('.search-input');

    if (!toggleBtn || !overlay) return;

    function openSearch() {
      overlay.removeAttribute('hidden');
      setTimeout(() => {
        overlay.setAttribute('aria-hidden', 'false');
        input.focus();
      }, 10);
    }

    function closeSearch() {
      overlay.setAttribute('aria-hidden', 'true');
      setTimeout(() => {
        overlay.setAttribute('hidden', '');
      }, {{ section.settings.search_transition | times: 1000 }});
    }

    toggleBtn.addEventListener('click', openSearch);
    closeBtn.addEventListener('click', closeSearch);

    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) closeSearch();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay.getAttribute('aria-hidden') === 'false') {
        closeSearch();
      }
    });
  })();
  {%- endif -%}

  // Cart count update
  (function() {
    const cartCount = document.querySelector('.cart-count');
    if (!cartCount) return;

    // Listen for cart updates
    document.addEventListener('cart:updated', function(e) {
      const count = e.detail.item_count || 0;
      cartCount.textContent = count;
      if (count === 0) {
        cartCount.setAttribute('hidden', '');
      } else {
        cartCount.removeAttribute('hidden');
      }
    });
  })();
</script>


<style>
  /* ─── Reset & Base ─────────────────────────────────────── */
  .site-header *,
  .site-header *::before,
  .site-header *::after { box-sizing: border-box; }

  /* ─── Fixed Header Shell ────────────────────────────────── */
  .site-header {
    position: fixed;
    top: var(--announcement-height, 0px);
    left: 0;
    right: 0;
    z-index: 200;
    width: 100%;
    background-color: {{ section.settings.header_bg }};
    color: {{ section.settings.header_text_color }};
    border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_bottom_color }};
    box-shadow: {{ section.settings.header_shadow }};
    transition: background-color {{ section.settings.sticky_transition }}s ease,
                box-shadow {{ section.settings.sticky_transition }}s ease,
                padding {{ section.settings.sticky_transition }}s ease;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  body {
    padding-top: var(--nav-total-height, 80px);
  }

  /* ─── Inner wrapper ─────────────────────────────────────── */
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_h }}px {{ section.settings.padding_bottom }}px;
    gap: 1rem;
    transition: padding {{ section.settings.sticky_transition }}s ease;
  }

  /* ─── Sticky state ──────────────────────────────────────── */
  .site-header.is-sticky {
    background-color: {{ section.settings.sticky_bg }};
    box-shadow: {{ section.settings.sticky_shadow }};
  }
  .site-header.is-sticky .header__inner {
    padding-top: {{ section.settings.sticky_padding }}px;
    padding-bottom: {{ section.settings.sticky_padding }}px;
  }

  /* ─── Logo ──────────────────────────────────────────────── */
  .header__logo { flex-shrink: 0; line-height: 1; }
  .logo-link { text-decoration: none; color: inherit; display: flex; align-items: center; }
  .logo-image {
    display: block;
    height: auto;
    max-height: 60px;
    width: auto;
    max-width: {{ section.settings.logo_width }}px;
    object-fit: contain;
    transition: max-width {{ section.settings.sticky_transition }}s ease;
  }
  .site-header.is-sticky .logo-image { max-height: 44px; }
  .logo-text {
    font-size: clamp({{ section.settings.logo_text_min }}px, 2.5vw, {{ section.settings.logo_text_max }}px);
    font-weight: {{ section.settings.logo_font_weight }};
    letter-spacing: {{ section.settings.logo_letter_spacing }}px;
    white-space: nowrap;
    color: inherit;
  }

  /* ─── Desktop Nav ───────────────────────────────────────── */
  .site-nav { display: flex; align-items: center; flex: 1; justify-content: center; }
  .site-nav__list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0; padding: 0;
    gap: clamp(0.6rem, 1.5vw, {{ section.settings.nav_gap_max }}rem);
    flex-wrap: nowrap;
  }
  .site-nav__item { position: relative; }

  .site-nav__link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: {{ section.settings.header_text_color }};
    font-size: clamp(12px, 1.1vw, {{ section.settings.nav_font_size }}px);
    font-weight: {{ section.settings.nav_font_weight }};
    white-space: nowrap;
    padding: 8px 2px 14px;
    margin-bottom: -8px;
    position: relative;
    transition: opacity 0.2s ease;
  }
  .site-nav__link::after {
    content: '';
    position: absolute;
    bottom: 8px; left: 0; right: 0;
    height: 1.5px;
    background: currentColor;
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: left;
  }
  .site-nav__item:not(.site-nav__item--has-dropdown) .site-nav__link:hover::after,
  .site-nav__item:not(.site-nav__item--has-dropdown) .site-nav__link--active::after { transform: scaleX(1); }
  .site-nav__item--has-dropdown .site-nav__link::after { display: none !important; }
  .site-nav__link:hover { opacity: 0.75; }

  /* ─── Dropdown ──────────────────────────────────────────── */
  .site-nav__dropdown {
    display: block;
    position: absolute;
    top: calc(100% - 2px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 180px;
    list-style: none;
    margin: 0; padding: 8px 0;
    background-color: {{ section.settings.dropdown_bg }};
    border-radius: {{ section.settings.dropdown_radius }}px;
    box-shadow: {{ section.settings.dropdown_shadow }};
    border: 1px solid rgba(0,0,0,0.08);
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
    z-index: 300;
  }
  .site-nav__dropdown::before {
    content: '';
    position: absolute;
    top: -7px; left: 50%;
    transform: translateX(-50%);
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-bottom: 7px solid {{ section.settings.dropdown_bg }};
  }
  .site-nav__item--has-dropdown:hover .site-nav__dropdown,
  .site-nav__item--has-dropdown:focus-within .site-nav__dropdown,
  .site-nav__item--has-dropdown.is-open .site-nav__dropdown {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .site-nav__dropdown li { display: block; }
  .site-nav__dropdown-link {
    display: block;
    padding: 10px 20px;
    text-decoration: none;
    color: {{ section.settings.header_text_color }};
    font-size: {{ section.settings.dropdown_font_size }}px;
    white-space: nowrap;
    transition: background-color 0.15s ease, padding-left 0.15s ease;
  }
  .site-nav__dropdown-link:hover { background-color: rgba(0,0,0,0.05); padding-left: 26px; }
  .site-nav__dropdown-link--active { font-weight: 600; }

  /* ─── Right Controls ────────────────────────────────────── */
  .header__right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: {{ section.settings.icon_gap }}px;
    flex: 1;
  }
  .header__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.header_text_color }};
    text-decoration: none;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
    position: relative;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
    width: calc({{ section.settings.icon_size }}px + 8px);
    height: calc({{ section.settings.icon_size }}px + 8px);
  }
  .header__icon:hover { opacity: 0.7; }
  .header__icon svg {
    display: block;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    flex-shrink: 0;
  }

  /* Cart badge */
  .header__cart { position: relative; }
  .cart-count {
    position: absolute;
    top: -7px; right: -7px;
    min-width: 17px; height: 17px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; line-height: 1;
    padding: 2px 4px;
    background-color: {{ section.settings.cart_badge_bg }};
    color: {{ section.settings.cart_badge_text }};
    font-size: {{ section.settings.cart_badge_size }}px;
    pointer-events: none;
  }

  /* CTA Button */
  .header__btn {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    font-size: clamp(11px, 1vw, {{ section.settings.button_font_size }}px);
    font-weight: {{ section.settings.button_font_weight }};
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }
  .header__btn:hover {
    background: linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%);
    color: #FFFFFF;
    border-color: transparent;
  }

  /* Social icons */
  .header__socials {
    display: flex;
    align-items: center;
    gap: {{ section.settings.social_gap }}px;
    flex-shrink: 0;
  }

  /* ─── Hamburger ─────────────────────────────────────────── */
  .mobile-menu-btn {
    display: none;
    background: none; border: none; cursor: pointer;
    padding: 6px;
    color: {{ section.settings.header_text_color }};
    flex-shrink: 0;
  }

  /* ─── Responsive ────────────────────────────────────────── */
  @media screen and (max-width: 1023px) {
    .site-nav, .header__socials, .header__btn, .header__search-toggle { display: none !important; }
    .mobile-menu-btn { display: inline-flex; }
  }
  @media screen and (min-width: 1024px) {
    .mobile-menu-btn { display: none !important; }
  }

  /* ─── Mobile Drawer ─────────────────────────────────────── */
  .mobile-drawer {
    position: fixed;
    top: 0; left: 0;
    width: min(320px, 85vw);
    height: 100%;
    z-index: 500;
    overflow-y: auto;
    background-color: {{ section.settings.drawer_bg }};
    color: {{ section.settings.drawer_text_color }};
    display: flex;
    flex-direction: column;
    padding: 2rem 1.5rem;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-drawer.mobile-drawer--active { transform: translateX(0); }

  .mobile-drawer-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 499; opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-drawer-overlay.active { opacity: 1; pointer-events: auto; }

  .mobile-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .mobile-drawer__close {
    background: none; border: none; cursor: pointer;
    color: inherit; padding: 4px; margin-left: auto;
    opacity: 0.7; transition: opacity 0.2s;
  }
  .mobile-drawer__close:hover { opacity: 1; }

  .mobile-drawer__nav ul { list-style: none; padding: 0; margin: 0; width: 100%; }
  .mobile-drawer__nav > ul > li { border-bottom: 1px solid rgba(0,0,0,0.08); }
  .mobile-drawer__nav > ul > li:last-child { border-bottom: none; }

  .drawer-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 4px;
    text-decoration: none;
    color: inherit;
    font-size: clamp({{ section.settings.drawer_font_min }}px, 5vw, {{ section.settings.drawer_font_max }}px);
    font-weight: {{ section.settings.drawer_font_weight }};
    background: none; border: none; cursor: pointer; text-align: left;
    transition: opacity 0.2s;
  }
  .drawer-link:hover { opacity: 0.65; }

  .drawer-accordion__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 4px;
    font-size: clamp({{ section.settings.drawer_font_min }}px, 5vw, {{ section.settings.drawer_font_max }}px);
    font-weight: {{ section.settings.drawer_font_weight }};
    background: none; border: none; color: inherit; cursor: pointer; text-align: left;
  }
  .drawer-accordion__icon { transition: transform 0.25s ease; flex-shrink: 0; }
  .drawer-accordion__toggle[aria-expanded="true"] .drawer-accordion__icon { transform: rotate(180deg); }
  .drawer-accordion__body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .drawer-accordion__body.open { max-height: 500px; }

  .drawer-sublink {
    display: block;
    padding: 10px 12px;
    text-decoration: none;
    color: inherit;
    font-size: {{ section.settings.drawer_subfont_size }}px;
    opacity: 0.8;
    transition: opacity 0.2s, padding-left 0.2s;
  }
  .drawer-sublink:hover { opacity: 1; padding-left: 20px; }

  .mobile-drawer__footer {
    margin-top: auto;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
  }
  .drawer-socials { display: flex; gap: {{ section.settings.social_gap }}px; align-items: center; }
  .drawer-socials a { color: inherit; opacity: 0.8; transition: opacity 0.2s; }
  .drawer-socials a:hover { opacity: 1; }

  /* ─── Search Overlay ────────────────────────────────────── */
  .search-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,{{ section.settings.search_overlay_opacity | divided_by: 100.0 }});
    backdrop-filter: blur({{ section.settings.search_overlay_blur }}px);
    z-index: 600;
    display: flex;
    align-items: {{ section.settings.search_position }};
    justify-content: center;
    padding: 4rem 2rem 2rem;
    opacity: 0; visibility: hidden;
    transition: opacity {{ section.settings.search_transition }}s ease, visibility {{ section.settings.search_transition }}s ease;
  }
  .search-overlay.is-open { opacity: 1; visibility: visible; }
  .search-overlay__content { position: relative; width: 100%; max-width: {{ section.settings.search_max_width }}px; }
  .search-overlay__close {
    position: absolute; top: -3rem; right: 0;
    background: none; border: none; color: white; cursor: pointer;
    padding: 8px; opacity: 0.8; transition: opacity 0.2s;
  }
  .search-overlay__close:hover { opacity: 1; }
  .search-form { position: relative; display: flex; align-items: center; }
  .search-input {
    width: 100%;
    padding: {{ section.settings.search_input_padding }}px;
    padding-right: 56px;
    font-size: {{ section.settings.search_input_size }}px;
    border: {{ section.settings.search_input_border }}px solid {{ section.settings.search_input_border_color }};
    border-radius: {{ section.settings.search_input_radius }}px;
    background: {{ section.settings.search_input_bg }};
    color: {{ section.settings.search_input_text }};
    outline: none;
  }
  .search-submit {
    position: absolute; right: 12px;
    background: none; border: none; cursor: pointer;
    padding: 8px;
    color: {{ section.settings.search_input_text }};
  }
</style>

<div class="mobile-drawer-overlay" id="drawer-overlay"></div>

<header
  class="site-header{% if section.settings.enable_sticky %} header-sticky{% endif %}"
  id="site-header"
  data-sticky="{{ section.settings.enable_sticky }}"
  data-scroll-threshold="{{ section.settings.sticky_threshold }}"
>
  <div class="header__inner">

    <!-- Left: Hamburger + Logo -->
    <div style="display:flex;align-items:center;gap:0.75rem;flex:1;">
      <button class="mobile-menu-btn"
              aria-expanded="false"
              aria-controls="mobile-drawer"
              aria-label="Open navigation">
        <svg aria-hidden="true" viewBox="0 0 24 24"
             width="{{ section.settings.hamburger_size }}"
             height="{{ section.settings.hamburger_size }}"
             fill="none" stroke="currentColor"
             stroke-width="{{ section.settings.hamburger_thickness }}"
             stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
      </button>

      <div class="header__logo">
        <a href="{{ routes.root_url }}" class="logo-link">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 400 }}"
              srcset="{{ section.settings.logo | image_url: width: 200 }} 200w,
                      {{ section.settings.logo | image_url: width: 400 }} 400w"
              sizes="{{ section.settings.logo_width }}px"
              alt="{{ shop.name }}"
              class="logo-image"
              width="{{ section.settings.logo_width }}"
              height="auto"
              loading="eager"
            >
          {%- else -%}
            <span class="logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>

    <!-- Center: Desktop Nav -->
    {%- if section.settings.menu != blank -%}
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="site-nav__list">
          {%- for link in linklists[section.settings.menu].links -%}
            {%- if link.links != blank -%}
              <li class="site-nav__item site-nav__item--has-dropdown">
                <a href="{{ link.url }}"
                   class="site-nav__link{% if link.active %} site-nav__link--active{% endif %}"
                   aria-haspopup="true"
                   aria-expanded="false">
                  {{ link.title }}
                </a>
                <ul class="site-nav__dropdown" role="menu">
                  {%- for childlink in link.links -%}
                    <li role="none">
                      <a href="{{ childlink.url }}"
                         class="site-nav__dropdown-link{% if childlink.active %} site-nav__dropdown-link--active{% endif %}"
                         role="menuitem">
                        {{ childlink.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </li>
            {%- else -%}
              <li class="site-nav__item">
                <a href="{{ link.url }}"
                   class="site-nav__link{% if link.active %} site-nav__link--active{% endif %}"
                   {% if link.active %}aria-current="page"{% endif %}>
                  {{ link.title }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <!-- Right: Icons + CTA -->
    <div class="header__right" style="flex:1;justify-content:flex-end;">
      {%- if section.settings.show_search -%}
        <button class="header__icon header__search-toggle"
                aria-label="Search"
                data-search-toggle>
          <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
          </svg>
        </button>
      {%- endif -%}

      <div class="header__socials">
        {%- if section.settings.social_facebook_link != blank -%}
          <a href="{{ section.settings.social_facebook_link }}" class="header__icon" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_instagram_link != blank -%}
          <a href="{{ section.settings.social_instagram_link }}" class="header__icon" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
              <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07zm0-2.16C8.74 0 8.33.01 7.05.07 5.77.13 4.89.33 4.14.62c-.78.3-1.44.73-2 1.29-.56.56-.99 1.22-1.29 2-.29.75-.49 1.63-.55 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.16.55 2.91.3.78.73 1.44 1.29 2 .56.56 1.22.99 2 1.29.75.29 1.63.49 2.91.55 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.28-.06 2.16-.26 2.91-.55.78-.3 1.44-.73 2-1.29.56-.56.99-1.22 1.29-2 .29-.75.49-1.63.55-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.16-.55-2.91-.3-.78-.73-1.44-1.29-2-.56-.56-1.22-.99-2-1.29-.75-.29-1.63-.49-2.91-.55C15.67.01 15.26 0 12 0zm0 5.84c-3.4 0-6.16 2.76-6.16 6.16s2.76 6.16 6.16 6.16 6.16-2.76 6.16-6.16-2.76-6.16-6.16-6.16zm0 10.16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm3.97-10.45c-.53 0-.96.43-.96.96s.43.96.96.96.96-.43.96-.96-.43-.96-.96-.96z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <a href="{{ routes.cart_url }}"
         class="header__icon header__cart"
         aria-label="Cart ({{ cart.item_count }} items)">
        <svg viewBox="0 0 24 24" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" fill="currentColor">
          <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
        </svg>
        <span class="cart-count"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="header__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</header>

<!-- ─── Search Overlay ──────────────────────────────────── -->
{%- if section.settings.show_search -%}
<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-overlay__content">
    <button class="search-overlay__close" aria-label="Close search">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="search" name="q" placeholder="{{ section.settings.search_placeholder }}"
             class="search-input" autocomplete="off" aria-label="Search">
      <button type="submit" class="search-submit" aria-label="Submit search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </button>
    </form>
  </div>
</div>
{%- endif -%}

<!-- ─── Mobile Drawer ───────────────────────────────────── -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <div class="mobile-drawer__header">
    {%- if section.settings.drawer_logo != blank -%}
      <img src="{{ section.settings.drawer_logo | image_url: width: section.settings.drawer_logo_width }}"
           alt="{{ shop.name }}"
           style="max-width:{{ section.settings.drawer_logo_width }}px;height:auto;">
    {%- elsif section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: width: section.settings.drawer_logo_width }}"
           alt="{{ shop.name }}"
           style="max-width:{{ section.settings.drawer_logo_width }}px;height:auto;">
    {%- else -%}
      <span style="font-weight:700;font-size:1.1rem;">{{ shop.name }}</span>
    {%- endif -%}
    <button class="mobile-drawer__close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <nav class="mobile-drawer__nav" aria-label="Mobile navigation">
    {%- if section.settings.menu != blank -%}
      <ul>
        {%- for link in linklists[section.settings.menu].links -%}
          <li>
            {%- if link.links != blank -%}
              <button class="drawer-accordion__toggle" aria-expanded="false">
                {{ link.title }}
                <svg class="drawer-accordion__icon" width="16" height="16" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="drawer-accordion__body">
                <ul style="list-style:none;padding:0 0 0.5rem 1rem;margin:0;">
                  {%- for childlink in link.links -%}
                    <li><a href="{{ childlink.url }}" class="drawer-sublink">{{ childlink.title }}</a></li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="drawer-link">{{ link.title }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </nav>

  <div class="mobile-drawer__footer">
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}"
         style="display:inline-flex;align-items:center;text-decoration:none;
                background:linear-gradient(135deg,#3A6FE8 0%,#8B52D4 55%,#CC72E8 100%);
                color:#FFFFFF;
                border:none;
                border-radius:{{ section.settings.button_border_radius }}px;
                padding:{{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
                font-size:{{ section.settings.button_font_size }}px;
                font-weight:{{ section.settings.button_font_weight }};">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

    {%- if section.settings.show_drawer_socials -%}
      <div class="drawer-socials">
        {%- if section.settings.social_facebook_link != blank -%}
          <a href="{{ section.settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="{{ section.settings.drawer_social_size }}" height="{{ section.settings.drawer_social_size }}" fill="currentColor">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_instagram_link != blank -%}
          <a href="{{ section.settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="{{ section.settings.drawer_social_size }}" height="{{ section.settings.drawer_social_size }}" fill="currentColor">
              <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07zm0-2.16C8.74 0 8.33.01 7.05.07 5.77.13 4.89.33 4.14.62c-.78.3-1.44.73-2 1.29-.56.56-.99 1.22-1.29 2-.29.75-.49 1.63-.55 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.16.55 2.91.3.78.73 1.44 1.29 2 .56.56 1.22.99 2 1.29.75.29 1.63.49 2.91.55 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.28-.06 2.16-.26 2.91-.55.78-.3 1.44-.73 2-1.29.56-.56.99-1.22 1.29-2 .29-.75.49-1.63.55-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.16-.55-2.91-.3-.78-.73-1.44-1.29-2-.56-.56-1.22-.99-2-1.29-.75-.29-1.63-.49-2.91-.55C15.67.01 15.26 0 12 0zm0 5.84c-3.4 0-6.16 2.76-6.16 6.16s2.76 6.16 6.16 6.16 6.16-2.76 6.16-6.16-2.76-6.16-6.16-6.16zm0 10.16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm3.97-10.45c-.53 0-.96.43-.96.96s.43.96.96.96.96-.43.96-.96-.43-.96-.96-.96z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

  var header       = document.getElementById('site-header');
  var announcement = document.querySelector('.announcement-bar');

  function setHeights() {
    var aH = announcement ? announcement.offsetHeight : 0;
    var hH = header ? header.offsetHeight : 0;
    document.documentElement.style.setProperty('--announcement-height', aH + 'px');
    document.documentElement.style.setProperty('--nav-total-height', (aH + hH) + 'px');
  }
  setHeights();
  window.addEventListener('resize', setHeights, { passive: true });
  window.addEventListener('load', setHeights);

  {%- if section.settings.enable_sticky -%}
  window.addEventListener('scroll', function() {
    if (!header) return;
    if (window.scrollY > {{ section.settings.sticky_threshold }}) {
      header.classList.add('is-sticky');
    } else {
      header.classList.remove('is-sticky');
    }
  }, { passive: true });
  {%- endif -%}

  var dropdownItems = document.querySelectorAll('.site-nav__item--has-dropdown');
  dropdownItems.forEach(function(item) {
    var leaveTimer = null;
    item.addEventListener('mouseenter', function() {
      clearTimeout(leaveTimer);
      item.classList.add('is-open');
      var link = item.querySelector('.site-nav__link');
      if (link) link.setAttribute('aria-expanded', 'true');
    });
    item.addEventListener('mouseleave', function() {
      leaveTimer = setTimeout(function() {
        item.classList.remove('is-open');
        var link = item.querySelector('.site-nav__link');
        if (link) link.setAttribute('aria-expanded', 'false');
      }, 100);
    });
    var parentLink = item.querySelector('.site-nav__link');
    if (parentLink) {
      parentLink.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          var isOpen = item.classList.contains('is-open');
          item.classList.toggle('is-open', !isOpen);
          parentLink.setAttribute('aria-expanded', String(!isOpen));
        }
        if (e.key === 'Escape') {
          item.classList.remove('is-open');
          parentLink.setAttribute('aria-expanded', 'false');
          parentLink.focus();
        }
      });
    }
    item.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        item.classList.remove('is-open');
        var link = item.querySelector('.site-nav__link');
        if (link) { link.setAttribute('aria-expanded', 'false'); link.focus(); }
      }
    });
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.site-nav__item--has-dropdown')) {
      dropdownItems.forEach(function(item) {
        item.classList.remove('is-open');
        var link = item.querySelector('.site-nav__link');
        if (link) link.setAttribute('aria-expanded', 'false');
      });
    }
  });

  var menuBtn  = document.querySelector('.mobile-menu-btn');
  var drawer   = document.getElementById('mobile-drawer');
  var closeBtn = document.querySelector('.mobile-drawer__close');
  var overlay  = document.getElementById('drawer-overlay');

  function openDrawer() {
    if (!drawer) return;
    drawer.classList.add('mobile-drawer--active');
    drawer.setAttribute('aria-hidden', 'false');
    if (overlay) overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    if (menuBtn) menuBtn.setAttribute('aria-expanded', 'true');
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('mobile-drawer--active');
    drawer.setAttribute('aria-hidden', 'true');
    if (overlay) overlay.classList.remove('active');
    document.body.style.overflow = '';
    if (menuBtn) menuBtn.setAttribute('aria-expanded', 'false');
  }

  if (menuBtn)  menuBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay)  overlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer && drawer.classList.contains('mobile-drawer--active')) closeDrawer();
  });

  if (drawer) {
    drawer.querySelectorAll('.drawer-accordion__toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var body = this.nextElementSibling;
        this.setAttribute('aria-expanded', String(!expanded));
        if (body) body.classList.toggle('open', !expanded);
      });
    });
  }

  {%- if section.settings.show_search -%}
  var searchToggle  = document.querySelector('[data-search-toggle]');
  var searchOverlay = document.getElementById('search-overlay');
  var searchClose   = document.querySelector('.search-overlay__close');
  var searchInput   = document.querySelector('.search-input');

  function openSearch() {
    if (!searchOverlay) return;
    searchOverlay.classList.add('is-open');
    searchOverlay.setAttribute('aria-hidden', 'false');
    setTimeout(function() { if (searchInput) searchInput.focus(); }, 50);
  }
  function closeSearch() {
    if (!searchOverlay) return;
    searchOverlay.classList.remove('is-open');
    searchOverlay.setAttribute('aria-hidden', 'true');
  }

  if (searchToggle)  searchToggle.addEventListener('click', openSearch);
  if (searchClose)   searchClose.addEventListener('click', closeSearch);
  if (searchOverlay) searchOverlay.addEventListener('click', function(e) {
    if (e.target === searchOverlay) closeSearch();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && searchOverlay && searchOverlay.classList.contains('is-open')) closeSearch();
  });
  {%- endif -%}

  var cartCount = document.querySelector('.cart-count');
  if (cartCount) {
    document.addEventListener('cart:updated', function(e) {
      var n = (e.detail && e.detail.item_count) || 0;
      cartCount.textContent = n;
      if (n === 0) cartCount.setAttribute('hidden', '');
      else cartCount.removeAttribute('hidden');
    });
  }

});
</script>

{% schema %}
{
  "name": "Header (Enhanced)",
  "settings": [
    { "type": "header", "content": "Header Appearance" },
    { "type": "color",  "id": "header_bg",            "label": "Background Color",      "default": "#F8F6F4" },
    { "type": "color",  "id": "header_text_color",    "label": "Text Color",            "default": "#1A1A1A" },
    { "type": "text",   "id": "header_shadow",         "label": "Header Shadow",         "default": "none" },
    { "type": "range",  "id": "padding_top",           "label": "Top Padding",           "min": 8,  "max": 40, "step": 2,   "unit": "px",  "default": 16 },
    { "type": "range",  "id": "padding_bottom",        "label": "Bottom Padding",        "min": 8,  "max": 40, "step": 2,   "unit": "px",  "default": 16 },
    { "type": "range",  "id": "padding_h",             "label": "Side Padding",          "min": 0,  "max": 60, "step": 4,   "unit": "px",  "default": 12 },
    { "type": "range",  "id": "border_bottom_width",   "label": "Border Bottom Width",   "min": 0,  "max": 5,  "step": 1,   "unit": "px",  "default": 0 },
    { "type": "color",  "id": "border_bottom_color",   "label": "Border Bottom Color",   "default": "#0000001a" },

    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo",            "label": "Logo Image" },
    { "type": "range",  "id": "logo_width",            "label": "Logo Max Width",        "min": 60, "max": 300, "step": 10, "unit": "px",  "default": 160 },
    { "type": "range",  "id": "logo_text_min",         "label": "Logo Text Min Size",    "min": 14, "max": 28,  "step": 1,  "unit": "px",  "default": 18 },
    { "type": "range",  "id": "logo_text_max",         "label": "Logo Text Max Size",    "min": 20, "max": 48,  "step": 2,  "unit": "px",  "default": 26 },
    { "type": "range",  "id": "logo_font_weight",      "label": "Logo Font Weight",      "min": 300, "max": 900, "step": 100, "default": 700 },
    { "type": "range",  "id": "logo_letter_spacing",   "label": "Logo Letter Spacing",   "min": 0,  "max": 5,   "step": 1,  "unit": "px",  "default": 1 },

    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu",               "label": "Menu",                  "default": "main-menu" },
    { "type": "range",  "id": "nav_font_size",          "label": "Nav Font Size",         "min": 11, "max": 18,  "step": 1,  "unit": "px",  "default": 14 },
    { "type": "range",  "id": "nav_font_weight",        "label": "Nav Font Weight",       "min": 300, "max": 700, "step": 100, "default": 400 },
    { "type": "range",  "id": "nav_gap_max",            "label": "Nav Gap Max",           "min": 1,  "max": 4,   "step": 1,  "unit": "rem", "default": 2 },
    { "type": "range",  "id": "caret_size",             "label": "Dropdown Caret Size",   "min": 8,  "max": 14,  "step": 1,  "unit": "px",  "default": 10 },

    { "type": "header", "content": "Dropdown" },
    { "type": "color",  "id": "dropdown_bg",            "label": "Dropdown Background",   "default": "#F8F6F4" },
    { "type": "range",  "id": "dropdown_font_size",     "label": "Dropdown Font Size",    "min": 12, "max": 18,  "step": 1,  "unit": "px",  "default": 14 },
    { "type": "range",  "id": "dropdown_radius",        "label": "Dropdown Border Radius","min": 0,  "max": 20,  "step": 2,  "unit": "px",  "default": 6 },
    { "type": "text",   "id": "dropdown_shadow",        "label": "Dropdown Shadow",       "default": "0 8px 30px rgba(0,0,0,0.12)" },

    { "type": "header", "content": "Icons & Cart" },
    { "type": "range",  "id": "icon_size",              "label": "Icon Size",             "min": 18, "max": 30,  "step": 2,  "unit": "px",  "default": 22 },
    { "type": "range",  "id": "icon_gap",               "label": "Header Icons Gap",      "min": 4,  "max": 32,  "step": 4,  "unit": "px",  "default": 8 },
    { "type": "range",  "id": "social_gap",             "label": "Social Icons Gap",      "min": 4,  "max": 24,  "step": 4,  "unit": "px",  "default": 8 },
    { "type": "color",  "id": "cart_badge_bg",          "label": "Cart Badge Background", "default": "#3A6FE8" },
    { "type": "color",  "id": "cart_badge_text",        "label": "Cart Badge Text",       "default": "#FFFFFF" },
    { "type": "range",  "id": "cart_badge_size",        "label": "Cart Badge Font Size",  "min": 9,  "max": 14,  "step": 1,  "unit": "px",  "default": 10 },

    { "type": "header", "content": "Search" },
    { "type": "checkbox", "id": "show_search",          "label": "Show Search",           "default": false },
    { "type": "text",   "id": "search_placeholder",     "label": "Search Placeholder",    "default": "Search..." },
    { "type": "range",  "id": "search_overlay_opacity", "label": "Overlay Opacity",       "min": 50, "max": 95,  "step": 5,  "unit": "%",   "default": 85 },
    { "type": "range",  "id": "search_overlay_blur",    "label": "Overlay Blur",          "min": 0,  "max": 20,  "step": 2,  "unit": "px",  "default": 10 },
    { "type": "select", "id": "search_position",        "label": "Search Position",
      "options": [
        { "value": "flex-start", "label": "Top"    },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Bottom" }
      ], "default": "flex-start"
    },
    { "type": "range",  "id": "search_max_width",       "label": "Search Max Width",      "min": 400, "max": 800, "step": 50, "unit": "px",  "default": 600 },
    { "type": "range",  "id": "search_input_padding",   "label": "Input Padding",         "min": 10, "max": 28,  "step": 2,  "unit": "px",  "default": 18 },
    { "type": "range",  "id": "search_input_size",      "label": "Input Font Size",       "min": 16, "max": 32,  "step": 2,  "unit": "px",  "default": 22 },
    { "type": "range",  "id": "search_input_border",    "label": "Input Border Width",    "min": 0,  "max": 3,   "step": 1,  "unit": "px",  "default": 1 },
    { "type": "color",  "id": "search_input_border_color", "label": "Input Border Color", "default": "#CCCCCC" },
    { "type": "range",  "id": "search_input_radius",    "label": "Input Border Radius",   "min": 0,  "max": 50,  "step": 2,  "unit": "px",  "default": 8 },
    { "type": "color",  "id": "search_input_bg",        "label": "Input Background",      "default": "#FFFFFF" },
    { "type": "color",  "id": "search_input_text",      "label": "Input Text Color",      "default": "#1A1A1A" },
    { "type": "text",   "id": "search_transition",      "label": "Transition Speed (s)",  "default": "0.3", "info": "In seconds, e.g. 0.3" },

    { "type": "header", "content": "Sticky Header" },
    { "type": "checkbox", "id": "enable_sticky",        "label": "Enable Sticky Header",  "default": true },
    { "type": "range",  "id": "sticky_threshold",       "label": "Scroll Threshold",      "min": 0,  "max": 200, "step": 10, "unit": "px",  "default": 50 },
    { "type": "color",  "id": "sticky_bg",              "label": "Sticky Background",     "default": "#F8F6F4f2" },
    { "type": "text",   "id": "sticky_shadow",          "label": "Sticky Shadow",         "default": "0 4px 20px rgba(58,111,232,0.10)" },
    { "type": "range",  "id": "sticky_padding",         "label": "Sticky Padding",        "min": 6,  "max": 24,  "step": 1,  "unit": "px",  "default": 10 },
    { "type": "text",   "id": "sticky_transition",      "label": "Sticky Transition (s)", "default": "0.3", "info": "In seconds, e.g. 0.3" },

    { "type": "header", "content": "Mobile Menu" },
    { "type": "range",  "id": "hamburger_size",         "label": "Hamburger Size",        "min": 20, "max": 32,  "step": 2,  "unit": "px",  "default": 24 },
    { "type": "range",  "id": "hamburger_thickness",    "label": "Hamburger Thickness",   "min": 1,  "max": 3,   "step": 0.5, "default": 2 },
    { "type": "color",  "id": "drawer_bg",              "label": "Drawer Background",     "default": "#F8F6F4" },
    { "type": "color",  "id": "drawer_text_color",      "label": "Drawer Text Color",     "default": "#1A1A1A" },
    { "type": "image_picker", "id": "drawer_logo",      "label": "Drawer Logo (optional)" },
    { "type": "range",  "id": "drawer_logo_width",      "label": "Drawer Logo Width",     "min": 60, "max": 220, "step": 10, "unit": "px",  "default": 120 },
    { "type": "range",  "id": "drawer_font_min",        "label": "Link Font Min",         "min": 16, "max": 28,  "step": 2,  "unit": "px",  "default": 20 },
    { "type": "range",  "id": "drawer_font_max",        "label": "Link Font Max",         "min": 24, "max": 40,  "step": 2,  "unit": "px",  "default": 28 },
    { "type": "range",  "id": "drawer_font_weight",     "label": "Link Font Weight",      "min": 300, "max": 800, "step": 100, "default": 600 },
    { "type": "range",  "id": "drawer_subfont_size",    "label": "Sub-link Font Size",    "min": 13, "max": 20,  "step": 1,  "unit": "px",  "default": 15 },

{%- liquid
  assign spacing_top = section.settings.spacing_top | default: 'lg'
  assign spacing_bottom = section.settings.spacing_bottom | default: 'lg'
-%}
<div class="newsletter-section{% if section.settings.enable_animation %} has-animation{% endif %}"
     id="Newsletter-{{ section.id }}"
     style="position: relative;
            padding: var(--spacing-{{ spacing_top }}) {{ section.settings.padding_horizontal }}px var(--spacing-{{ spacing_bottom }});
            background-color: {{ section.settings.bg_color }};
            background-image: {% if section.settings.image != blank %}url('{{ section.settings.image | img_url: 'master' }}'){% else %}none{% endif %};
            background-size: {{ section.settings.bg_size }};
            background-position: {{ section.settings.bg_position }};
            display: flex;
            justify-content: center;
            align-items: center;">

  <div class="newsletter-overlay"
       style="position: absolute;
              top: 0;
              left: 0;
              right: 0;
              bottom: 0;
              background: {% if section.settings.use_gradient %}{{ section.settings.overlay_gradient }}{% else %}{{ section.settings.overlay_color }}{% endif %};
              opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
              z-index: 1;"></div>

  <div class="newsletter-content{% if section.settings.enable_animation %} fade-up{% endif %}"
       data-animation-delay="0"
       style="position: relative;
              z-index: 2;
              width: 100%;
              max-width: {{ section.settings.content_max_width }}px;
              background: {{ section.settings.form_bg }};
              padding: {{ section.settings.form_padding }}px;
              border-radius: {{ section.settings.form_border_radius }}px;
              box-shadow: {{ section.settings.form_shadow }};">

    {%- if section.settings.title != blank -%}
      <h2 class="newsletter-heading"
          style="font-size: clamp({{ section.settings.heading_size_min }}px, 4vw, {{ section.settings.heading_size }}px);
                 text-align: {{ section.settings.heading_align }};
                 margin-bottom: {{ section.settings.heading_margin }}px;
                 color: {{ section.settings.text_color }};
                 font-family: var(--font-heading);
                 font-weight: {{ section.settings.heading_weight }};
                 letter-spacing: {{ section.settings.heading_letter_spacing }}px;">
        {{ section.settings.title }}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="newsletter-description"
           style="text-align: {{ section.settings.description_align }};
                  color: {{ section.settings.description_color }};
                  font-size: {{ section.settings.description_size }}px;
                  line-height: {{ section.settings.description_line_height }};
                  margin-bottom: {{ section.settings.description_margin }}px;
                  max-width: {{ section.settings.description_max_width }}px;
                  margin-left: auto;
                  margin-right: auto;">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    {% form 'customer', id: 'newsletter-form-' | append: section.id, class: 'newsletter-form', data-ajax: section.settings.enable_ajax %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      <div class="form-messages" id="form-messages-{{ section.id }}" style="display: none;">
        <div class="form-success"
             style="padding: {{ section.settings.message_padding }}px;
                    background: {{ section.settings.success_bg }};
                    color: {{ section.settings.success_text }};
                    border-radius: {{ section.settings.message_radius }}px;
                    margin-bottom: {{ section.settings.message_margin }}px;
                    text-align: center;
                    font-size: {{ section.settings.message_font_size }}px;
                    font-weight: {{ section.settings.message_font_weight }};
                    animation: slideDown 0.5s ease;">
          <span class="success-icon" style="display: {{ section.settings.show_success_icon ? 'inline-block' : 'none' }}; margin-right: 8px;">✓</span>
          <span class="success-message">{{ section.settings.success_message }}</span>
        </div>

        <div class="form-error"
             style="padding: {{ section.settings.message_padding }}px;
                    background: {{ section.settings.error_bg }};
                    color: {{ section.settings.error_text }};
                    border-radius: {{ section.settings.message_radius }}px;
                    margin-bottom: {{ section.settings.message_margin }}px;
                    text-align: center;
                    font-size: {{ section.settings.message_font_size }}px;
                    font-weight: {{ section.settings.message_font_weight }};
                    animation: slideDown 0.5s ease;">
          <span class="error-icon" style="display: {{ section.settings.show_error_icon ? 'inline-block' : 'none' }}; margin-right: 8px;">⚠</span>
          <span class="error-message">{{ section.settings.error_message }}</span>
        </div>
      </div>

      {%- if form.posted_successfully? -%}
        <div class="form-success"
             style="padding: {{ section.settings.message_padding }}px;
                    background: {{ section.settings.success_bg }};
                    color: {{ section.settings.success_text }};
                    border-radius: {{ section.settings.message_radius }}px;
                    margin-bottom: {{ section.settings.message_margin }}px;
                    text-align: center;
                    font-size: {{ section.settings.message_font_size }}px;
                    font-weight: {{ section.settings.message_font_weight }};">
          <span class="success-icon" style="display: {{ section.settings.show_success_icon ? 'inline-block' : 'none' }}; margin-right: 8px;">✓</span>
          {{ section.settings.success_message }}
        </div>
      {%- elsif form.errors -%}
        <div class="form-error"
             style="padding: {{ section.settings.message_padding }}px;
                    background: {{ section.settings.error_bg }};
                    color: {{ section.settings.error_text }};
                    border-radius: {{ section.settings.message_radius }}px;
                    margin-bottom: {{ section.settings.message_margin }}px;
                    text-align: center;
                    font-size: {{ section.settings.message_font_size }}px;">
          <span class="error-icon" style="display: {{ section.settings.show_error_icon ? 'inline-block' : 'none' }}; margin-right: 8px;">⚠</span>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      {%- if section.settings.layout == 'row' -%}
        <div class="form-row"
             style="display: grid;
                    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                    gap: {{ section.settings.field_gap }}px;
                    margin-bottom: {{ section.settings.field_gap }}px;">

          {%- if section.settings.show_name_fields -%}
            <div class="form-field">
              <label class="form-label"
                     style="display: {{ section.settings.label_display }};
                            font-size: {{ section.settings.label_font_size }}px;
                            margin-bottom: {{ section.settings.label_margin }}px;
                            font-weight: {{ section.settings.label_font_weight }};
                            color: {{ section.settings.label_color }};
                            letter-spacing: {{ section.settings.label_letter_spacing }}px;">
                {{ section.settings.label_first_name }}
                {%- if section.settings.show_required %}<span style="color: {{ section.settings.required_color }};">*</span>{%- endif -%}
              </label>
              <input type="text"
                     name="contact[first_name]"
                     class="form-input"
                     placeholder="{{ section.settings.placeholder_first_name | escape }}"
                     {% if section.settings.require_name %}required{% endif %}
                     style="width: 100%;
                            padding: {{ section.settings.input_padding }}px;
                            background: {{ section.settings.input_bg }};
                            border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
                            border-radius: {{ section.settings.input_border_radius }}px;
                            color: {{ section.settings.input_text_color }};
                            font-size: {{ section.settings.input_font_size }}px;
                            font-family: var(--font-body);
                            transition: all {{ section.settings.input_transition }}s ease;">
            </div>

            <div class="form-field">
              <label class="form-label"
                     style="display: {{ section.settings.label_display }};
                            font-size: {{ section.settings.label_font_size }}px;
                            margin-bottom: {{ section.settings.label_margin }}px;
                            font-weight: {{ section.settings.label_font_weight }};
                            color: {{ section.settings.label_color }};
                            letter-spacing: {{ section.settings.label_letter_spacing }}px;">
                {{ section.settings.label_last_name }}
                {%- if section.settings.show_required %}<span style="color: {{ section.settings.required_color }};">*</span>{%- endif -%}
              </label>
              <input type="text"
                     name="contact[last_name]"
                     class="form-input"
                     placeholder="{{ section.settings.placeholder_last_name | escape }}"
                     {% if section.settings.require_name %}required{% endif %}
                     style="width: 100%;
                            padding: {{ section.settings.input_padding }}px;
                            background: {{ section.settings.input_bg }};
                            border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
                            border-radius: {{ section.settings.input_border_radius }}px;
                            color: {{ section.settings.input_text_color }};
                            font-size: {{ section.settings.input_font_size }}px;
                            font-family: var(--font-body);
                            transition: all {{ section.settings.input_transition }}s ease;">
            </div>
          {%- endif -%}

          <div class="form-field">
            <label class="form-label"
                   style="display: {{ section.settings.label_display }};
                          font-size: {{ section.settings.label_font_size }}px;
                          margin-bottom: {{ section.settings.label_margin }}px;
                          font-weight: {{ section.settings.label_font_weight }};
                          color: {{ section.settings.label_color }};
                          letter-spacing: {{ section.settings.label_letter_spacing }}px;">
              {{ section.settings.label_email }}
              {%- if section.settings.show_required %}<span style="color: {{ section.settings.required_color }};">*</span>{%- endif -%}
            </label>
            <input type="email"
                   name="contact[email]"
                   class="form-input"
                   placeholder="{{ section.settings.placeholder_email | escape }}"
                   required
                   style="width: 100%;
                          padding: {{ section.settings.input_padding }}px;
                          background: {{ section.settings.input_bg }};
                          border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
                          border-radius: {{ section.settings.input_border_radius }}px;
                          color: {{ section.settings.input_text_color }};
                          font-size: {{ section.settings.input_font_size }}px;
                          font-family: var(--font-body);
                          transition: all {{ section.settings.input_transition }}s ease;">
          </div>

          <div class="form-field" style="display: flex; align-items: flex-end;">
            <button type="submit"
                    class="form-submit"
                    style="width: 100%;
                           padding: {{ section.settings.button_padding }}px;
                           background: {{ section.settings.button_bg }};
                           color: {{ section.settings.button_text }};
                           border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
                           border-radius: {{ section.settings.button_border_radius }}px;
                           font-size: {{ section.settings.button_font_size }}px;
                           font-weight: {{ section.settings.button_font_weight }};
                           font-family: var(--font-heading);
                           letter-spacing: {{ section.settings.button_letter_spacing }}px;
                           cursor: pointer;
                           transition: all {{ section.settings.button_transition }}s ease;
                           text-transform: {{ section.settings.button_text_transform }};
                           position: relative;
                           overflow: hidden;">
              <span class="button-text">{{ section.settings.button_label }}</span>
              <span class="button-loader" style="display: none;">
                <svg width="20" height="20" viewBox="0 0 50 50" style="animation: spin 1s linear infinite;">
                  <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="5" stroke-dasharray="31.4 31.4" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        </div>

      {%- else -%}
        {%- if section.settings.show_name_fields -%}
          <div class="form-row"
               style="display: grid;
                      grid-template-columns: 1fr 1fr;
                      gap: {{ section.settings.field_gap }}px;
                      margin-bottom: {{ section.settings.field_gap }}px;">
            <div class="form-field">
              <label class="form-label"
                     style="display: {{ section.settings.label_display }};
                            font-size: {{ section.settings.label_font_size }}px;
                            margin-bottom: {{ section.settings.label_margin }}px;
                            font-weight: {{ section.settings.label_font_weight }};
                            color: {{ section.settings.label_color }};
                            letter-spacing: {{ section.settings.label_letter_spacing }}px;">
                {{ section.settings.label_first_name }}
                {%- if section.settings.show_required %}<span style="color: {{ section.settings.required_color }};">*</span>{%- endif -%}
              </label>
              <input type="text"
                     name="contact[first_name]"
                     class="form-input"
                     placeholder="{{ section.settings.placeholder_first_name | escape }}"
                     {% if section.settings.require_name %}required{% endif %}
                     style="width: 100%;
                            padding: {{ section.settings.input_padding }}px;
                            background: {{ section.settings.input_bg }};
                            border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
                            border-radius: {{ section.settings.input_border_radius }}px;
                            color: {{ section.settings.input_text_color }};
                            font-size: {{ section.settings.input_font_size }}px;
                            font-family: var(--font-body);
                            transition: all {{ section.settings.input_transition }}s ease;">
            </div>

            <div class="form-field">
              <label class="form-label"
                     style="display: {{ section.settings.label_display }};
                            font-size: {{ section.settings.label_font_size }}px;
                            margin-bottom: {{ section.settings.label_margin }}px;
                            font-weight: {{ section.settings.label_font_weight }};
                            color: {{ section.settings.label_color }};
                            letter-spacing: {{ section.settings.label_letter_spacing }}px;">
                {{ section.settings.label_last_name }}
                {%- if section.settings.show_required %}<span style="color: {{ section.settings.required_color }};">*</span>{%- endif -%}
              </label>
              <input type="text"
                     name="contact[last_name]"
                     class="form-input"
                     placeholder="{{ section.settings.placeholder_last_name | escape }}"
                     {% if section.settings.require_name %}required{% endif %}
                     style="width: 100%;
                            padding: {{ section.settings.input_padding }}px;
                            background: {{ section.settings.input_bg }};
                            border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
                            border-radius: {{ section.settings.input_border_radius }}px;
                            color: {{ section.settings.input_text_color }};
                            font-size: {{ section.settings.input_font_size }}px;
                            font-family: var(--font-body);
                            transition: all {{ section.settings.input_transition }}s ease;">
            </div>
          </div>
        {%- endif -%}

        <div class="form-field" style="margin-bottom: {{ section.settings.field_gap }}px;">
          <label class="form-label"
                 style="display: {{ section.settings.label_display }};
                        font-size: {{ section.settings.label_font_size }}px;
                        margin-bottom: {{ section.settings.label_margin }}px;
                        font-weight: {{ section.settings.label_font_weight }};
                        color: {{ section.settings.label_color }};
                        letter-spacing: {{ section.settings.label_letter_spacing }}px;">
            {{ section.settings.label_email }}
            {%- if section.settings.show_required %}<span style="color: {{ section.settings.required_color }};">*</span>{%- endif -%}
          </label>
          <input type="email"
                 name="contact[email]"
                 class="form-input"
                 placeholder="{{ section.settings.placeholder_email | escape }}"
                 required
                 style="width: 100%;
                        padding: {{ section.settings.input_padding }}px;
                        background: {{ section.settings.input_bg }};
                        border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
                        border-radius: {{ section.settings.input_border_radius }}px;
                        color: {{ section.settings.input_text_color }};
                        font-size: {{ section.settings.input_font_size }}px;
                        font-family: var(--font-body);
                        transition: all {{ section.settings.input_transition }}s ease;">
        </div>

        <button type="submit"
                class="form-submit"
                style="width: 100%;
                       padding: {{ section.settings.button_padding }}px;
                       background: {{ section.settings.button_bg }};
                       color: {{ section.settings.button_text }};
                       border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
                       border-radius: {{ section.settings.button_border_radius }}px;
                       font-size: {{ section.settings.button_font_size }}px;
                       font-weight: {{ section.settings.button_font_weight }};
                       font-family: var(--font-heading);
                       letter-spacing: {{ section.settings.button_letter_spacing }}px;
                       cursor: pointer;
                       transition: all {{ section.settings.button_transition }}s ease;
                       text-transform: {{ section.settings.button_text_transform }};
                       margin-top: {{ section.settings.button_margin_top }}px;">
          <span class="button-text">{{ section.settings.button_label }}</span>
          <span class="button-loader" style="display: none;">
            <svg width="20" height="20" viewBox="0 0 50 50" style="animation: spin 1s linear infinite;">
              <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="5" stroke-dasharray="31.4 31.4" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
      {%- endif -%}

      {%- if section.settings.show_checkbox -%}
        <label class="checkbox-container"
               style="display: flex;
                      align-items: center;
                      gap: {{ section.settings.checkbox_gap }}px;
                      margin-top: {{ section.settings.checkbox_margin }}px;
                      cursor: pointer;">
          <input type="checkbox"
                 name="customer[accepts_marketing]"
                 class="checkbox-input"
                 value="true"
                 style="appearance: none;
                        width: {{ section.settings.checkbox_size }}px;
                        height: {{ section.settings.checkbox_size }}px;
                        border: {{ section.settings.checkbox_border_width }}px solid {{ section.settings.checkbox_border_color }};
                        background: {{ section.settings.checkbox_bg }};
                        border-radius: {{ section.settings.checkbox_radius }}px;
                        cursor: pointer;
                        position: relative;
                        transition: all {{ section.settings.checkbox_transition }}s ease;">
          <span class="checkbox-label"
                style="font-size: {{ section.settings.checkbox_label_size }}px;
                       color: {{ section.settings.checkbox_label_color }};
                       font-family: var(--font-body);">
            {{ section.settings.checkbox_text }}
          </span>
        </label>
      {%- endif -%}
    {% endform %}

    {%- if section.settings.show_privacy_note and section.settings.privacy_note != blank -%}
      <div class="privacy-note"
           style="margin-top: {{ section.settings.privacy_note_margin }}px;
                  text-align: {{ section.settings.privacy_note_align }};
                  font-size: {{ section.settings.privacy_note_size }}px;
                  color: {{ section.settings.privacy_note_color }};
                  line-height: {{ section.settings.privacy_note_line_height }};">
        {{ section.settings.privacy_note }}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  /* Input focus states */
  .form-input:focus {
    outline: none;
    border-color: {{ section.settings.input_focus_border_color }};
    border-width: {{ section.settings.input_focus_border_width }}px;
    background: {{ section.settings.input_focus_bg }};
    box-shadow: {{ section.settings.input_focus_shadow }};
  }

  .form-input::placeholder {
    color: {{ section.settings.placeholder_color }};
    opacity: {{ section.settings.placeholder_opacity | divided_by: 100.0 }};
  }

  /* Button hover states */
  .form-submit:hover {
    background: {{ section.settings.button_hover_bg }};
    color: {{ section.settings.button_hover_text }};
    border-color: {{ section.settings.button_hover_border }};
    transform: translateY(-{{ section.settings.button_hover_lift }}px) scale({{ section.settings.button_hover_scale | divided_by: 100.0 }});
    box-shadow: {{ section.settings.button_hover_shadow }};
  }

  .form-submit:active {
    transform: translateY(0) scale(0.98);
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Checkbox checked state */
  .checkbox-input:checked {
    background: {{ section.settings.checkbox_checked_bg }};
    border-color: {{ section.settings.checkbox_checked_border }};
  }

  .checkbox-input:checked::after {
    content: '{{ section.settings.checkbox_icon }}';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: {{ section.settings.checkbox_icon_size }}px;
    color: {{ section.settings.checkbox_icon_color }};
  }

  /* Animations */
  .fade-up {
    opacity: 0;
    transform: translateY({{ section.settings.animation_distance }}px);
    transition: opacity {{ section.settings.animation_duration }}s {{ section.settings.animation_easing }},
                transform {{ section.settings.animation_duration }}s {{ section.settings.animation_easing }};
  }

  .fade-up.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Mobile responsive */
  @media screen and (max-width: 767px) {
    .newsletter-section {
      padding-top: {{ section.settings.mobile_padding_top }}px !important;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px !important;
    }

    .form-row {
      grid-template-columns: 1fr !important;
    }

    .newsletter-content {
      padding: {{ section.settings.mobile_form_padding }}px !important;
    }
  }
</style>

<script>
  // Form AJAX submission
  {%- if section.settings.enable_ajax -%}
  (function() {
    const form = document.getElementById('newsletter-form-{{ section.id }}');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      const button = form.querySelector('.form-submit');
      const buttonText = button.querySelector('.button-text');
      const buttonLoader = button.querySelector('.button-loader');
      const messageContainer = document.getElementById('form-messages-{{ section.id }}');
      const successMessage = messageContainer.querySelector('.form-success');
      const errorMessage = messageContainer.querySelector('.form-error');

      // Show loading state
      button.disabled = true;
      buttonText.style.display = 'none';
      buttonLoader.style.display = 'inline-block';

      // Submit form
      fetch(form.action, {
        method: 'POST',
        body: new FormData(form)
      })
      .then(response => response.text())
      .then(() => {
        // Show success
        messageContainer.style.display = 'block';
        successMessage.style.display = 'block';
        errorMessage.style.display = 'none';

        // Reset form
        form.reset();

        // Hide loader
        button.disabled = false;
        buttonText.style.display = 'inline-block';
        buttonLoader.style.display = 'none';

        // Hide message after delay
        setTimeout(() => {
          messageContainer.style.display = 'none';
          successMessage.style.display = 'none';
        }, {{ section.settings.message_auto_hide_delay | times: 1000 }});

        {%- if section.settings.enable_confetti -%}
        // Trigger confetti
        if (typeof confetti !== 'undefined') {
          confetti({
            particleCount: 100,
            spread: 70,
            origin: { y: 0.6 }
          });
        }
        {%- endif -%}
      })
      .catch(() => {
        // Show error
        messageContainer.style.display = 'block';
        successMessage.style.display = 'none';
        errorMessage.style.display = 'block';

        // Hide loader
        button.disabled = false;
        buttonText.style.display = 'inline-block';
        buttonLoader.style.display = 'none';

        // Hide message after delay
        setTimeout(() => {
          messageContainer.style.display = 'none';
          errorMessage.style.display = 'none';
        }, {{ section.settings.message_auto_hide_delay | times: 1000 }});
      });
    });
  })();
  {%- endif -%}

  // Scroll animations
  {%- if section.settings.enable_animation -%}
  (function() {
    const options = {
      threshold: {{ section.settings.animation_threshold | divided_by: 100.0 }},
      rootMargin: '{{ section.settings.animation_margin }}px'
    };

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.dataset.animationDelay || 0;
          setTimeout(() => {
            entry.target.classList.add('in-view');
          }, parseFloat(delay) * 1000);
          observer.unobserve(entry.target);
        }
      });
    }, options);

    document.querySelectorAll('.newsletter-section .fade-up').forEach(el => {
      observer.observe(el);
    });
  })();
  {%- endif -%}
</script>

{% schema %}
{
  "name": "Newsletter (Enhanced)",
  "settings": [
    {
      "type": "header",
      "content": "Section Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#e2e2e2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {

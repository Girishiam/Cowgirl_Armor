<style>
  .newsletter-section-{{ section.id }} {
    position: relative;
    padding: clamp(4rem, 10vw, 8rem) 2rem;
    background-size: cover;
    background-position: center;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    display: flex;
    justify-content: center;
    align-items: center;
    {% if section.settings.image != blank %}
      background-image: url('{{ section.settings.image | image_url: width: 2000 }}');
    {% endif %}
  }

  .newsletter-overlay-{{ section.id }} {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .newsletter-content-{{ section.id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 800px;
  }

  .newsletter-heading-{{ section.id }} {
    font-size: clamp(2rem, 5vw, 4rem);
    text-align: center;
    margin-bottom: 3rem;
    color: {{ section.settings.text_color }};
    display: inline-block;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.8);
    padding: 0.5rem 1rem;
    border-left: 4px solid #1a365d; /* Dark blue accent line */
  }

  .premium-form-group {
    margin-bottom: 2rem;
  }

  .premium-form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media screen and (min-width: 768px) {
    .premium-form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .premium-input-container {
    position: relative;
  }

  .premium-label {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-body);
    font-weight: bold;
    color: {{ section.settings.text_color }};
  }

  .premium-input {
    width: 100%;
    padding: 0.8rem 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0,0,0,0.3);
    color: {{ section.settings.text_color }};
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .premium-input:focus {
    outline: none;
    border-bottom-color: {{ section.settings.text_color }};
  }

  .premium-input::placeholder {
    color: rgba(0,0,0,0.5);
    font-size: 0.85rem;
  }

  .premium-checkbox-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    cursor: pointer;
  }

  .premium-checkbox {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 1px solid rgba(0,0,0,0.3);
    background: transparent;
    cursor: pointer;
    position: relative;
    border-radius: 2px;
  }

  .premium-checkbox:checked::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 12px;
    color: {{ section.settings.text_color }};
  }

  .premium-checkbox-label {
    font-size: 0.9rem;
    font-family: var(--font-body);
    color: {{ section.settings.text_color }};
  }

  .premium-submit-btn {
    background-color: transparent;
    color: {{ section.settings.text_color }};
    border: 1px solid {{ section.settings.text_color }};
    padding: 0.8rem 2.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .premium-submit-btn:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }
</style>

<div class="newsletter-section-{{ section.id }}">
  <div class="newsletter-overlay-{{ section.id }}"></div>

  <div class="newsletter-content-{{ section.id }}">
    {%- if section.settings.title != blank -%}
      <h2 class="newsletter-heading-{{ section.id }}">{{ section.settings.title }}</h2>
    {%- endif -%}

    {% form 'customer', id: 'premium-newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <div
          class="form-success"
          style="padding: 1rem; background: rgba(255,255,255,0.8); color: green; margin-bottom: 2rem; text-align: center;"
        >
          {{ section.settings.success_message }}
        </div>
      {%- endif -%}

      <div class="premium-form-group">
        <label class="premium-label">Name</label>
        <div class="premium-form-row">
          <div class="premium-input-container">
            <input
              type="text"
              name="contact[first_name]"
              class="premium-input"
              placeholder="First Name (required)"
              required
            >
          </div>
          <div class="premium-input-container">
            <input
              type="text"
              name="contact[last_name]"
              class="premium-input"
              placeholder="Last Name (required)"
              required
            >
          </div>
        </div>
      </div>

      <div class="premium-form-group">
        <label class="premium-label"
          >Email <span style="font-weight: normal; font-size: 0.85rem;">(required)</span></label
        >
        <input type="email" name="contact[email]" class="premium-input" placeholder="" required>
      </div>

      <label class="premium-checkbox-container">
        <input type="checkbox" name="customer[accepts_marketing]" class="premium-checkbox" value="true">
        <span class="premium-checkbox-label">{{ section.settings.checkbox_text }}</span>
      </label>

      <button type="submit" class="premium-submit-btn">
        {{ section.settings.button_label }}
      </button>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Premium Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Join The Cowgirl Army"
    },
    {
      "type": "text",
      "id": "checkbox_text",
      "label": "Checkbox Label",
      "default": "Sign up for news and updates"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Submit"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Welcome to the Cowgirl Army!"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback BG Color",
      "default": "#e2e2e2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Premium Newsletter",
      "category": "Form"
    }
  ]
}
{% endschema %}

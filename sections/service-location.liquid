<style>
  /* ── Reset ── */
  .sln-{{ section.id }} *,
  .sln-{{ section.id }} *::before,
  .sln-{{ section.id }} *::after { box-sizing: border-box; }

  /* ── Section wrapper ── */
  .sln-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_desktop }}px 0 {{ section.settings.padding_bottom_desktop }}px;
  }

  .sln-{{ section.id }} .sln__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.padding_h_desktop }}px;
  }

  /* ── Main 2-col grid ── */
  .sln-{{ section.id }} .sln__grid {
    display: grid;
    grid-template-columns: {{ section.settings.left_col }}fr {{ section.settings.right_col }}fr;
    gap: {{ section.settings.col_gap }}px;
    align-items: start;
  }

  /* ════════════════════════════════
     LEFT COLUMN
  ════════════════════════════════ */
  .sln-{{ section.id }} .sln__left {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.left_gap }}px;
  }

  /* Hero image */
  .sln-{{ section.id }} .sln__hero-wrap {
    position: relative;
    border-radius: {{ section.settings.img_radius }}px;
    overflow: hidden;
    box-shadow: {{ section.settings.img_shadow }};
  }
  .sln-{{ section.id }} .sln__hero-img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .sln-{{ section.id }} .sln__hero-wrap:hover .sln__hero-img {
    transform: scale(1.03);
  }

  /* Sub-images (map screenshots etc) */
  .sln-{{ section.id }} .sln__sub-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.sub_img_gap }}px;
  }
  .sln-{{ section.id }} .sln__sub-wrap {
    position: relative;
    border-radius: {{ section.settings.img_radius }}px;
    overflow: hidden;
    box-shadow: {{ section.settings.img_shadow }};
  }
  .sln-{{ section.id }} .sln__sub-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
    transition: transform 0.5s ease;
  }
  .sln-{{ section.id }} .sln__sub-wrap:hover .sln__sub-img {
    transform: scale(1.04);
  }
  /* Single sub-image spans full width */
  .sln-{{ section.id }} .sln__sub-images--single .sln__sub-wrap {
    grid-column: 1 / -1;
  }

  /* ════════════════════════════════
     RIGHT COLUMN
  ════════════════════════════════ */
  .sln-{{ section.id }} .sln__right {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.right_gap }}px;
  }

  /* ── Eyebrow ── */
  .sln-{{ section.id }} .sln__eyebrow {
    font-family: var(--font-body-family, sans-serif);
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sln-{{ section.id }} .sln__eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: {{ section.settings.accent_color }};
    flex-shrink: 0;
  }

  /* ── Section title ── */
  .sln-{{ section.id }} .sln__title {
    font-family: var(--font-heading-family, serif);
    font-size: clamp({{ section.settings.title_min }}px, 3vw, {{ section.settings.title_max }}px);
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.15;
    letter-spacing: {{ section.settings.title_ls | divided_by: 100.0 }}em;
    color: {{ section.settings.title_color }};
    margin: 0;
  }

  /* ── Address line ── */
  .sln-{{ section.id }} .sln__address {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp({{ section.settings.address_min }}px, 1.3vw, {{ section.settings.address_max }}px);
    font-weight: {{ section.settings.address_weight }};
    color: {{ section.settings.address_color }};
    margin: 0;
    line-height: 1.5;
  }
  .sln-{{ section.id }} .sln__address strong { font-weight: 700; color: {{ section.settings.title_color }}; }

  /* ── Divider ── */
  .sln-{{ section.id }} .sln__rule {
    border: none;
    border-top: 1px solid {{ section.settings.rule_color }};
    margin: 0;
  }

  /* ── Block title (e.g. "Important Navigation Tips") ── */
  .sln-{{ section.id }} .sln__block-title {
    font-family: var(--font-heading-family, serif);
    font-size: clamp({{ section.settings.block_title_min }}px, 2vw, {{ section.settings.block_title_max }}px);
    font-weight: {{ section.settings.block_title_weight }};
    color: {{ section.settings.title_color }};
    margin: 0;
    line-height: 1.25;
  }

  /* ── Rich text body ── */
  .sln-{{ section.id }} .sln__rte {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp({{ section.settings.body_min }}px, 1.2vw, {{ section.settings.body_max }}px);
    font-weight: {{ section.settings.body_weight }};
    line-height: {{ section.settings.body_lh | divided_by: 100.0 }};
    color: {{ section.settings.body_color }};
    margin: 0;
  }
  .sln-{{ section.id }} .sln__rte p { margin: 0 0 0.85em; }
  .sln-{{ section.id }} .sln__rte p:last-child { margin: 0; }
  .sln-{{ section.id }} .sln__rte strong {
    font-weight: 700;
    color: {{ section.settings.title_color }};
  }
  .sln-{{ section.id }} .sln__rte em { font-style: italic; }
  .sln-{{ section.id }} .sln__rte a {
    color: {{ section.settings.accent_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
  }
  .sln-{{ section.id }} .sln__rte ul,
  .sln-{{ section.id }} .sln__rte ol {
    padding-left: 1.3em;
    margin: 0 0 0.85em;
  }
  .sln-{{ section.id }} .sln__rte ul { list-style: disc; }
  .sln-{{ section.id }} .sln__rte ol { list-style: decimal; }
  .sln-{{ section.id }} .sln__rte li { margin-bottom: 0.5em; line-height: 1.6; }
  .sln-{{ section.id }} .sln__rte li strong {
    font-weight: 700;
    color: {{ section.settings.title_color }};
  }

  /* ── Right column images ── */
  .sln-{{ section.id }} .sln__right-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.sub_img_gap }}px;
  }
  .sln-{{ section.id }} .sln__right-img-wrap {
    position: relative;
    border-radius: {{ section.settings.img_radius }}px;
    overflow: hidden;
    box-shadow: {{ section.settings.img_shadow }};
  }
  .sln-{{ section.id }} .sln__right-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
    transition: transform 0.5s ease;
  }
  .sln-{{ section.id }} .sln__right-img-wrap:hover .sln__right-img {
    transform: scale(1.04);
  }
  .sln-{{ section.id }} .sln__right-images--single .sln__right-img-wrap {
    grid-column: 1 / -1;
  }
  .sln-{{ section.id }} .sln__right-images--single .sln__right-img {
    aspect-ratio: 16/7;
  }

  /* ── CTA button ── */
  .sln-{{ section.id }} .sln__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-family: var(--font-body-family, sans-serif);
    font-size: {{ section.settings.btn_size }}px;
    font-weight: {{ section.settings.btn_weight }};
    letter-spacing: 0.04em;
    text-transform: {{ section.settings.btn_transform }};
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_color }};
    border: {{ section.settings.btn_border_w }}px solid {{ section.settings.btn_border_c }};
    border-radius: {{ section.settings.btn_radius }}px;
    padding: {{ section.settings.btn_pv }}px {{ section.settings.btn_ph }}px;
    transition: background-color 0.25s ease, color 0.25s ease,
                transform 0.2s ease, box-shadow 0.25s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    align-self: flex-start;
  }
  .sln-{{ section.id }} .sln__btn:hover {
    background-color: {{ section.settings.btn_bg_hover }};
    color: {{ section.settings.btn_color_hover }};
    transform: translateY(-2px);
    box-shadow: 0 6px 22px rgba(0,0,0,0.13);
  }
  .sln-{{ section.id }} .sln__btn svg {
    flex-shrink: 0;
    transition: transform 0.22s ease;
  }
  .sln-{{ section.id }} .sln__btn:hover svg { transform: translateX(4px); }

  /* ── Responsive ── */
  @media screen and (max-width: 960px) {
    .sln-{{ section.id }} .sln__grid {
      grid-template-columns: 1fr;
    }
    .sln-{{ section.id }} .sln__right-images {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 600px) {
    .sln-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .sln-{{ section.id }} .sln__container {
      padding: 0 {{ section.settings.padding_h_mobile }}px;
    }
    .sln-{{ section.id }} .sln__sub-images,
    .sln-{{ section.id }} .sln__right-images {
      grid-template-columns: 1fr;
    }
    .sln-{{ section.id }} .sln__sub-images .sln__sub-wrap,
    .sln-{{ section.id }} .sln__right-images .sln__right-img-wrap {
      grid-column: auto;
    }
  }
</style>

<section class="sln-{{ section.id }}">
  <div class="sln__container">
    <div class="sln__grid">

      <!-- ══ LEFT COLUMN ══ -->
      <div class="sln__left">

        {%- comment -%} Hero image {%- endcomment -%}
        {%- if section.settings.hero_image != blank -%}
          <div class="sln__hero-wrap">
            <img
              src="{{ section.settings.hero_image | image_url: width: 900 }}"
              srcset="{{ section.settings.hero_image | image_url: width: 400 }} 400w,
                      {{ section.settings.hero_image | image_url: width: 700 }} 700w,
                      {{ section.settings.hero_image | image_url: width: 900 }} 900w"
              sizes="(max-width: 960px) 100vw, 45vw"
              alt="{{ section.settings.hero_image.alt | default: section.settings.title | escape }}"
              class="sln__hero-img"
              loading="eager"
            >
          </div>
        {%- endif -%}

        {%- comment -%} Sub images (maps, screenshots) {%- endcomment -%}
        {%- assign sub_count = 0 -%}
        {%- if section.settings.sub_image_1 != blank -%}{%- assign sub_count = sub_count | plus: 1 -%}{%- endif -%}
        {%- if section.settings.sub_image_2 != blank -%}{%- assign sub_count = sub_count | plus: 1 -%}{%- endif -%}

        {%- if sub_count > 0 -%}
          <div class="sln__sub-images{% if sub_count == 1 %} sln__sub-images--single{% endif %}">
            {%- if section.settings.sub_image_1 != blank -%}
              <div class="sln__sub-wrap">
                <img
                  src="{{ section.settings.sub_image_1 | image_url: width: 600 }}"
                  alt="{{ section.settings.sub_image_1.alt | default: 'Location map' | escape }}"
                  class="sln__sub-img"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
            {%- if section.settings.sub_image_2 != blank -%}
              <div class="sln__sub-wrap">
                <img
                  src="{{ section.settings.sub_image_2 | image_url: width: 600 }}"
                  alt="{{ section.settings.sub_image_2.alt | default: 'Location view' | escape }}"
                  class="sln__sub-img"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>

      <!-- ══ RIGHT COLUMN ══ -->
      <div class="sln__right">

        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'eyebrow' -%}
              {%- if block.settings.text != blank -%}
                <p class="sln__eyebrow" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </p>
              {%- endif -%}

            {%- when 'title' -%}
              {%- if block.settings.text != blank -%}
                <{{ block.settings.tag }} class="sln__title" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </{{ block.settings.tag }}>
              {%- endif -%}

            {%- when 'address' -%}
              {%- if block.settings.text != blank -%}
                <p class="sln__address" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </p>
              {%- endif -%}

            {%- when 'rule' -%}
              <hr class="sln__rule" {{ block.shopify_attributes }}>

            {%- when 'block_title' -%}
              {%- if block.settings.text != blank -%}
                <{{ block.settings.tag }} class="sln__block-title" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </{{ block.settings.tag }}>
              {%- endif -%}

            {%- when 'rich_text' -%}
              {%- if block.settings.content != blank -%}
                <div class="sln__rte" {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>
              {%- endif -%}

            {%- when 'images' -%}
              {%- assign ri_count = 0 -%}
              {%- if block.settings.image_1 != blank -%}{%- assign ri_count = ri_count | plus: 1 -%}{%- endif -%}
              {%- if block.settings.image_2 != blank -%}{%- assign ri_count = ri_count | plus: 1 -%}{%- endif -%}
              {%- if ri_count > 0 -%}
                <div class="sln__right-images{% if ri_count == 1 %} sln__right-images--single{% endif %}" {{ block.shopify_attributes }}>
                  {%- if block.settings.image_1 != blank -%}
                    <div class="sln__right-img-wrap">
                      <img
                        src="{{ block.settings.image_1 | image_url: width: 700 }}"
                        alt="{{ block.settings.image_1.alt | default: 'Location image' | escape }}"
                        class="sln__right-img"
                        loading="lazy"
                      >
                    </div>
                  {%- endif -%}
                  {%- if block.settings.image_2 != blank -%}
                    <div class="sln__right-img-wrap">
                      <img
                        src="{{ block.settings.image_2 | image_url: width: 700 }}"
                        alt="{{ block.settings.image_2.alt | default: 'Location image' | escape }}"
                        class="sln__right-img"
                        loading="lazy"
                      >
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'button' -%}
              {%- if block.settings.label != blank -%}
                <a
                  href="{{ block.settings.link }}"
                  class="sln__btn"
                  {{ block.shopify_attributes }}
                  {% if block.settings.new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                >
                  {{ block.settings.label }}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round"
                       aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}

      </div>
      <!-- /.sln__right -->

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Service Location & Nav",
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow Label",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Eyebrow Text",
          "default": "In Loving Memory"
        }
      ]
    },
    {
      "type": "title",
      "name": "Section Title",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Title Text",
          "default": "Service Location"
        },
        {
          "type": "select",
          "id": "tag",
          "label": "HTML Tag",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "address",
      "name": "Address / Subtitle",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Address Text",
          "default": "Services will be held at: Double N Cowboy Church 7202 E State Highway 6 Dublin, TX 76446"
        }
      ]
    },
    {
      "type": "rule",
      "name": "Divider Line",
      "limit": 4
    },
    {
      "type": "block_title",
      "name": "Sub-heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Sub-heading Text",
          "default": "Important Navigation Tips"
        },
        {
          "type": "select",
          "id": "tag",
          "label": "HTML Tag",
          "options": [
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" }
          ],
          "default": "h3"
        }
      ]
    },
    {
      "type": "rich_text",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "info": "Supports bold, italic, bullet lists, links"
        }
      ]
    },
    {
      "type": "images",
      "name": "Image Pair",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2 (optional — shows side by side)"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "View Pin Location on Google Maps"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "checkbox",
          "id": "new_tab",
          "label": "Open in new tab",
          "default": true
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title / Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#8BA4AC"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "address_color",
      "label": "Address Text Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "Divider Line Color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Content Width",
      "min": 800, "max": 1600, "step": 20, "unit": "px", "default": 1280
    },
    {
      "type": "range",
      "id": "left_col",
      "label": "Left Column Weight",
      "min": 1, "max": 3, "step": 1, "default": 2,
      "info": "Relative width — left vs right. e.g. 2 left / 3 right"
    },
    {
      "type": "range",
      "id": "right_col",
      "label": "Right Column Weight",
      "min": 1, "max": 4, "step": 1, "default": 3
    },
    {
      "type": "range",
      "id": "col_gap",
      "label": "Column Gap",
      "min": 16, "max": 100, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "left_gap",
      "label": "Left Column Item Gap",
      "min": 8, "max": 40, "step": 4, "unit": "px", "default": 16
    },
    {
      "type": "range",
      "id": "right_gap",
      "label": "Right Column Item Gap",
      "min": 8, "max": 48, "step": 4, "unit": "px", "default": 20
    },
    {
      "type": "range",
      "id": "sub_img_gap",
      "label": "Sub-image Gap",
      "min": 4, "max": 24, "step": 2, "unit": "px", "default": 10
    },
    {
      "type": "header",
      "content": "Padding — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom",
      "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72
    },
    {
      "type": "range",
      "id": "padding_h_desktop",
      "label": "Sides",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40
    },
    {
      "type": "header",
      "content": "Padding — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "padding_h_mobile",
      "label": "Sides",
      "min": 0, "max": 40, "step": 4, "unit": "px", "default": 20
    },
    {
      "type": "header",
      "content": "Left Column Images"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero / Portrait Image"
    },
    {
      "type": "image_picker",
      "id": "sub_image_1",
      "label": "Map / Screenshot 1"
    },
    {
      "type": "image_picker",
      "id": "sub_image_2",
      "label": "Map / Screenshot 2"
    },
    {
      "type": "header",
      "content": "Image Style"
    },
    {
      "type": "range",
      "id": "img_radius",

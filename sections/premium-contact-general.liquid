<style>
  .premium-general-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body);
  }

  .premium-general__header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem auto;
    padding: 0 2rem;
  }

  .premium-general__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    margin: 0 0 1rem 0;
    color: inherit;
  }

  .premium-general__subtext {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    opacity: 0.9;
    margin: 0;
  }

  .premium-general__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media screen and (min-width: 1024px) {
    .premium-general__container {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }

  .premium-general__form-card {
    background-color: {{ section.settings.card_bg_color }};
    padding: 3rem;
    border-radius: var(--border-radius, 8px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.05);
  }

  @media screen and (max-width: 767px) {
    .premium-general__form-card { padding: 2rem 1.5rem; }
  }

  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .premium-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 768px) {
    .premium-form__row { grid-template-columns: 1fr 1fr; }
  }

  .premium-form__field {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .premium-form__label {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
  }

  .premium-form__label span {
    font-weight: normal;
    opacity: 0.6;
    margin-left: 0.25rem;
  }

  .premium-form__input,
  .premium-form__textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0,0,0,0.2);
    color: {{ section.settings.text_color }};
    font-family: inherit;
    font-size: 1rem;
    padding: 0.5rem 0;
    transition: border-color 0.3s ease;
  }

  .premium-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .premium-form__input:focus,
  .premium-form__textarea:focus {
    outline: none;
    border-bottom-color: {{ section.settings.text_color }};
  }

  .premium-form__checkbox-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
  }

  .premium-form__checkbox {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 1px solid rgba(0,0,0,0.3);
    background: transparent;
    cursor: pointer;
    position: relative;
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .premium-form__checkbox:checked { border-color: {{ section.settings.text_color }}; }

  .premium-form__checkbox:checked::after {
    content: '✓';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 12px;
    color: {{ section.settings.text_color }};
  }

  .premium-form__checkbox-label {
    font-size: 0.9rem;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  .premium-form__submit {
    align-self: center;
    background: transparent;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    padding: 1rem 4rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
    width: 100%;
  }

  @media screen and (min-width: 768px) {
    .premium-form__submit { width: auto; }
  }

  .premium-form__submit:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.card_bg_color }};
  }

  .premium-general__image-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .premium-general__image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUpAnim {
    to { opacity: 1; transform: translateY(0); }
  }

  .premium-form__message {
    padding: 1rem;
    font-size: 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
    text-align: center;
  }
  .premium-form__message--success {
    background-color: rgba(46, 204, 113, 0.1);
    color: #27ae60;
    border: 1px solid #27ae60;
  }
  .premium-form__message--error {
    background-color: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid #c0392b;
  }
</style>

<div class="premium-general-{{ section.id }}">

  <div class="premium-general__header fade-up-anim">
    {%- if section.settings.heading != blank -%}
      <h2 class="premium-general__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="premium-general__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>

  <div class="premium-general__container">

    <div class="premium-general__form-card fade-up-anim" style="animation-delay: 150ms;">
      {%- form 'contact', id: 'GeneralContactForm-{{ section.id }}', class: 'premium-form' -%}

        {%- if form.posted_successfully? -%}
          <div class="premium-form__message premium-form__message--success" tabindex="-1" autofocus>
            {{ section.settings.success_message }}
          </div>

        {%- else -%}

          {%- if form.errors -%}
            <div class="premium-form__message premium-form__message--error" tabindex="-1" autofocus>
              Please adjust the following fields: {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="premium-form__row">
            <div class="premium-form__field">
              <label class="premium-form__label" for="GeneralForm-first-{{ section.id }}">
                {{ section.settings.label_first_name | default: 'First Name' }}
                <span>{{ section.settings.label_required | default: '(required)' }}</span>
              </label>
              <input type="text" id="GeneralForm-first-{{ section.id }}"
                     class="premium-form__input"
                     name="contact[First Name]"
                     autocomplete="given-name" required>
            </div>
            <div class="premium-form__field">
              <label class="premium-form__label" for="GeneralForm-last-{{ section.id }}">
                {{ section.settings.label_last_name | default: 'Last Name' }}
                <span>{{ section.settings.label_required | default: '(required)' }}</span>
              </label>
              <input type="text" id="GeneralForm-last-{{ section.id }}"
                     class="premium-form__input"
                     name="contact[Last Name]"
                     autocomplete="family-name" required>
            </div>
          </div>

          <div class="premium-form__field">
            <label class="premium-form__label" for="GeneralForm-email-{{ section.id }}">
              {{ section.settings.label_email | default: 'Email' }}
              <span>{{ section.settings.label_required | default: '(required)' }}</span>
            </label>
            <input type="email" id="GeneralForm-email-{{ section.id }}"
                   class="premium-form__input"
                   name="contact[email]"
                   autocomplete="email" required>
          </div>

          {%- comment -%}
            Checkbox fix: contact[tags] does nothing on a contact form.
            Using contact[Newsletter Signup] so the value shows clearly
            in the email you receive — easy to spot who wants updates.
          {%- endcomment -%}
          {%- if section.settings.show_checkbox -%}
            <label class="premium-form__checkbox-wrapper">
              <input type="checkbox"
                     id="GeneralForm-newsletter-{{ section.id }}"
                     class="premium-form__checkbox"
                     name="contact[Newsletter Signup]"
                     value="Yes">
              <span class="premium-form__checkbox-label">{{ section.settings.checkbox_label }}</span>
            </label>
          {%- endif -%}

          <div class="premium-form__field">
            <label class="premium-form__label" for="GeneralForm-subject-{{ section.id }}">
              {{ section.settings.label_subject | default: 'Subject' }}
              <span>{{ section.settings.label_required | default: '(required)' }}</span>
            </label>
            <input type="text" id="GeneralForm-subject-{{ section.id }}"
                   class="premium-form__input"
                   name="contact[Subject]" required>
          </div>

          <div class="premium-form__field">
            <label class="premium-form__label" for="GeneralForm-body-{{ section.id }}">
              {{ section.settings.label_message | default: 'Message' }}
              <span>{{ section.settings.label_required | default: '(required)' }}</span>
            </label>
            <textarea id="GeneralForm-body-{{ section.id }}"
                      class="premium-form__textarea"
                      name="contact[Message]" required></textarea>
          </div>

          <button type="submit" class="premium-form__submit">
            {{ section.settings.button_label }}
          </button>

        {%- endif -%}

      {%- endform -%}
    </div>

    <div class="premium-general__image-wrapper fade-up-anim" style="animation-delay: 300ms;">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                  {{ section.settings.image | image_url: width: 800 }} 800w"
          sizes="(max-width: 1023px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: 'Decorative Graphic' | escape }}"
          class="premium-general__image"
          loading="lazy"
        >
      {%- else -%}
        <div style="width: 100%; max-width: 500px; aspect-ratio: 1/1;">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg premium-general__image' }}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "General Contact & Graphic",
  "settings": [
    { "type": "text",        "id": "heading", "label": "Heading",    "default": "Questions?"       },
    { "type": "text",        "id": "subtext", "label": "Subheading", "default": "We are here to help!" },
    { "type": "image_picker","id": "image",   "label": "Decorative Graphic (Right Column)" },
    { "type": "header", "content": "Form Settings" },
    { "type": "checkbox", "id": "show_checkbox",    "label": "Show Newsletter Checkbox", "default": true },
    { "type": "text",     "id": "checkbox_label",   "label": "Checkbox Label",           "default": "Sign up for news and updates" },
    { "type": "text",     "id": "label_first_name", "label": "First Name Label",         "default": "First Name" },
    { "type": "text",     "id": "label_last_name",  "label": "Last Name Label",          "default": "Last Name"  },
    { "type": "text",     "id": "label_email",      "label": "Email Label",              "default": "Email"      },
    { "type": "text",     "id": "label_subject",    "label": "Subject Label",            "default": "Subject"    },
    { "type": "text",     "id": "label_message",    "label": "Message Label",            "default": "Message"    },
    { "type": "text",     "id": "label_required",   "label": "Required Text",            "default": "(required)" },
    { "type": "text",     "id": "button_label",     "label": "Submit Button Label",      "default": "Submit"     },
    { "type": "text",     "id": "success_message",  "label": "Success Message",          "default": "Thanks for reaching out! We will get back to you shortly." },
    { "type": "header", "content": "Colors & Spacing" },
    { "type": "color", "id": "bg_color",      "label": "Section Background", "default": "#EBEBEB" },
    { "type": "color", "id": "card_bg_color", "label": "Form Card Background","default": "#FFFFFF" },
    { "type": "color", "id": "text_color",    "label": "Text Color",         "default": "#1A1A1A" },
    { "type": "range", "id": "padding_top",    "label": "Top Padding",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [{ "name": "General Contact & Graphic" }]
}
{% endschema %}

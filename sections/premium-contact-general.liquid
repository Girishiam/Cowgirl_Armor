<style>
  /* ── Outer wrapper — full width, background lives here ── */
  .premium-general-outer-{{ section.id }} {
    width: 100%;
    {%- if section.settings.use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
    {%- else -%}
      background-color: {{ section.settings.bg_color }};
    {%- endif -%}
  }

  /* ── Inner — padding + color ── */
  .premium-general-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body);
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  /* ── Header ── */
  .premium-general__header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }

  .premium-general__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    color: inherit;
  }

  .premium-general__subtext {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    opacity: 0.88;
    margin: 0;
  }

  /* ── Layout grid ── */
  .premium-general__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media screen and (min-width: 1024px) {
    .premium-general__container { grid-template-columns: 1fr 1fr; gap: 6rem; }
  }

  /* ── Form card ── */
  .premium-general__form-card {
    padding: 3rem;
    border-radius: 10px;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.1);
      border: 1.5px solid rgba(255,255,255,0.25);
      box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    {%- else -%}
      background-color: {{ section.settings.card_bg_color }};
      border: 1px solid rgba(0,0,0,0.05);
      box-shadow: 0 20px 50px rgba(0,0,0,0.05);
    {%- endif -%}
  }

  @media screen and (max-width: 767px) {
    .premium-general__form-card { padding: 2rem 1.5rem; }
  }

  /* ── Form ── */
  .premium-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .premium-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 768px) {
    .premium-form__row { grid-template-columns: 1fr 1fr; }
  }

  .premium-form__field { display: flex; flex-direction: column; position: relative; }

  .premium-form__label {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    opacity: 0.9;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }
  .premium-form__label span { font-weight: normal; opacity: 0.6; margin-left: 0.25rem; }

  /* ── Inputs — full bordered box ── */
  .premium-form__input,
  .premium-form__textarea {
    width: 100%;
    font-family: inherit;
    font-size: 1rem;
    border-radius: 6px;
    padding: 0.85rem 1rem;
    transition: border-color 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    -webkit-appearance: none;
    appearance: none;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.12);
      border: 1.5px solid rgba(255,255,255,0.35);
      color: #FFFFFF;
      caret-color: #FFFFFF;
    {%- else -%}
      background: transparent;
      border: 1.5px solid rgba(0,0,0,0.18);
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  .premium-form__textarea { resize: vertical; min-height: 120px; }

  .premium-form__input:focus,
  .premium-form__textarea:focus {
    outline: none;
    {%- if section.settings.use_gradient -%}
      border-color: rgba(255,255,255,0.9);
      background: rgba(255,255,255,0.2);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.12);
    {%- else -%}
      border-color: {{ section.settings.text_color }};
      box-shadow: 0 0 0 3px rgba(139,82,212,0.12);
    {%- endif -%}
  }

  .premium-form__input::placeholder,
  .premium-form__textarea::placeholder {
    {%- if section.settings.use_gradient -%}
      color: rgba(255,255,255,0.45);
    {%- else -%}
      color: rgba(0,0,0,0.35);
    {%- endif -%}
  }

  /* ── Checkbox ── */
  .premium-form__checkbox-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
  }

  .premium-form__checkbox {
    appearance: none;
    width: 18px; height: 18px;
    border: 1.5px solid
      {%- if section.settings.use_gradient -%} rgba(255,255,255,0.5)
      {%- else -%} rgba(0,0,0,0.3){%- endif -%};
    background: transparent;
    cursor: pointer;
    position: relative;
    border-radius: 2px;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .premium-form__checkbox:checked {
    {%- if section.settings.use_gradient -%}
      background: #FFFFFF;
      border-color: #FFFFFF;
    {%- else -%}
      background: {{ section.settings.text_color }};
      border-color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  .premium-form__checkbox:checked::after {
    content: '✓';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 12px;
    {%- if section.settings.use_gradient -%}
      color: #8B52D4;
    {%- else -%}
      color: {{ section.settings.card_bg_color }};
    {%- endif -%}
  }

  .premium-form__checkbox-label {
    font-size: 0.9rem;
    opacity: 0.85;
    {%- if section.settings.use_gradient -%}
      color: #FFFFFF;
    {%- else -%}
      color: {{ section.settings.text_color }};
    {%- endif -%}
  }

  /* ── Submit ── */
  .premium-form__submit {
    align-self: center;
    width: 100%;
    padding: 1rem 4rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: opacity 0.25s ease, transform 0.2s ease, background-color 0.25s ease, color 0.25s ease;
    margin-top: 1rem;
    border-radius: 4px;
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.15);
      color: #FFFFFF;
      border: 1.5px solid rgba(255,255,255,0.5);
    {%- elsif section.settings.btn_use_gradient -%}
      background: var(--brand-gradient, linear-gradient(135deg, #3A6FE8 0%, #8B52D4 55%, #CC72E8 100%));
      color: #FFFFFF;
      border: none;
    {%- else -%}
      background: transparent;
      color: {{ section.settings.text_color }};
      border: 1.5px solid {{ section.settings.text_color }};
    {%- endif -%}
  }

  @media screen and (min-width: 768px) {
    .premium-form__submit { width: auto; }
  }

  .premium-form__submit:hover {
    transform: translateY(-2px);
    {%- if section.settings.use_gradient -%}
      background: rgba(255,255,255,0.28);
      border-color: #FFFFFF;
    {%- elsif section.settings.btn_use_gradient -%}
      opacity: 0.85;
    {%- else -%}
      background-color: {{ section.settings.text_color }};
      color: {{ section.settings.card_bg_color }};
    {%- endif -%}
  }

  /* ── Messages ── */
  .premium-form__message {
    padding: 1rem;
    font-size: 1rem;
    border-radius: 6px;
    margin-bottom: 1rem;
    text-align: center;
  }
  .premium-form__message--success {
    background-color: rgba(46,204,113,0.15);
    border: 1px solid rgba(46,204,113,0.5);
    {%- if section.settings.use_gradient -%}color: #FFFFFF;{%- else -%}color: #27ae60;{%- endif -%}
  }
  .premium-form__message--error {
    background-color: rgba(231,76,60,0.12);
    border: 1px solid rgba(231,76,60,0.4);
    color: #c0392b;
  }

  /* ── Right column image ── */
  .premium-general__image-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .premium-general__image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    {%- unless section.settings.use_gradient -%}
      mix-blend-mode: multiply;
    {%- endunless -%}
  }

  /* ── Animations ── */
  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUpAnim { to { opacity: 1; transform: translateY(0); } }
</style>

<div class="premium-general-outer-{{ section.id }}">
  <div class="premium-general-{{ section.id }}">

    <div class="premium-general__header fade-up-anim">
      {%- if section.settings.heading != blank -%}
        <h2 class="premium-general__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="premium-general__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="premium-general__container">

      <div class="premium-general__form-card fade-up-anim" style="animation-delay: 150ms;">
        {%- form 'contact', id: 'GeneralContactForm-{{ section.id }}', class: 'premium-form' -%}

          {%- if form.posted_successfully? -%}
            <div class="premium-form__message premium-form__message--success" tabindex="-1" autofocus>
              {{ section.settings.success_message }}
            </div>

          {%- else -%}

            {%- if form.errors -%}
              <div class="premium-form__message premium-form__message--error" tabindex="-1" autofocus>
                Please adjust the following fields: {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="premium-form__row">
              <div class="premium-form__field">
                <label class="premium-form__label" for="GeneralForm-first-{{ section.id }}">
                  {{ section.settings.label_first_name | default: 'First Name' }}
                  <span>{{ section.settings.label_required | default: '(required)' }}</span>
                </label>
                <input type="text" id="GeneralForm-first-{{ section.id }}"
                       class="premium-form__input"
                       name="contact[First Name]"
                       autocomplete="given-name" required>
              </div>
              <div class="premium-form__field">
                <label class="premium-form__label" for="GeneralForm-last-{{ section.id }}">
                  {{ section.settings.label_last_name | default: 'Last Name' }}
                  <span>{{ section.settings.label_required | default: '(required)' }}</span>
                </label>
                <input type="text" id="GeneralForm-last-{{ section.id }}"
                       class="premium-form__input"
                       name="contact[Last Name]"
                       autocomplete="family-name" required>
              </div>
            </div>

            <div class="premium-form__field">
              <label class="premium-form__label" for="GeneralForm-email-{{ section.id }}">
                {{ section.settings.label_email | default: 'Email' }}
                <span>{{ section.settings.label_required | default: '(required)' }}</span>
              </label>
              <input type="email" id="GeneralForm-email-{{ section.id }}"
                     class="premium-form__input"
                     name="contact[email]"
                     autocomplete="email" required>
            </div>

            {%- if section.settings.show_checkbox -%}
              <label class="premium-form__checkbox-wrapper">
                <input type="checkbox"
                       id="GeneralForm-newsletter-{{ section.id }}"
                       class="premium-form__checkbox"
                       name="contact[Newsletter Signup]"
                       value="Yes">
                <span class="premium-form__checkbox-label">{{ section.settings.checkbox_label }}</span>
              </label>
            {%- endif -%}

            <div class="premium-form__field">
              <label class="premium-form__label" for="GeneralForm-subject-{{ section.id }}">
                {{ section.settings.label_subject | default: 'Subject' }}
                <span>{{ section.settings.label_required | default: '(required)' }}</span>
              </label>
              <input type="text" id="GeneralForm-subject-{{ section.id }}"
                     class="premium-form__input"
                     name="contact[Subject]" required>
            </div>

            <div class="premium-form__field">
              <label class="premium-form__label" for="GeneralForm-body-{{ section.id }}">
                {{ section.settings.label_message | default: 'Message' }}
                <span>{{ section.settings.label_required | default: '(required)' }}</span>
              </label>
              <textarea id="GeneralForm-body-{{ section.id }}"
                        class="premium-form__textarea"
                        name="contact[Message]" required></textarea>
            </div>

            <button type="submit" class="premium-form__submit">
              {{ section.settings.button_label }}
            </button>

          {%- endif -%}

        {%- endform -%}
      </div>

      <div class="premium-general__image-wrapper fade-up-anim" style="animation-delay: 300ms;">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                    {{ section.settings.image | image_url: width: 800 }} 800w"
            sizes="(max-width: 1023px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: 'Decorative Graphic' | escape }}"
            class="premium-general__image"
            loading="lazy"
          >
        {%- else -%}
          <div style="width:100%;max-width:500px;aspect-ratio:1/1;">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg premium-general__image' }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "General Contact & Graphic",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use brand gradient background",
      "default": false,
      "info": "Spans full width. Form card becomes frosted glass. All text and inputs auto-switch to white."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background (if not gradient)",
      "default": "#F8F6F4"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Form Card Background (if not gradient)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (if not gradient)",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Content"
    },
    { "type": "text",         "id": "heading", "label": "Heading",    "default": "Questions?"        },
    { "type": "text",         "id": "subtext", "label": "Subheading", "default": "We are here to help!" },
    { "type": "image_picker", "id": "image",   "label": "Decorative Graphic (Right Column)" },

    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "checkbox",
      "id": "btn_use_gradient",
      "label": "Use brand gradient on button",
      "default": true,
      "info": "Ignored when section background is gradient — button auto-adapts to frosted glass."
    },

    {
      "type": "header",
      "content": "Form Settings"
    },
    { "type": "checkbox", "id": "show_checkbox",    "label": "Show Newsletter Checkbox", "default": true },
    { "type": "text",     "id": "checkbox_label",   "label": "Checkbox Label",           "default": "Sign up for news and updates" },
    { "type": "text",     "id": "label_first_name", "label": "First Name Label",         "default": "First Name" },
    { "type": "text",     "id": "label_last_name",  "label": "Last Name Label",          "default": "Last Name"  },
    { "type": "text",     "id": "label_email",      "label": "Email Label",              "default": "Email"      },
    { "type": "text",     "id": "label_subject",    "label": "Subject Label",            "default": "Subject"    },
    { "type": "text",     "id": "label_message",    "label": "Message Label",            "default": "Message"    },
    { "type": "text",     "id": "label_required",   "label": "Required Text",            "default": "(required)" },
    { "type": "text",     "id": "button_label",     "label": "Submit Button Label",      "default": "Submit"     },
    { "type": "text",     "id": "success_message",  "label": "Success Message",
      "default": "Thanks for reaching out! We will get back to you shortly." },

    {
      "type": "header",
      "content": "Spacing"
    },
    { "type": "range", "id": "padding_top",    "label": "Top Padding",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 100 }
  ],
  "presets": [{ "name": "General Contact & Graphic" }]
}
{% endschema %}

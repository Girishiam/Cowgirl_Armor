<style>
  .premium-collection-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .premium-product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 768px) {
    .premium-product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-product-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 4rem 3rem;
    }
  }

  .premium-product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    group: hover;
  }

  .premium-product-card__link {
    text-decoration: none;
    color: {{ section.settings.text_color }};
    flex-grow: 1;
  }

  .premium-product-card__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.image_ratio }};
    background-color: rgba(0,0,0,0.03);
    overflow: hidden;
    margin-bottom: 1.5rem;
    border-radius: var(--border-radius);
  }

  .premium-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .premium-product-card:hover .premium-product-card__image {
    transform: scale(1.04);
  }

  .premium-product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .premium-product-card__title {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
  }

  .premium-product-card__price {
    font-family: var(--font-body);
    font-size: 1rem;
    opacity: 0.8;
  }

  /* Premium Add to Cart Form */
  .premium-product-card__form {
    margin-top: auto; /* Pushes button to bottom to align grids */
  }

  .premium-add-btn {
    width: 100%;
    padding: 0.8rem 1rem;
    background-color: transparent;
    color: {{ section.settings.text_color }};
    border: 1px solid {{ section.settings.text_color }};
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .premium-add-btn:hover:not([disabled]) {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  .premium-add-btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
    border-color: rgba(0,0,0,0.2);
  }
</style>

<div class="premium-collection-{{ section.id }}">
  {%- assign current_collection = section.settings.collection | default: collection -%}

  {%- paginate current_collection.products by section.settings.products_per_page -%}
    <div class="premium-product-grid">
      {%- for product in current_collection.products -%}
        <div
          class="premium-product-card fade-up-anim"
          style="animation-delay: {{ forloop.index0 | times: 50 | modulo: 300 }}ms;"
        >
          <a href="{{ product.url | within: current_collection }}" class="premium-product-card__link">
            <div class="premium-product-card__image-wrapper">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="premium-product-card__image"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'premium-product-card__image placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="premium-product-card__info">
              <h3 class="premium-product-card__title">{{ product.title }}</h3>
              <div class="premium-product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span style="text-decoration: line-through; opacity: 0.5; margin-right: 0.5rem;">
                    {{- product.compare_at_price | money -}}
                  </span>
                {%- endif -%}
                <span>{{ product.price | money }}</span>
              </div>
            </div>
          </a>

          {%- form 'product', product, class: 'premium-product-card__form' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button
              type="submit"
              name="add"
              class="premium-add-btn"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {%- if product.available -%}
                Add to Cart
              {%- else -%}
                Sold Out
              {%- endif -%}
            </button>
          {%- endform -%}
        </div>
      {%- else -%}
        {%- for i in (1..section.settings.products_per_page) -%}
          <div class="premium-product-card">
            <div class="premium-product-card__image-wrapper">
              {{ 'product-' | append: i | placeholder_svg_tag: 'premium-product-card__image placeholder-svg' }}
            </div>
            <div class="premium-product-card__info">
              <h3 class="premium-product-card__title">Premium Cowgirl Product</h3>
              <div class="premium-product-card__price">$29.99</div>
            </div>
            <button class="premium-add-btn" disabled>Add to Cart</button>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div style="margin-top: 4rem; text-align: center; font-family: var(--font-body);">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Premium Product Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave blank if using on a default Collection template."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "2 / 3", "label": "Tall Portrait (2:3)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "label": "Products per page",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Premium Product Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}

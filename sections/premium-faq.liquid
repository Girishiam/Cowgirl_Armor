<style>
  .premium-faq-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    overflow: hidden;
  }

  .premium-faq__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }

  .premium-faq__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .premium-faq__container {
    position: relative;
    z-index: 3;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media screen and (min-width: 1024px) {
    .premium-faq__container {
      grid-template-columns: 1fr 1.5fr;
      gap: 6rem;
      align-items: flex-start;
    }
  }

  /* Left Side: Heading */
  .premium-faq__header-col {
    position: sticky;
    top: 120px;
  }

  .premium-faq__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    color: inherit;
  }

  .premium-faq__subtext {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  /* Right Side: Accordion */
  .premium-faq__accordion-col {
    display: flex;
    flex-direction: column;
  }

  .premium-faq__item {
    border-bottom: 1px solid rgba(0,0,0,0.15); /* Adjust opacity based on text color */
  }

  /* Use currentColor with opacity for dynamic border colors */
  .premium-faq-{{ section.id }} .premium-faq__item {
    border-color: color-mix(in srgb, {{ section.settings.text_color }} 20%, transparent);
  }

  .premium-faq__question {
    width: 100%;
    background: transparent;
    border: none;
    padding: 2rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: inherit;
    text-align: left;
    transition: opacity 0.3s ease;
  }

  .premium-faq__question:hover {
    opacity: 0.7;
  }

  .premium-faq__icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-left: 1.5rem;
  }

  .premium-faq__icon::before,
  .premium-faq__icon::after {
    content: '';
    position: absolute;
    background-color: currentColor;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Horizontal line of the + */
  .premium-faq__icon::before {
    top: 9px;
    left: 0;
    width: 20px;
    height: 2px;
  }

  /* Vertical line of the + */
  .premium-faq__icon::after {
    top: 0;
    left: 9px;
    width: 2px;
    height: 20px;
  }

  /* When Active, rotate vertical line to horizontal to make a minus */
  .premium-faq__item.is-active .premium-faq__icon::after {
    transform: rotate(90deg);
  }

  /* Smooth Grid Transition for Accordion Body */
  .premium-faq__answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .premium-faq__item.is-active .premium-faq__answer-wrapper {
    grid-template-rows: 1fr;
  }

  .premium-faq__answer-inner {
    overflow: hidden;
  }

  .premium-faq__answer-content {
    padding-bottom: 2rem;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    opacity: 0.9;
  }
</style>

<div class="premium-faq-{{ section.id }}">
  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 2000 }}"
      alt="{{ section.settings.heading | escape }}"
      class="premium-faq__bg"
      loading="lazy"
    >
  {%- endif -%}

  <div class="premium-faq__overlay"></div>

  <div class="premium-faq__container">
    <div class="premium-faq__header-col fade-up-anim">
      {%- if section.settings.heading != blank -%}
        <h2 class="premium-faq__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <div class="premium-faq__subtext">{{ section.settings.subtext }}</div>
      {%- endif -%}
    </div>

    <div class="premium-faq__accordion-col">
      {%- for block in section.blocks -%}
        <div
          class="premium-faq__item fade-up-anim"
          style="animation-delay: {{ forloop.index0 | times: 100 }}ms;"
          {{ block.shopify_attributes }}
        >
          <button class="premium-faq__question" aria-expanded="false" aria-controls="faq-answer-{{ block.id }}">
            <span>{{ block.settings.question }}</span>
            <div class="premium-faq__icon"></div>
          </button>

          <div class="premium-faq__answer-wrapper" id="faq-answer-{{ block.id }}">
            <div class="premium-faq__answer-inner">
              <div class="premium-faq__answer-content">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqContainer = document.querySelector('.premium-faq-{{ section.id }}');
    if (!faqContainer) return;

    const questions = faqContainer.querySelectorAll('.premium-faq__question');

    questions.forEach(question => {
      question.addEventListener('click', function() {
        const item = this.closest('.premium-faq__item');
        const isActive = item.classList.contains('is-active');

        // Optional: Close all other accordions (Premium feel)
        {% if section.settings.close_others %}
          faqContainer.querySelectorAll('.premium-faq__item').forEach(otherItem => {
            otherItem.classList.remove('is-active');
            otherItem.querySelector('.premium-faq__question').setAttribute('aria-expanded', 'false');
          });
        {% endif %}

        // Toggle clicked item
        if (!isActive) {
          item.classList.add('is-active');
          this.setAttribute('aria-expanded', 'true');
        } else {
          item.classList.remove('is-active');
          this.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Premium FAQ / Accordion",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Find out more about our mission and where your support goes.</p>"
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "Close other items when one is opened",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback Background Color",
      "default": "#E2E2E2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Image Overlay Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Overlay Opacity",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Is your non-profit a 501(c)3?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Provide a detailed answer here to help your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium FAQ / Accordion",
      "category": "Text",
      "blocks": [{ "type": "faq" }, { "type": "faq" }, { "type": "faq" }]
    }
  ]
}
{% endschema %}

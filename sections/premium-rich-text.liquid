<style>
  .premium-rich-text-{{ section.id }} {
    --section-bg-color: {{ section.settings.bg_color }};
    --section-text-color: {{ section.settings.text_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --content-width: {{ section.settings.content_width }}px;
    --link-color: {{ section.settings.link_color }};

    background-color: var(--section-bg-color);
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    color: var(--section-text-color);
    display: flex;
    justify-content: center;
    text-align: {{ section.settings.text_alignment }};
    position: relative;
    overflow: hidden;
  }

  {%- if section.settings.enable_bg_pattern -%}
  .premium-rich-text-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: {{ section.settings.bg_pattern }};
    opacity: {{ section.settings.bg_pattern_opacity | divided_by: 100.0 }};
    z-index: 0;
  }
  {%- endif -%}

  .premium-rich-text__container {
    max-width: var(--content-width);
    width: 100%;
    padding: 0 {{ section.settings.padding_horizontal_mobile }}px;
    position: relative;
    z-index: 1;
    {%- if section.settings.enable_columns -%}
    column-count: {{ section.settings.column_count_mobile }};
    column-gap: {{ section.settings.column_gap }}px;
    {%- endif -%}
  }

  @media screen and (min-width: 768px) {
    .premium-rich-text__container {
      padding: 0 {{ section.settings.padding_horizontal_tablet }}px;
      {%- if section.settings.enable_columns -%}
      column-count: {{ section.settings.column_count_tablet }};
      {%- endif -%}
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-rich-text__container {
      padding: 0 {{ section.settings.padding_horizontal }}px;
      {%- if section.settings.enable_columns -%}
      column-count: {{ section.settings.column_count }};
      {%- endif -%}
    }
  }

  .premium-rich-text__heading {
    font-family: var(--font-heading);
    font-size: clamp(
      {{ section.settings.heading_font_size_mobile }}px,
      {{ section.settings.heading_font_size_vw }}vw,
      {{ section.settings.heading_font_size }}px
    );
    margin-top: 0;
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    line-height: {{ section.settings.heading_line_height }};
    color: inherit;
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    text-transform: {{ section.settings.heading_text_transform }};
    {%- if section.settings.enable_columns -%}
    column-span: all;
    {%- endif -%}
  }

  {%- if section.settings.enable_drop_cap -%}
  .premium-rich-text__text > p:first-of-type::first-letter {
    float: left;
    font-size: {{ section.settings.drop_cap_size }}em;
    line-height: {{ section.settings.drop_cap_line_height }};
    font-weight: {{ section.settings.drop_cap_font_weight }};
    margin: {{ section.settings.drop_cap_margin_top }}px {{ section.settings.drop_cap_margin_right }}px {{ section.settings.drop_cap_margin_bottom }}px 0;
    color: {{ section.settings.drop_cap_color }};
  }
  {%- endif -%}

  .premium-rich-text__text {
    font-family: var(--font-body);
    font-size: clamp(
      {{ section.settings.text_font_size_mobile }}px,
      {{ section.settings.text_font_size_vw }}vw,
      {{ section.settings.text_font_size }}px
    );
    line-height: {{ section.settings.text_line_height }};
    opacity: {{ section.settings.text_opacity | divided_by: 100.0 }};
    color: inherit;
    font-weight: {{ section.settings.text_font_weight }};
  }

  .premium-rich-text__text p {
    margin-bottom: {{ section.settings.paragraph_spacing }}px;
  }

  .premium-rich-text__text p:last-child {
    margin-bottom: 0;
  }

  .premium-rich-text__text h2,
  .premium-rich-text__text h3,
  .premium-rich-text__text h4 {
    font-family: var(--font-heading);
    margin-top: {{ section.settings.subheading_margin_top }}px;
    margin-bottom: {{ section.settings.subheading_margin_bottom }}px;
    line-height: {{ section.settings.subheading_line_height }};
    font-weight: {{ section.settings.subheading_font_weight }};
    {%- if section.settings.enable_columns -%}
    column-span: all;
    {%- endif -%}
  }

  .premium-rich-text__text h2 {
    font-size: {{ section.settings.h2_font_size }}px;
  }

  .premium-rich-text__text h3 {
    font-size: {{ section.settings.h3_font_size }}px;
  }

  .premium-rich-text__text h4 {
    font-size: {{ section.settings.h4_font_size }}px;
  }

  .premium-rich-text__text a {
    color: var(--link-color);
    text-decoration: {{ section.settings.link_decoration }};
    text-underline-offset: {{ section.settings.link_underline_offset }}px;
    transition: opacity {{ section.settings.link_hover_duration }}ms ease;
  }

  .premium-rich-text__text a:hover {
    opacity: {{ section.settings.link_hover_opacity | divided_by: 100.0 }};
  }

  .premium-rich-text__text strong {
    font-weight: {{ section.settings.bold_font_weight }};
  }

  .premium-rich-text__text em {
    font-style: italic;
  }

  .premium-rich-text__text ul,
  .premium-rich-text__text ol {
    margin: {{ section.settings.list_margin_vertical }}px 0;
    padding-left: {{ section.settings.list_padding_left }}px;
  }

  .premium-rich-text__text li {
    margin-bottom: {{ section.settings.list_item_spacing }}px;
  }

  .premium-rich-text__text blockquote {
    border-left: {{ section.settings.blockquote_border_width }}px solid {{ section.settings.blockquote_border_color }};
    padding-left: {{ section.settings.blockquote_padding_left }}px;
    margin: {{ section.settings.blockquote_margin_vertical }}px 0;
    font-style: {{ section.settings.blockquote_font_style }};
    font-size: {{ section.settings.blockquote_font_size }}px;
    opacity: {{ section.settings.blockquote_opacity | divided_by: 100.0 }};
    {%- if section.settings.enable_columns -%}
    column-span: all;
    {%- endif -%}
  }

  .premium-rich-text__divider {
    width: {{ section.settings.divider_width }}%;
    height: {{ section.settings.divider_height }}px;
    background-color: {{ section.settings.divider_color }};
    border: none;
    margin: {{ section.settings.divider_margin_vertical }}px auto;
    opacity: {{ section.settings.divider_opacity | divided_by: 100.0 }};
    {%- if section.settings.enable_columns -%}
    column-span: all;
    {%- endif -%}
  }

  .premium-rich-text__button {
    display: inline-block;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    transition:
      background-color {{ section.settings.button_hover_duration }}ms ease,
      color {{ section.settings.button_hover_duration }}ms ease,
      transform {{ section.settings.button_hover_duration }}ms ease;
    margin-top: {{ section.settings.button_margin_top }}px;
    text-transform: {{ section.settings.button_text_transform }};
    letter-spacing: {{ section.settings.button_letter_spacing }}px;
    {%- if section.settings.enable_columns -%}
    column-span: all;
    {%- endif -%}
  }

  .premium-rich-text__button:hover {
    background-color: {{ section.settings.button_hover_bg_color }};
    color: {{ section.settings.button_hover_text_color }};
    transform: translateY({{ section.settings.button_hover_lift }}px);
  }

  /* Scroll Animation */
  .premium-rich-text-animate {
    opacity: 0;
    transform: translateY({{ section.settings.animation_distance }}px);
    transition:
      opacity {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }},
      transform {{ section.settings.animation_duration }}ms {{ section.settings.animation_easing }};
  }

  .premium-rich-text-animate.animated {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger delays */
  .premium-rich-text-animate:nth-child(1) { transition-delay: 0ms; }
  .premium-rich-text-animate:nth-child(2) { transition-delay: {{ section.settings.animation_stagger }}ms; }
  .premium-rich-text-animate:nth-child(3) { transition-delay: calc({{ section.settings.animation_stagger }}ms * 2); }
  .premium-rich-text-animate:nth-child(4) { transition-delay: calc({{ section.settings.animation_stagger }}ms * 3); }
</style>

<div class="premium-rich-text-{{ section.id }}">
  <div class="premium-rich-text__container premium-rich-text-animate">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="premium-rich-text__heading" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h2>
          {%- endif -%}

        {%- when 'text' -%}
          {%- if block.settings.text != blank -%}
            <div class="premium-rich-text__text" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- endif -%}

        {%- when 'divider' -%}
          <hr class="premium-rich-text__divider" {{ block.shopify_attributes }}>

        {%- when 'button' -%}
          {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
            <a href="{{ block.settings.button_link }}" class="premium-rich-text__button" {{ block.shopify_attributes }}>
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const animateElements = document.querySelectorAll('.premium-rich-text-' + sectionId + ' .premium-rich-text-animate');

  if (!animateElements.length) return;

  const observerOptions = {
    threshold: {{ section.settings.animation_threshold | divided_by: 100.0 }},
    rootMargin: '{{ section.settings.animation_root_margin }}px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animated');
        {%- if section.settings.animation_once -%}
        observer.unobserve(entry.target);
        {%- endif -%}
      } else {
        {%- unless section.settings.animation_once -%}
        entry.target.classList.remove('animated');
        {%- endunless -%}
      }
    });
  }, observerOptions);

  animateElements.forEach(el => observer.observe(el));
})();
</script>


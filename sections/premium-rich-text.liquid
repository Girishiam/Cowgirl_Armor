<style>
  .premium-rich-text-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: {{ section.settings.text_color }};
    display: flex;
    justify-content: center;
    text-align: {{ section.settings.text_alignment }};
  }

  .premium-rich-text__container {
    max-width: {{ section.settings.content_width }}px;
    width: 100%;
    padding: 0 2rem;
  }

  .premium-rich-text__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    margin-top: 0;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: inherit;
    letter-spacing: 0.02em;
  }

  .premium-rich-text__text {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.8;
    opacity: 0.9;
    color: inherit;
  }

  .premium-rich-text__text p {
    margin-bottom: 1.5rem;
  }

  .premium-rich-text__text p:last-child {
    margin-bottom: 0;
  }

  .premium-rich-text__text a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.3s ease;
  }

  .premium-rich-text__text a:hover {
    opacity: 0.6;
  }

  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<div class="premium-rich-text-{{ section.id }}">
  <div class="premium-rich-text__container fade-up-anim">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <h2 class="premium-rich-text__heading" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
          </h2>

        {%- when 'text' -%}
          <div class="premium-rich-text__text" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Premium Rich Text",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum Content Width",
      "default": 800,
      "info": "Keeping this narrower makes paragraphs easier to read on large screens."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Be The Light Pink Memorial Cap"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Content",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Honor Oaklynn Rae Domer with the Be The Light pink memorial cap. 100% of proceeds donated to Rope Like A Girl Foundation. #LoveLikeOaklynn</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Rich Text",
      "category": "Text",
      "blocks": [{ "type": "heading" }, { "type": "text" }]
    }
  ]
}
{% endschema %}

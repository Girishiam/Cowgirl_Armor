<style>
  .premium-coll-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  /* --- Optional Marquee Styling --- */
  .premium-marquee {
    background-color: {{ section.settings.marquee_bg }};
    color: {{ section.settings.marquee_text_color }};
    padding: 0.8rem 0;
    overflow: hidden;
    white-space: nowrap;
    display: flex;
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    margin-bottom: 4rem;
  }

  .premium-marquee__content {
    display: flex;
    gap: 3rem;
    padding-right: 3rem;
    animation: marqueeScroll {{ section.settings.marquee_speed }}s linear infinite;
    font-family: var(--font-body);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  /* --- Collection Header --- */
  .premium-coll__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .premium-coll__header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media screen and (min-width: 768px) {
    .premium-coll__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .premium-coll__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .premium-coll__shop-all {
    display: inline-block;
    padding: 0.8rem 3rem;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .premium-coll__shop-all:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* --- Product Grid --- */
  .premium-coll__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 768px) {
    .premium-coll__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .premium-coll__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 3rem 2rem;
    }
  }

  /* --- Product Card (Inline Form matching screenshot) --- */
  .premium-card {
    display: flex;
    flex-direction: column;
    color: {{ section.settings.text_color }};
  }

  .premium-card__image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: rgba(0,0,0,0.03);
    margin-bottom: 1rem;
  }

  .premium-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .premium-card:hover .premium-card__image {
    transform: scale(1.05);
  }

  .premium-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .premium-card__title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    line-height: 1.3;
  }

  .premium-card__price {
    font-family: var(--font-body);
    font-size: 0.95rem;
    opacity: 0.8;
  }

  /* The Inline Action Row */
  .premium-card__action-row {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    width: 100%;
  }

  .premium-card__qty {
    display: flex;
    align-items: center;
    border: 1px solid rgba(0,0,0,0.2);
    width: 35%; /* Keeps it small on the left */
  }

  .premium-card__qty-btn {
    background: transparent;
    border: none;
    width: 30%;
    height: 100%;
    cursor: pointer;
    font-size: 1.1rem;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .premium-card__qty-input {
    width: 40%;
    border: none;
    background: transparent;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: inherit;
    -moz-appearance: textfield;
    padding: 0;
  }

  .premium-card__qty-input::-webkit-outer-spin-button,
  .premium-card__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .premium-card__add-btn {
    flex-grow: 1; /* Takes up the rest of the space */
    background: transparent;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    font-family: var(--font-body);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0.8rem 0;
  }

  .premium-card__add-btn:hover:not([disabled]) {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  .premium-card__add-btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .fade-up-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUpAnim 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeUpAnim {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="premium-coll-{{ section.id }}">
  {%- if section.settings.show_marquee and section.settings.marquee_text != blank -%}
    <div class="premium-marquee">
      <div class="premium-marquee__content">{{ section.settings.marquee_text }}</div>
      <div class="premium-marquee__content">{{ section.settings.marquee_text }}</div>
      <div class="premium-marquee__content">{{ section.settings.marquee_text }}</div>
    </div>
  {%- endif -%}

  <div class="premium-coll__container">
    <div class="premium-coll__header fade-up-anim">
      <h2 class="premium-coll__title">
        {{ section.settings.title | default: collection.title | default: 'The Collection' }}
      </h2>

      {%- if section.settings.show_view_all -%}
        <a
          href="{{ section.settings.collection.url | default: routes.all_products_collection_url }}"
          class="premium-coll__shop-all"
        >
          {{ section.settings.shop_all_text | default: 'Shop All' | escape }}
        </a>
      {%- endif -%}
    </div>

    {%- assign target_collection = section.settings.collection | default: collection -%}

    <div class="premium-coll__grid">
      {%- for product in target_collection.products limit: section.settings.product_limit -%}
        <div
          class="premium-card fade-up-anim"
          style="animation-delay: {{ forloop.index0 | times: 100 | modulo: 400 }}ms;"
        >
          <a href="{{ product.url }}" class="premium-card__image-wrapper">
            {%- if product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="premium-card__image"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'premium-card__image placeholder-svg' }}
            {%- endif -%}
          </a>

          <div class="premium-card__info">
            <a href="{{ product.url }}" class="premium-card__title">{{ product.title }}</a>
            <div class="premium-card__price">{{ product.price | money }}</div>
          </div>

          {%- form 'product', product, class: 'premium-card__action-row' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            <div class="premium-card__qty">
              <button type="button" class="premium-card__qty-btn" onclick="this.nextElementSibling.stepDown()">
                −
              </button>
              <input type="number" name="quantity" class="premium-card__qty-input" value="1" min="1">
              <button type="button" class="premium-card__qty-btn" onclick="this.previousElementSibling.stepUp()">
                +
              </button>
            </div>

            <button
              type="submit"
              name="add"
              class="premium-card__add-btn"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {%- if product.available -%}
                {{ section.settings.button_add_to_cart | default: 'Add to cart' | escape }}
              {%- else -%}
                {{ section.settings.button_sold_out | default: 'Sold Out' | escape }}
              {%- endif -%}
            </button>
          {%- endform -%}
        </div>

      {%- else -%}
        {%- for i in (1..section.settings.columns_desktop) -%}
          <div class="premium-card">
            <div class="premium-card__image-wrapper">
              {{ 'product-' | append: i | placeholder_svg_tag: 'premium-card__image placeholder-svg' }}
            </div>
            <div class="premium-card__info">
              <span class="premium-card__title">Fashion Ribbon Ball Cap</span>
              <div class="premium-card__price">$29.99</div>
            </div>
            <div class="premium-card__action-row">
              <div class="premium-card__qty">
                <button type="button" class="premium-card__qty-btn">−</button>
                <input type="number" class="premium-card__qty-input" value="1">
                <button type="button" class="premium-card__qty-btn">+</button>
              </div>
              <button class="premium-card__add-btn" disabled>Add to cart</button>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Collection Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Display"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Cowgirl Armor- The OG Collection"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'Shop All' button",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_all_text",
      "label": "'Shop All' Button Text",
      "default": "Shop All"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 24,
      "step": 4,
      "label": "Maximum products to show",
      "default": 8
    },
    {
      "type": "header",
      "content": "Marquee Banner (Optional)"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show Scrolling Marquee",
      "default": true
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "❖ The Shield of Faith ❖ Sword of the Spirit ❖ The Helmet of Salvation ❖ Pray Boldly"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 20
    },
    {
      "type": "color",
      "id": "marquee_bg",
      "label": "Marquee Background",
      "default": "#E2E2E2"
    },
    {
      "type": "color",
      "id": "marquee_text_color",
      "label": "Marquee Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Product Card Texts"
    },
    {
      "type": "text",
      "id": "button_add_to_cart",
      "label": "Add to Cart Text",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "button_sold_out",
      "label": "Sold Out Text",
      "default": "Sold Out"
    }
  ],
  "presets": [
    {
      "name": "Premium Collection Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}

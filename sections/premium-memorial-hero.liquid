    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Button Font Size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "btn_font_weight",
      "label": "Button Font Weight",
      "min": 400,
      "max": 700,
      "step": 100,

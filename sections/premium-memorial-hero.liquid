    {
      "type": "checkbox",
      "id": "enable_text_shadow",
      "label": "Text shadow for readability",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Memorial Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}

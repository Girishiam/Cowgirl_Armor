      "min": 80,
      "max": 160,
      "step": 5,
      "unit": "%",
      "default": 110,
      "info": "e.g. 110 = 1.1"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "label": "Title Letter Spacing",
      "min": -5,
      "max": 20,
      "step": 1,
      "default": -1,
      "info": "Divide by 100 for em value — e.g. -1 = -0.01em, 5 = 0.05em"
    },
    {
      "type": "range",
      "id": "title_gap",
      "label": "Gap Below Title",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "#LoveLikeOaklynn"
    },
    {
      "type": "range",
      "id": "subtitle_size_min",
      "label": "Subtitle Size — Min",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subtitle_size_max",
      "label": "Subtitle Size — Max",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "subtitle_weight",
      "label": "Subtitle Font Weight",
      "min": 300,
      "max": 700,
      "step": 100,
      "default": 400
    },
    {
      "type": "range",
      "id": "subtitle_spacing",
      "label": "Subtitle Letter Spacing",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 5,
      "info": "Divide by 100 for em value — e.g. 5 = 0.05em"
    },
    {
      "type": "range",
      "id": "subtitle_opacity",
      "label": "Subtitle Opacity",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "subtitle_gap",
      "label": "Gap Below Subtitle",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",

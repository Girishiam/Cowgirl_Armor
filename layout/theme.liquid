<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_bg }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {%- comment -%} Social Media Meta Tags {%- endcomment -%}
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:type" content="website">
    <meta property="og:description" content="{{ page_description | escape }}">
    {%- if page_image -%}
      <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    {%- endif -%}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | escape }}">
    <meta name="twitter:description" content="{{ page_description | escape }}">

    {{ content_for_header }}

    {%- comment -%} Preconnect for performance {%- endcomment -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="dns-prefetch" href="https://productreviews.shopifycdn.com">

    {%- comment -%} Load fonts {%- endcomment -%}
    {%- unless settings.type_header_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_body_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    {%- assign header_font_bold = settings.type_header_font | font_modify: 'weight', 'bolder' -%}
    {%- assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bolder' -%}
    {%- assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic' -%}
    {%- assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic' -%}

    <style>
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
      {%- if body_font_bold -%}{{ body_font_bold | font_face: font_display: 'swap' }}{%- endif -%}
      {%- if body_font_italic -%}{{ body_font_italic | font_face: font_display: 'swap' }}{%- endif -%}
      {%- if body_font_bold_italic -%}{{ body_font_bold_italic | font_face: font_display: 'swap' }}{%- endif -%}
      {%- if header_font_bold -%}{{ header_font_bold | font_face: font_display: 'swap' }}{%- endif -%}

      :root {
        {%- comment -%} Colors {%- endcomment -%}
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-accent: {{ settings.color_accent }};
        --color-secondary: {{ settings.color_secondary }};
        --color-border: {{ settings.color_border }};
        --color-error: {{ settings.color_error }};
        --color-success: {{ settings.color_success }};

        {%- comment -%} Button Colors {%- endcomment -%}
        --color-button: {{ settings.color_button }};
        --color-button-text: {{ settings.color_button_text }};
        --color-button-hover: {{ settings.color_button_hover }};

        {%- comment -%} Typography {%- endcomment -%}
        --font-heading-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --heading-scale: {{ settings.heading_scale | divided_by: 100.0 }};
        --body-scale: {{ settings.body_scale | divided_by: 100.0 }};
        --font-size-base-px: {{ settings.font_size_base }}px;
        --heading-weight: {{ settings.heading_weight }};
        --heading-text-transform: {{ settings.heading_text_transform }};
        --heading-letter-spacing: {{ settings.heading_letter_spacing }}px;
        --heading-line-height: {{ settings.heading_line_height | divided_by: 100.0 }};
        --body-weight: {{ settings.body_weight }};
        --body-letter-spacing: {{ settings.body_letter_spacing }}px;
        --body-line-height: {{ settings.body_line_height | divided_by: 100.0 }};

        {%- comment -%} Page Layout {%- endcomment -%}
        --page-width: {{ settings.page_width }}px;
        --content-width: {{ settings.content_width }}px;

        {%- comment -%} Spacing {%- endcomment -%}
        --spacing-sections: {{ settings.spacing_sections }}px;
        --spacing-grid-horizontal: {{ settings.spacing_grid_horizontal }}px;
        --spacing-grid-vertical: {{ settings.spacing_grid_vertical }}px;

        {%- comment -%} Border & Corners {%- endcomment -%}
        --border-radius: {{ settings.border_radius }}px;
        --border-thickness: {{ settings.border_thickness }}px;
        --border-opacity: {{ settings.border_opacity | divided_by: 100.0 }};
        --buttons-radius: {{ settings.buttons_radius }}px;
        --buttons-border-thickness: {{ settings.buttons_border_thickness }}px;

        {%- comment -%} Shadows {%- endcomment -%}
        --shadow-opacity: {{ settings.shadow_opacity | divided_by: 100.0 }};
        --shadow-blur: {{ settings.shadow_blur }}px;

        {%- comment -%} Logo {%- endcomment -%}
        --logo-width: {{ settings.logo_width }}px;

        {%- comment -%} Badges {%- endcomment -%}
        --badge-sale-bg: {{ settings.badge_sale_bg }};
        --badge-sale-text: {{ settings.badge_sale_text }};
        --badge-sold-out-bg: {{ settings.badge_sold_out_bg }};
        --badge-sold-out-text: {{ settings.badge_sold_out_text }};
        --badge-corner-radius: {{ settings.badge_corner_radius }}px;

        {%- comment -%} Drawers {%- endcomment -%}
        --drawer-overlay-opacity: {{ settings.drawer_overlay_opacity | divided_by: 100.0 }};
        --drawer-overlay-color: {{ settings.drawer_overlay_color }};

        {%- comment -%} Icons {%- endcomment -%}
        --icon-size: {{ settings.icon_size }}px;

        {%- comment -%} Input Fields {%- endcomment -%}
        --inputs-radius: {{ settings.inputs_radius }}px;
        --inputs-border-thickness: {{ settings.inputs_border_thickness }}px;
        --inputs-bg: {{ settings.inputs_bg }};
        --inputs-border-color: {{ settings.inputs_border_color }};
        --inputs-focus-color: {{ settings.inputs_focus_color }};

        {%- comment -%} Popovers & Modals {%- endcomment -%}
        --popup-border-radius: {{ settings.popup_border_radius }}px;
        --popup-border-thickness: {{ settings.popup_border_thickness }}px;
        --popup-overlay-opacity: {{ settings.popup_overlay_opacity | divided_by: 100.0 }};
        --popup-overlay-color: {{ settings.popup_overlay_color }};

        {%- comment -%} Prices {%- endcomment -%}
        --price-sale-color: {{ settings.price_sale_color }};
      }

      {% if settings.buttons_uppercase %}
      .btn {
        text-transform: uppercase;
      }
      {% endif %}

      {% if settings.buttons_shadow %}
      .btn {
        box-shadow: 0 4px var(--shadow-blur) rgba(0, 0, 0, var(--shadow-opacity));
      }
      {% endif %}

      input, textarea, select {
        border-radius: var(--inputs-radius);
        border-width: var(--inputs-border-thickness);
        background-color: var(--inputs-bg);
        border-color: var(--inputs-border-color);
      }
      input:focus, textarea:focus, select:focus {
        border-color: var(--inputs-focus-color);
        outline: none;
      }

      .badge--sale {
        background-color: var(--badge-sale-bg);
        color: var(--badge-sale-text);
        border-radius: var(--badge-corner-radius);
      }
      .badge--sold-out {
        background-color: var(--badge-sold-out-bg);
        color: var(--badge-sold-out-text);
        border-radius: var(--badge-corner-radius);
      }

      .price--sale { color: var(--price-sale-color); }

      .modal-overlay, .drawer-overlay {
        background-color: var(--drawer-overlay-color);
        opacity: var(--drawer-overlay-opacity);
      }
      .modal-overlay {
        opacity: var(--popup-overlay-opacity);
        background-color: var(--popup-overlay-color);
      }

      {% unless settings.popup_show_overlay %}
      .modal-overlay { display: none; }
      {% endunless %}

      {% if settings.animations_reveal_on_scroll %}
      .animate-on-scroll {
        opacity: 0;
        transition: opacity 0.5s ease, transform 0.5s ease;
      }
      {% if settings.animations_type == 'slide-in' %}
      .animate-on-scroll { transform: translateY(20px); }
      .animate-on-scroll.is-visible { opacity: 1; transform: translateY(0); }
      {% elsif settings.animations_type == 'zoom' %}
      .animate-on-scroll { transform: scale(0.95); }
      .animate-on-scroll.is-visible { opacity: 1; transform: scale(1); }
      {% else %}
      .animate-on-scroll.is-visible { opacity: 1; }
      {% endif %}
      {% endif %}

      {% if settings.animations_hover_images %}
      .card__media img, .product-card img {
        transition: transform 0.4s ease;
      }
      .card__media:hover img, .product-card:hover img {
        transform: scale(1.05);
      }
      {% endif %}
    </style>

    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'main.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="template-{{ template.name }}">
    <a class="skip-to-content" href="#MainContent">
      Skip to content
    </a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.quantity_error' | t }}`
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`
      };
    </script>
  </body>
</html>
